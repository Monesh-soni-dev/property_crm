<div class="mb-6">
  <nav class="text-sm text-gray-500 mb-2">
    <%= link_to "Leads", leads_path, class: "hover:text-gray-900" %> / <%= @lead.name %>
  </nav>
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-['Playfair_Display'] font-semibold"><%= @lead.name %></h1>
    <div class="flex gap-3">
      <%= link_to "Edit Lead", edit_lead_path(@lead), 
          class: "bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700 transition" %>
      <%= link_to "Delete", lead_path(@lead), method: :delete, 
          confirm: "Are you sure you want to delete this lead?",
          class: "bg-red-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-red-700 transition" %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main Lead Information -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Customer Information -->
    <div class="bg-white rounded-lg border border-gray-200 p-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">Customer Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Name</p>
          <p class="font-medium"><%= @lead.name %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Phone</p>
          <p class="font-medium"><%= @lead.phone %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Email</p>
          <p class="font-medium"><%= @lead.email.presence || 'Not provided' %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Source</p>
          <p class="font-medium capitalize"><%= @lead.source&.humanize || 'Not specified' %></p>
        </div>
      </div>
    </div>

    <!-- Property Information -->
    <div class="bg-white rounded-lg border border-gray-200 p-6">
      <h2 class="text-lg font-medium text-gray-900 mb-4">Property Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Property Name</p>
          <p class="font-medium"><%= @lead.property_name.presence || @lead.property&.name || 'Not specified' %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Location</p>
          <p class="font-medium"><%= @lead.property_location.presence || @lead.property&.location || 'Not specified' %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Property Type</p>
          <p class="font-medium capitalize"><%= @lead.property_type&.humanize || 'Not specified' %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Budget</p>
          <% if @lead.budget.present? && @lead.budget.to_f > 0 %>
            <p class="font-medium text-green-600">₹<%= number_to_currency(@lead.budget, unit: '', precision: 0, delimiter: ',') %></p>
          <% else %>
            <p class="font-medium">Not specified</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Notes -->
    <% if @lead.notes.present? %>
      <div class="bg-white rounded-lg border border-gray-200 p-6">
        <h2 class="text-lg font-medium text-gray-900 mb-4">Notes</h2>
        <p class="text-gray-700 whitespace-pre-wrap"><%= @lead.notes %></p>
      </div>
    <% end %>

    <!-- Activities Section -->
    <div class="bg-white rounded-lg border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium text-gray-900">Activities</h2>
        <button class="text-blue-600 hover:text-blue-800 text-sm">Add Activity</button>
      </div>
      
      <% if @lead.activities.any? %>
        <div class="space-y-3">
          <% @lead.activities.recent.each do |activity| %>
            <div class="flex gap-3 p-3 border border-gray-200 rounded-lg">
              <div class="flex-1">
                <p class="text-sm text-gray-900"><%= activity.description %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= activity.activity_type&.humanize %> • 
                  <%= time_ago_in_words(activity.occurred_at) %> ago
                </p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-center py-8">No activities recorded yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Status Card -->
    <div class="bg-white rounded-lg border border-gray-200 p-6">
      <h3 class="text-lg font-medium text-gray-900 mb-4">Lead Status</h3>
      <div class="space-y-3">
        <div>
          <p class="text-sm text-gray-500">Current Stage</p>
          <span class="inline-flex px-3 py-1 text-sm font-medium rounded-full
            <%= case @lead.stage
                when 'new_lead'
                  'bg-gray-100 text-gray-800'
                when 'contacted'
                  'bg-blue-100 text-blue-800'
                when 'interested'
                  'bg-green-100 text-green-800'
                when 'visit_scheduled'
                  'bg-yellow-100 text-yellow-800'
                when 'negotiation'
                  'bg-orange-100 text-orange-800'
                when 'closed'
                  'bg-emerald-100 text-emerald-800'
                when 'rejected'
                  'bg-red-100 text-red-800'
                else
                  'bg-gray-100 text-gray-800'
                end %>">
            <%= @lead.stage.humanize %>
          </span>
        </div>
        
        <div>
          <p class="text-sm text-gray-500">Follow Up Date</p>
          <% if @lead.follow_up_date %>
            <p class="font-medium <%= 'text-red-600' if @lead.follow_up_date == Date.current %>">
              <%= @lead.follow_up_date.strftime("%B %d, %Y") %>
              <% if @lead.follow_up_date == Date.current %>
                <span class="text-xs text-red-600">(Today)</span>
              <% elsif @lead.follow_up_date < Date.current %>
                <span class="text-xs text-red-600">(Overdue)</span>
              <% end %>
            </p>
          <% else %>
            <p class="text-gray-400">Not set</p>
          <% end %>
        </div>
        
        <div>
          <p class="text-sm text-gray-500">Created</p>
          <p class="font-medium"><%= @lead.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
        </div>
        
        <% if @lead.updated_at != @lead.created_at %>
          <div>
            <p class="text-sm text-gray-500">Last Updated</p>
            <p class="font-medium"><%= time_ago_in_words(@lead.updated_at) %> ago</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Project/Property Links -->
    <% if @lead.project || @lead.property %>
      <div class="bg-white rounded-lg border border-gray-200 p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Associated</h3>
        <div class="space-y-2">
          <% if @lead.project %>
            <div>
              <p class="text-sm text-gray-500">Project</p>
              <%= link_to @lead.project.name, project_path(@lead.project), 
                  class: "text-blue-600 hover:text-blue-800" %>
            </div>
          <% end %>
          
          <% if @lead.property %>
            <div>
              <p class="text-sm text-gray-500">Property</p>
              <%= link_to @lead.property.name, property_path(@lead.property), 
                  class: "text-blue-600 hover:text-blue-800" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>