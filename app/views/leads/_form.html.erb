<%= form_with model: lead, local: true, class: "space-y-6" do |f| %>
  <% if lead.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc list-inside">
              <% lead.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Customer Information -->
    <div class="space-y-4">
      <h3 class="text-lg font-medium text-gray-900">Customer Information</h3>
      
      <div>
        <%= f.label :customer_name, "Customer Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :customer_name, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "Full name" %>
      </div>
      
      <div>
        <%= f.label :customer_phone, "Phone Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :customer_phone, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "10-digit phone number" %>
      </div>
      
      <div>
        <%= f.label :customer_email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :customer_email, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "email@example.com" %>
      </div>
    </div>

    <!-- Property Information -->
    <div class="space-y-4">
      <h3 class="text-lg font-medium text-gray-900">Property Information</h3>
      
      <div>
        <%= f.label :property_name, "Property Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :property_name, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "Property name or description" %>
      </div>
      
      <div>
        <%= f.label :property_location, "Location", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :property_location, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "City, area, or address" %>
      </div>
      
      <div>
        <%= f.label :property_type, "Property Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :property_type, 
            options_for_select([
              ["Select property type", ""],
              ["Apartment", "apartment"],
              ["Villa", "villa"],
              ["Plot", "plot"],
              ["Commercial", "commercial"],
              ["Other", "other"]
            ], lead.property_type), 
            {}, 
            { class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
      </div>
    </div>
  </div>

  <!-- Lead Details -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <%= f.label :budget, "Budget (₹)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :budget, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "Expected budget" %>
    </div>
    
    <div>
      <%= f.label :source, "Lead Source", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :source, 
          options_for_select([
            ["Select source", ""],
            ["Website", "website"],
            ["Referral", "referral"],
            ["Advertisement", "advertisement"],
            ["Social Media", "social_media"],
            ["Phone Call", "phone_call"],
            ["Walk-in", "walk_in"],
            ["Other", "other"]
          ], lead.source), 
          {}, 
          { class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
    </div>
    
    <div>
      <%= f.label :stage, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :stage, 
          options_for_select(Lead.stages.keys.map { |k| [k.humanize, k] }, lead.stage), 
          {}, 
          { class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
    </div>
  </div>

  <div>
    <%= f.label :follow_up_date, "Follow Up Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.date_field :follow_up_date, class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :notes, rows: 4, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "Any additional notes or comments..." %>
  </div>

  <!-- Hidden fields for optional associations -->
  <%= f.hidden_field :project_id if lead.project_id %>
  <%= f.hidden_field :property_id if lead.property_id %>

  <div class="flex gap-3 pt-4">
    <%= f.submit (lead.new_record? ? "Create Lead" : "Update Lead"), 
        class: "bg-blue-600 text-white px-6 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition" %>
    <%= link_to "Cancel", (lead.new_record? ? leads_path : lead_path(lead)), 
        class: "bg-gray-500 text-white px-6 py-2 rounded-md text-sm font-medium hover:bg-gray-600 transition" %>
  </div>
<% end %>