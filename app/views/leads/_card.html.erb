<%= turbo_frame_tag "lead_#{lead.id}" do %>
  <%= link_to lead_path(lead),
        id: "lead_#{lead.id}",
        class: "block bg-white border border-gray-200 rounded-lg p-2.5 hover:border-blue-400 transition cursor-pointer" do %>
    <p class="text-xs font-semibold text-gray-800 mb-0.5"><%= lead.name %></p>
    <p class="text-[11px] text-gray-400"><%= lead.project.name %></p>
    <p class="text-[11px] text-green-600 font-medium mt-1">
      ₹<%= number_to_human(lead.budget, units: { thousand: 'L', lakh: 'Cr' }) %> budget
    </p>
    <div class="flex items-center justify-between mt-2">
      <span class="text-[10px] px-2 py-0.5 rounded-full
        <%= lead.source == 'website' ? 'bg-blue-50 text-blue-700' : lead.source == 'referral' ? 'bg-green-50 text-green-700' : 'bg-purple-50 text-purple-700' %>">
        <%= lead.source.humanize %>
      </span>
      <span class="text-[10px] text-gray-400"><%= lead.created_at.strftime("%d %b") %></span>
    </div>
  <% end %>
<% end %>