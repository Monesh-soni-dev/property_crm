<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-['Playfair_Display'] font-semibold">Lead Management</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @pagy ? @pagy.count : @leads.count %> leads</p>
  </div>
  <div class="flex gap-3">
    <%= link_to "View Interests", interests_path,
          class: "flex items-center gap-1.5 bg-green-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-600 transition" %>
    <%= link_to "New Lead", new_lead_path,
          class: "flex items-center gap-1.5 bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-600 transition" %>
  </div>
</div>

<!-- Filters -->
<div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
  <%= form_with url: leads_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do |f| %>
    <div class="flex-1 min-w-48">
      <%= f.label :search, "Search", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :search, value: params[:search], placeholder: "Name, phone, property...", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    
    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, options_for_select([["All Statuses", ""]] + Lead.stages.keys.map { |k| [k.humanize, k] }, params[:status]), {}, { class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
    </div>
    
    <div>
      <%= f.label :follow_up, "Follow Up", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :follow_up, options_for_select([["All", ""], ["Today", "today"], ["Upcoming", "upcoming"]], params[:follow_up]), {}, { class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
    </div>
    
    <div>
      <%= f.submit "Filter", class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700 transition" %>
      <%= link_to "Reset", leads_path, class: "ml-2 text-gray-600 hover:text-gray-900 text-sm" %>
    </div>
  <% end %>
</div>

<!-- Leads Table -->
<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Customer</th>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Phone</th>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Property</th>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Budget</th>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Status</th>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Follow Up</th>
          <th class="text-left py-3 px-4 font-medium text-sm text-gray-900">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @leads.each do |lead| %>
          <tr class="hover:bg-gray-50 <%= 'bg-yellow-50' if lead.follow_up_date == Date.current %>">
            <td class="py-3 px-4">
              <div>
                <p class="font-medium text-gray-900"><%= lead.customer_name %></p>
                <p class="text-sm text-gray-500"><%= lead.email %></p>
              </div>
            </td>
            <td class="py-3 px-4 text-sm text-gray-900"><%= lead.phone %></td>
            <td class="py-3 px-4">
              <div>
                <% if lead.property&.title %>
                  <p class="text-sm text-gray-900"><%= lead.property.title %></p>
                  <p class="text-xs text-gray-500"><%= lead.property.project&.name || 'Project not set' %></p>
                <% elsif lead.property_name.present? %>
                  <p class="text-sm text-gray-900"><%= lead.property_name %></p>
                  <p class="text-xs text-gray-500"><%= lead.property_location || 'Location not set' %></p>
                <% else %>
                  <p class="text-sm text-gray-400">Property not specified</p>
                <% end %>
              </div>
            </td>
            <td class="py-3 px-4">
              <% if lead.budget.present? %>
                <% begin %>
                  <% budget_value = lead.budget.to_f %>
                  <% if budget_value > 0 %>
                    <span class="text-sm text-green-600 font-medium">₹<%= number_to_currency(budget_value, unit: '', precision: 0, delimiter: ',') %></span>
                  <% else %>
                    <span class="text-sm text-gray-400">Budget not set</span>
                  <% end %>
                <% rescue %>
                  <span class="text-sm text-gray-400">Invalid budget</span>
                <% end %>
              <% else %>
                <span class="text-sm text-gray-400">N/A</span>
              <% end %>
            </td>
            <td class="py-3 px-4">
              <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full
                <%= case lead.stage
                    when 'new_lead'
                      'bg-gray-100 text-gray-800'
                    when 'contacted'
                      'bg-blue-100 text-blue-800'
                    when 'interested'
                      'bg-green-100 text-green-800'
                    when 'visit_scheduled'
                      'bg-yellow-100 text-yellow-800'
                    when 'negotiation'
                      'bg-orange-100 text-orange-800'
                    when 'closed'
                      'bg-emerald-100 text-emerald-800'
                    when 'rejected'
                      'bg-red-100 text-red-800'
                    else
                      'bg-gray-100 text-gray-800'
                    end %>">
                <%= lead.stage&.humanize || 'Unknown Stage' %>
              </span>
            </td>
            <td class="py-3 px-4">
              <% if lead.follow_up_date %>
                <span class="text-sm <%= 'text-red-600 font-medium' if lead.follow_up_date == Date.current %>">
                  <%= lead.follow_up_date.strftime("%b %d, %Y") %>
                </span>
              <% else %>
                <span class="text-sm text-gray-400">Not set</span>
              <% end %>
            </td>
            <td class="py-3 px-4">
              <div class="flex gap-2">
                <%= link_to "View", lead_path(lead), class: "text-blue-600 hover:text-blue-900 text-sm" %>
                <%= link_to "Edit", edit_lead_path(lead), class: "text-gray-600 hover:text-gray-900 text-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <% if @leads.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No leads found.</p>
      <%= link_to "Create your first lead", new_lead_path, class: "text-blue-600 hover:text-blue-900" %>
    </div>
  <% end %>
</div>

<!-- Pagination -->
<% if @pagy && @pagy.pages > 1 %>
  <div class="mt-6 pt-4 border-t border-gray-200">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">

      <!-- Count info -->
      <p class="text-sm text-gray-500 order-2 sm:order-1">
        Showing
        <span class="font-semibold text-gray-800"><%= @pagy.from %></span>
        –
        <span class="font-semibold text-gray-800"><%= @pagy.to %></span>
        of
        <span class="font-semibold text-gray-800"><%= @pagy.count %></span>
        leads
      </p>

      <!-- Page buttons -->
      <div class="flex items-center gap-1.5 order-1 sm:order-2">

        <% if @pagy.previous %>
          <% prev_url = @pagy.previous == 1 ? url_for(request.query_parameters.except("page")) : url_for(request.query_parameters.merge("page" => @pagy.previous)) %>
          <%= link_to prev_url, class: "inline-flex items-center gap-1.5 px-3 h-9 rounded-lg border border-gray-300 bg-white text-sm font-medium text-gray-600 hover:bg-blue-50 hover:border-blue-400 hover:text-blue-600 transition-colors shadow-sm" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <span class="hidden sm:inline">Prev</span>
          <% end %>
        <% else %>
          <span class="inline-flex items-center gap-1.5 px-3 h-9 rounded-lg border border-gray-200 bg-gray-50 text-sm font-medium text-gray-300 cursor-not-allowed shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <span class="hidden sm:inline">Prev</span>
          </span>
        <% end %>

        <% pagy_series(@pagy).each do |item| %>
          <% if item == :gap %>
            <span class="inline-flex items-center justify-center w-9 h-9 text-gray-400 text-sm select-none">…</span>
          <% elsif item.is_a?(String) %>
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-blue-600 text-white text-sm font-bold shadow-md ring-2 ring-blue-200">
              <%= item %>
            </span>
          <% else %>
            <% page_url = item == 1 ? url_for(request.query_parameters.except("page")) : url_for(request.query_parameters.merge("page" => item)) %>
            <%= link_to item, page_url, class: "inline-flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-blue-50 hover:border-blue-400 hover:text-blue-600 transition-colors shadow-sm" %>
          <% end %>
        <% end %>

        <% if @pagy.next %>
          <% next_url = url_for(request.query_parameters.merge("page" => @pagy.next)) %>
          <%= link_to next_url, class: "inline-flex items-center gap-1.5 px-3 h-9 rounded-lg border border-gray-300 bg-white text-sm font-medium text-gray-600 hover:bg-blue-50 hover:border-blue-400 hover:text-blue-600 transition-colors shadow-sm" do %>
            <span class="hidden sm:inline">Next</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        <% else %>
          <span class="inline-flex items-center gap-1.5 px-3 h-9 rounded-lg border border-gray-200 bg-gray-50 text-sm font-medium text-gray-300 cursor-not-allowed shadow-sm">
            <span class="hidden sm:inline">Next</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </span>
        <% end %>

      </div>
    </div>
  </div>
<% end %>