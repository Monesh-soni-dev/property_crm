<% breadcrumbs ["Account Settings", "#"] %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="bg-white rounded-2xl shadow-lg border border-gray-200">
    <div class="p-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Account Settings</h1>
        <p class="text-gray-600">Update your profile information and account preferences</p>
      </div>

      <%= form_with(model: @user, url: account_settings_path, method: :patch, 
                  class: "space-y-6", 
                  data: { turbo: true }) do |form| %>
        
        <!-- Profile Photo Section -->
        <div class="mb-8">
          <div class="flex items-center gap-6">
            <div class="flex-shrink-0">
              <div class="relative">
                <% if @user.photo.attached? %>
                  <%= image_tag @user.photo, class: "h-24 w-24 rounded-full object-cover border-4 border-gray-300" %>
                <% else %>
                  <div class="h-24 w-24 rounded-full bg-gray-200 border-4 border-gray-300 flex items-center justify-center">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                  </div>
                </div>
              </div>
              
              <div class="flex-1">
                <div>
                  <%= form.label :photo, class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.file_field :photo, class: "block w-full text-sm text-gray-900 border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
                  <p class="mt-2 text-xs text-gray-500">Upload a new profile photo (JPG, PNG, max 5MB)</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Personal Information Section -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :first_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :first_name, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <div>
            <%= form.label :last_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :last_name, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div>
          <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :phone, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.telephone_field :phone, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <div>
            <%= form.label :city, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :city, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div>
          <%= form.label :address, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :address, rows: 3, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :bio, rows: 4, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <!-- Submit Button -->
        <div class="flex items-center justify-end gap-4 mt-8">
          <%= form.submit "Update Account Settings", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" %>
          <%= link_to "Cancel", account_settings_path, class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition-all duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
