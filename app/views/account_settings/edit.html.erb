<% breadcrumbs ["Account Settings", "#"] %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="bg-white rounded-2xl shadow-lg border border-gray-200">
    <div class="p-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Account Settings</h1>
        <p class="text-gray-600">Update your profile information and account preferences</p>
      </div>

      <%= form_with(model: @user, url: account_settings_path, method: :patch,
                  class: "space-y-6",
                  multipart: true,
                  data: { turbo: false }) do |form| %>
        
        <!-- Profile Photo Section -->
        <div class="mb-8">
          <div class="flex items-center gap-6">
            <div class="flex-shrink-0">
              <div class="relative">
                <% if @user.photo.attached? %>
                  <%= image_tag @user.photo, class: "h-24 w-24 rounded-full object-cover border-4 border-gray-300" %>
                <% else %>
                  <div class="h-24 w-24 rounded-full bg-gray-200 border-4 border-gray-300 flex items-center justify-center">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                  </div>
                <% end %>
              
              <div class="flex-1">
                <div>
                  <%= form.label :photo, class: "block text-sm font-medium text-gray-700 mb-2" %>
                  <%= form.file_field :photo, class: "block w-full text-sm text-gray-900 border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
                  <p class="mt-2 text-xs text-gray-500">Upload a new profile photo (JPG, PNG, max 5MB)</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Personal Information Section -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :first_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :first_name, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <div>
            <%= form.label :last_name, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :last_name, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div>
          <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :mobile_number, "Mobile Number", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.telephone_field :mobile_number, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
          
          <div>
            <%= form.label :city, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :city, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :state, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :state, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>

          <div>
            <%= form.label :pincode, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :pincode, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div>
          <%= form.label :address, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :address, rows: 3, class: "w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <!-- Submit Button -->
        <div class="flex items-center justify-end gap-4 mt-8">
          <%= form.submit "Update Account Settings", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" %>
          <%= link_to "Cancel", edit_account_settings_path, class: "px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition-all duration-200" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Danger Zone -->
  <div class="bg-white rounded-2xl shadow-lg border-2 border-red-200 mt-8">
    <div class="p-8">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16c-.77.833.192 2.5 1.732 2.5z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-red-700">Danger Zone</h2>
      </div>
      <p class="text-sm text-gray-600 mb-6">Once you delete your account, all your data will be permanently removed. This action <strong>cannot be undone</strong>.</p>

      <button type="button" onclick="document.getElementById('deleteAccountModal').classList.remove('hidden')"
              class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-lg transition-colors">
        Delete My Account
      </button>
    </div>
  </div>
</div>

<!-- Delete Account Modal -->
<div id="deleteAccountModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm px-4">
  <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full border-2 border-red-200">
    <!-- Modal Header -->
    <div class="bg-red-50 rounded-t-2xl px-6 py-5 border-b border-red-200">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-red-800">Permanently Delete Account</h3>
          <p class="text-xs text-red-600">This action is irreversible</p>
        </div>
      </div>
    </div>

    <!-- Modal Body -->
    <div class="px-6 py-5">
      <!-- Consequences List -->
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-5">
        <p class="text-sm font-semibold text-red-800 mb-2">By deleting your account, you will permanently lose:</p>
        <ul class="text-sm text-red-700 space-y-1 list-none">
          <li class="flex items-center gap-2"><svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="3"/></svg> Your profile and personal information</li>
          <li class="flex items-center gap-2"><svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="3"/></svg> All your leads and activity history</li>
          <li class="flex items-center gap-2"><svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="3"/></svg> All projects and properties you created</li>
          <li class="flex items-center gap-2"><svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="3"/></svg> Access to this account — you cannot recover it</li>
        </ul>
      </div>

      <!-- Terms Checkbox -->
      <div class="flex items-start gap-3 mb-5 p-3 bg-yellow-50 border border-yellow-200 rounded-xl">
        <input type="checkbox" id="agreeTerms" onchange="updateDeleteBtn()"
               class="mt-0.5 w-4 h-4 border-2 border-yellow-400 rounded text-red-600 focus:ring-red-500 shrink-0">
        <label for="agreeTerms" class="text-sm text-yellow-800 cursor-pointer">
          I understand this is <strong>permanent and irreversible</strong>. I have read and accept the consequences of deleting my account.
        </label>
      </div>

      <%= form_with url: account_settings_path, method: :delete, local: true, id: "deleteAccountForm", data: { turbo: false } do %>
        <!-- Password Confirmation -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Enter your current password to confirm</label>
          <%= password_field_tag :current_password, '', required: true, placeholder: "Your current password",
              class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500" %>
        </div>

        <!-- Type DELETE MY ACCOUNT -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Type <span class="font-mono font-bold text-red-700 bg-red-50 px-1 rounded">DELETE MY ACCOUNT</span> to confirm
          </label>
          <%= text_field_tag :delete_confirmation, '', required: true, placeholder: "DELETE MY ACCOUNT",
              autocomplete: "off",
              oninput: "updateDeleteBtn()",
              id: "deleteConfirmInput",
              class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm font-mono focus:ring-2 focus:ring-red-500 focus:border-red-500" %>
        </div>

        <div class="flex gap-3">
          <button type="button" onclick="document.getElementById('deleteAccountModal').classList.add('hidden')"
                  class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
            Cancel — Keep My Account
          </button>
          <%= submit_tag "Permanently Delete Account",
              id: "deleteSubmitBtn",
              disabled: true,
              class: "flex-1 px-4 py-2.5 bg-red-300 text-white text-sm font-semibold rounded-lg cursor-not-allowed transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  function updateDeleteBtn() {
    const agreed = document.getElementById('agreeTerms').checked;
    const typed = document.getElementById('deleteConfirmInput').value.trim();
    const btn = document.getElementById('deleteSubmitBtn');

    if (agreed && typed === 'DELETE MY ACCOUNT') {
      btn.disabled = false;
      btn.classList.remove('bg-red-300', 'cursor-not-allowed');
      btn.classList.add('bg-red-600', 'hover:bg-red-700', 'cursor-pointer');
    } else {
      btn.disabled = true;
      btn.classList.remove('bg-red-600', 'hover:bg-red-700', 'cursor-pointer');
      btn.classList.add('bg-red-300', 'cursor-not-allowed');
    }
  }

  // Close modal on backdrop click
  document.getElementById('deleteAccountModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.add('hidden');
  });
</script>
