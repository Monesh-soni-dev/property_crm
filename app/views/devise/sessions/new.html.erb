<div class="bg-white rounded-lg shadow-md border border-gray-200 p-8">
  <%# Header %>
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Welcome back</h1>
    <p class="text-gray-600">Sign in to your PlotPlans account</p>
  </div>

  <%= render "devise/shared/error_messages", resource: resource %>

  <%# Social / Alternative Login Buttons %>
  <div class="space-y-3 mb-6">
    <%# Google Sign-In — must POST to satisfy omniauth-rails_csrf_protection %>
    <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post,
        class: "w-full flex items-center justify-center gap-3 px-4 py-2.5 border border-gray-300 rounded-lg hover:bg-gray-50 transition font-medium text-gray-700 text-sm bg-white cursor-pointer" do %>
      <svg class="w-5 h-5 pointer-events-none" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      Continue with Google
    <% end %>

    <%# Phone OTP Sign-In %>
    <%= link_to phone_login_path,
        class: "w-full flex items-center justify-center gap-3 px-4 py-2.5 border border-gray-300 rounded-lg hover:bg-gray-50 transition font-medium text-gray-700 text-sm" do %>
      <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      Login with Mobile OTP
    <% end %>
  </div>

  <%# Divider %>
  <div class="mb-6 relative">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-gray-300"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="px-2 bg-white text-gray-500">or sign in with email</span>
    </div>
  </div>

  <%# Sign in Form %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), local: true) do |f| %>
    <div class="space-y-5">
      <%# Email Field %>
      <div>
        <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
            placeholder: "your@email.com" %>
      </div>

      <%# Password Field %>
      <div>
        <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
            placeholder: "••••••••" %>
      </div>

      <%# Remember & Forgot Password %>
      <div class="flex items-center justify-between text-sm">
        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :remember_me, class: "w-4 h-4 border border-gray-300 rounded text-blue-600" %>
            <span class="text-gray-700">Remember me</span>
          </label>
        <% end %>
        <% if devise_mapping.recoverable? %>
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-blue-600 hover:text-blue-700 font-medium" %>
        <% end %>
      </div>

      <%# Submit Button %>
      <%= f.submit "Sign in", class: "w-full bg-blue-600 text-white font-semibold py-2.5 rounded-lg hover:bg-blue-700 transition" %>
    </div>
  <% end %>

  <%# Divider %>
  <div class="mt-6 mb-6 relative">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-gray-300"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="px-2 bg-white text-gray-500">Don't have an account?</span>
    </div>
  </div>

  <%# Links %>
  <div class="text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>

