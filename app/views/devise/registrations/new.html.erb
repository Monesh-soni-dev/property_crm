<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
  <div class="w-full">
    <!-- Professional Header Section -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center space-x-6 mb-10">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center shadow-2xl">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h6a2 2 0 002 2v6a2 2 0 002-2H7a2 2 0 01-2-2v-6a2 2 0 012-2h6a2 2 0 012 2v6"></path>
          </svg>
        </div>
        <h1 class="text-5xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent">
          PlotPlans
        </h1>
      </div>
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Create Your Account</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Join thousands of property professionals who trust PlotPlans for efficient property management
      </p>
    </div>

    <!-- Professional Form -->
    <div class="w-full">

      <!-- Form Content -->
      <div class="px-4 lg:px-8">

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true, 
          html: { multipart: true }) do |f| %>
        
        <div class="space-y-8">
          <!-- Personal Information Section -->
          <div class="mb-12">
            <div class="flex items-center mb-8">
              <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mr-6">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900">Personal Information</h3>
                <p class="text-base text-gray-600">Tell us about yourself</p>
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= f.label :first_name, "First Name", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.text_field :first_name, autocomplete: "given-name",
                    class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                    placeholder: "John" %>
                <% if resource.errors[:first_name].any? %>
                  <p class="mt-2 text-sm text-red-600"><%= resource.errors[:first_name].first %></p>
                <% end %>
              </div>

              <div>
                <%= f.label :last_name, "Last Name (Optional)", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.text_field :last_name, autocomplete: "family-name",
                    class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                    placeholder: "Doe" %>
                <% if resource.errors[:last_name].any? %>
                  <p class="mt-2 text-sm text-red-600"><%= resource.errors[:last_name].first %></p>
                <% end %>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= f.label :email, "Email Address", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                    class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                    placeholder: "you@example.com" %>
                <% if resource.errors[:email].any? %>
                  <p class="mt-2 text-sm text-red-600"><%= resource.errors[:email].first %></p>
                <% end %>
              </div>

              <div>
                <%= f.label :mobile_number, "Mobile Number *", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.telephone_field :mobile_number, autocomplete: "tel",
                    class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                    placeholder: "9876543210",
                    maxlength: 10,
                    required: true %>
                <% if resource.errors[:mobile_number].any? %>
                  <p class="mt-2 text-sm text-red-600"><%= resource.errors[:mobile_number].first %></p>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Location Information Section -->
          <div class="mb-12">
            <div class="flex items-center mb-8">
              <div class="w-12 h-12 bg-green-600 rounded-lg flex items-center justify-center mr-6">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-1.414.586l-4.243-4.242a1 1 0 01-.707 0l-4.242 4.243a1 1 0 01-1.415 1.414L16.657 16.657z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900">Location Information</h3>
                <p class="text-base text-gray-600">Where are you located? (Optional)</p>
              </div>
            </div>
            
            <div class="space-y-6">
              <div>
                <%= f.label :address, "Street Address", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.text_area :address, rows: 4, autocomplete: "street-address",
                    class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition resize-none shadow-md",
                    placeholder: "123 Main Street, Apartment 4B" %>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                  <%= f.label :city, "City", class: "block text-base font-semibold text-gray-700 mb-3" %>
                  <%= f.text_field :city, autocomplete: "address-level2",
                      class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                      placeholder: "New York" %>
                </div>
                <div>
                  <%= f.label :state, "State", class: "block text-base font-semibold text-gray-700 mb-3" %>
                  <%= f.text_field :state, autocomplete: "address-level1",
                      class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                      placeholder: "NY" %>
                </div>
                <div>
                  <%= f.label :pincode, "Pincode", class: "block text-base font-semibold text-gray-700 mb-3" %>
                  <%= f.text_field :pincode, autocomplete: "postal-code",
                      class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                      placeholder: "10001",
                      maxlength: 6 %>
                </div>
              </div>
            </div>
          </div>

          <!-- Account Details Section -->
          <div class="mb-12">
            <div class="flex items-center mb-8">
              <div class="w-12 h-12 bg-purple-600 rounded-lg flex items-center justify-center mr-6">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c-.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-1.543.94-3.31.826-2.37 2.37a1.724 1.724 0 00-1.065-2.572C18.375 1.998 18.375.325 19.125.325c.75 0 1.088.699 1.088 1.563v1.375c0 .864-.338 1.563-1.088 1.563-.75 0-1.125-.699-1.125-1.563v-1.375c0-.864.338-1.563 1.088-1.563.75 0 1.125.699 1.125 1.563v-1.375z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900">Account Details</h3>
                <p class="text-base text-gray-600">Set up your account preferences</p>
              </div>
            </div>
            
            <div class="space-y-6">
              <div>
                <%= f.label :role, "I am a", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.select :role, 
                    options_for_select([
                              ['Select your role...', '', { disabled: true, selected: true }],
                              ['Property Customer', 'customer'],
                              ['Builder/Developer', 'builder'], 
                              ['Real Estate Agent', 'agent'],
                              ['Engineer', 'engineer'],
                              ['Administrator', 'admin']
                            ]), {}, {
                              class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                              required: true,
                              'aria-required': true
                            } %>
                <% if resource.errors[:role].any? %>
                  <p class="mt-2 text-sm text-red-600"><%= resource.errors[:role].first %></p>
                <% end %>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="flex flex-col">
                  <%= f.label :password, "Password", class: "block text-base font-semibold text-gray-700 mb-3" %>
                  <% if @minimum_password_length %>
                    <p class="text-sm text-gray-500 mb-2"><%= @minimum_password_length %> characters minimum</p>
                  <% end %>
                  <%= f.password_field :password, autocomplete: "new-password",
                      class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                      placeholder: "Create a strong password" %>
                  <% if resource.errors[:password].any? %>
                    <p class="mt-2 text-sm text-red-600"><%= resource.errors[:password].first %></p>
                  <% end %>
                </div>

                <div class="flex flex-col">
                  <%= f.label :password_confirmation, "Confirm Password", class: "block text-base font-semibold text-gray-700 mb-3" %>
                  <div class="mb-2">
                    <% if @minimum_password_length %>
                      <p class="text-sm text-transparent"><%= @minimum_password_length %> characters minimum</p>
                    <% end %>
                  </div>
                  <%= f.password_field :password_confirmation, autocomplete: "new-password",
                      class: "w-full px-5 py-4 bg-white border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition shadow-md",
                      placeholder: "Re-enter your password" %>
                  <% if resource.errors[:password_confirmation].any? %>
                    <p class="mt-2 text-sm text-red-600"><%= resource.errors[:password_confirmation].first %></p>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <!-- Profile Photo Section -->
          <div class="mb-12">
            <div class="flex items-center mb-8">
              <div class="w-12 h-12 bg-indigo-600 rounded-lg flex items-center justify-center mr-6">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586 1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold text-gray-900">Profile Photo</h3>
                <p class="text-base text-gray-600">Add a photo to personalize your profile</p>
              </div>
            </div>
            
            <div class="flex items-center space-x-8">
              <div class="shrink-0">
                <div id="photo-preview" class="w-32 h-32 rounded-full bg-gray-200 flex items-center justify-center overflow-hidden border-4 border-gray-300">
                  <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                </div>
              </div>
              <div class="flex-1">
                <%= f.label :photo, "Upload Photo", class: "block text-base font-semibold text-gray-700 mb-3" %>
                <%= f.file_field :photo, 
                    class: "w-full text-base text-gray-500 file:mr-4 file:py-4 file:px-4 file:rounded-lg file:border-0 file:text-base file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer",
                    accept: "image/png, image/jpg, image/jpeg",
                    onchange: "previewPhoto(event)" %>
                <p class="text-sm text-gray-500 mt-2">PNG, JPG, or JPEG (max 5MB) - Optional</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Submit Section -->
        <div class="mt-16 pt-8 border-t border-gray-200">
          <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
            <div class="text-lg text-gray-600">
              Already have an account?
              <%= link_to "Sign in here", new_user_session_path, class: "font-semibold text-blue-600 hover:text-blue-500 underline text-xl" %>
            </div>
            
            <div class="flex items-center space-x-6">
              <%= link_to "Learn More", "#", class: "px-8 py-4 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-semibold text-lg" %>
              <%= f.submit "Create Account", class: "px-12 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold rounded-lg hover:from-blue-700 hover:to-indigo-700 transition-all duration-200 shadow-lg text-lg" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function previewPhoto(event) {
  const preview = document.getElementById('photo-preview');
  const file = event.target.files[0];
  
  if (file) {
    const reader = new FileReader();
    
    reader.onload = function(e) {
      preview.innerHTML = `<img src="${e.target.result}" alt="Profile preview" class="w-full h-full object-cover">`;
    };
    
    reader.readAsDataURL(file);
  }
}
</script>
