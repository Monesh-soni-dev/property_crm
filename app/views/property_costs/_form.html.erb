<%= form_with model: @cost, local: true, class: "space-y-6" do |f| %>

  <% if @cost.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% @cost.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title & Category -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-600 to-blue-400 px-6 py-3">
      <h3 class="text-sm font-bold text-white">Cost Details</h3>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4 p-6">

      <div class="md:col-span-2">
        <%= f.label :title, class: "block text-xs font-semibold text-gray-700 mb-1" do %>
          Cost Title <span class="text-red-500">*</span>
        <% end %>
        <%= f.text_field :title, required: true, placeholder: "e.g. RCC Slab Work, Plot Registration, Brokerage...",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :category, class: "block text-xs font-semibold text-gray-700 mb-1" do %>
          Category <span class="text-red-500">*</span>
        <% end %>
        <%= f.select :category,
            options_for_select(PropertyCost::CATEGORIES.map { |c| [c.humanize, c] }, @cost.category),
            {},
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :amount, class: "block text-xs font-semibold text-gray-700 mb-1" do %>
          Amount (₹) <span class="text-red-500">*</span>
        <% end %>
        <%= f.number_field :amount, min: 1, step: 1, required: true,
            placeholder: "Enter amount",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :cost_date, class: "block text-xs font-semibold text-gray-700 mb-1" do %>
          Date <span class="text-red-500">*</span>
        <% end %>
        <%= f.date_field :cost_date, required: true,
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :vendor_name, "Vendor / Contractor", class: "block text-xs font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :vendor_name, placeholder: "Vendor or contractor name (optional)",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :invoice_number, "Invoice / Bill Number", class: "block text-xs font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :invoice_number, placeholder: "Bill or invoice reference (optional)",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :notes, "Notes", class: "block text-xs font-semibold text-gray-700 mb-1" %>
        <%= f.text_area :notes, rows: 2, placeholder: "Any notes about this cost entry",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

    </div>
  </div>

  <!-- Link to Property / Project (optional) -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-teal-600 to-teal-400 px-6 py-3">
      <h3 class="text-sm font-bold text-white">Link to Property / Project <span class="font-normal text-teal-100">(optional)</span></h3>
    </div>
    <div class="p-6">
      <p class="text-xs text-gray-400 mb-4">
        Linking to a property or project enables profit/loss analysis. Leave blank to track as a standalone cost.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>
          <%= f.label :project_id, "Project", class: "block text-xs font-semibold text-gray-700 mb-1" %>
          <%= f.select :project_id,
              options_for_select(
                [['— No Project —', '']] + @projects.map { |p| [p.name, p.id] },
                @cost.project_id
              ),
              {},
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
        </div>

        <div>
          <%= f.label :property_id, "Property", class: "block text-xs font-semibold text-gray-700 mb-1" %>
          <%= f.select :property_id,
              options_for_select(
                [['— No Property —', '']] +
                @properties.map { |p| ["#{p.project.name} — #{p.title} (Unit #{p.unit_number})", p.id] },
                @cost.property_id
              ),
              {},
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
          <p class="text-xs text-gray-400 mt-1">If you select a property, its project is auto-linked.</p>
        </div>

      </div>
    </div>
  </div>

  <!-- Upload Invoice -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="bg-gradient-to-r from-purple-600 to-purple-400 px-6 py-3">
      <h3 class="text-sm font-bold text-white">Attach Invoice / Receipt <span class="font-normal text-purple-100">(optional)</span></h3>
    </div>
    <div class="p-6">
      <% if @cost.persisted? && @cost.invoice.attached? %>
        <div class="flex items-center gap-3 mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="text-sm text-green-700 font-medium">Invoice attached</span>
          <%= link_to "View / Download",
              rails_blob_path(@cost.invoice, disposition: 'attachment'),
              class: "ml-auto text-xs text-blue-600 hover:underline" %>
        </div>
      <% end %>
      <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-purple-400 transition-colors">
        <%= f.file_field :invoice, accept: "application/pdf,image/*",
            class: "w-full text-sm text-gray-600 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100" %>
        <p class="text-xs text-gray-400 mt-2">PDF, JPG, PNG, WEBP — up to 20 MB</p>
      </div>
    </div>
  </div>

  <!-- Submit -->
  <div class="flex gap-3">
    <%= f.submit @cost.new_record? ? "Add Cost Entry" : "Update Cost Entry",
        class: "px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer shadow-md" %>
    <%= link_to "Cancel", property_costs_path,
        class: "px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-semibold transition-colors" %>
  </div>

<% end %>
