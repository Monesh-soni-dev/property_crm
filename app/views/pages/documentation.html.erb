          <p class="text-gray-600 text-center mb-6">Hands-on tutorials for common use cases</p>
          <ul class="space-y-2 text-sm text-gray-700">
            <li>• Setting up your first project</li>
            <li>• Importing existing data</li>
            <li>• Configuring automation</li>
            <li>• Custom reporting setup</li>
            <li>• Integration examples</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Featured Documentation -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Featured Documentation</h2>
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white p-6">
            <h3 class="text-xl font-bold mb-2">Quick Start Guide</h3>
            <p class="text-blue-100">Get up and running with PropertyCRM in under 15 minutes</p>
          </div>
          
          <div class="p-6">
            <div class="space-y-4">
              <div class="flex items-start">
                <div class="bg-blue-100 rounded-full w-8 h-8 flex items-center justify-center mr-4 mt-0.5">
                  <span class="text-blue-600 font-bold text-sm">1</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Account Setup</h4>
                  <p class="text-gray-600 text-sm">Create your account and configure basic settings</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-blue-100 rounded-full w-8 h-8 flex items-center justify-center mr-4 mt-0.5">
                  <span class="text-blue-600 font-bold text-sm">2</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Add Your First Property</h4>
                  <p class="text-gray-600 text-sm">Learn the basics of property management in PropertyCRM</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-blue-100 rounded-full w-8 h-8 flex items-center justify-center mr-4 mt-0.5">
                  <span class="text-blue-600 font-bold text-sm">3</span>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Invite Your Team</h4>
                  <p class="text-gray-600 text-sm">Set up user permissions and collaborate effectively</p>
                </div>
              </div>
            </div>
            
            <div class="mt-6 pt-6 border-t border-gray-100">
              <button class="inline-flex items-center text-blue-600 hover:text-blue-700 font-medium">
                Read Full Guide
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-r from-green-500 to-green-600 text-white p-6">
            <h3 class="text-xl font-bold mb-2">API Integration Guide</h3>
            <p class="text-green-100">Connect PropertyCRM with your existing tools and workflows</p>
          </div>
          
          <div class="p-6">
            <div class="bg-gray-900 rounded-lg p-4 mb-4 text-sm">
              <div class="text-green-400 mb-2">// Example: Create a new property</div>
              <div class="text-gray-300">
                <span class="text-blue-300">POST</span> /api/v1/properties<br>
                <span class="text-purple-300">{</span><br>
                &nbsp;&nbsp;<span class="text-yellow-300">"name"</span>: <span class="text-green-300">"Downtown Condo"</span>,<br>
                &nbsp;&nbsp;<span class="text-yellow-300">"address"</span>: <span class="text-green-300">"123 Main St"</span>,<br>
                &nbsp;&nbsp;<span class="text-yellow-300">"type"</span>: <span class="text-green-300">"residential"</span><br>
                <span class="text-purple-300">}</span>
              </div>
            </div>
            
            <div class="space-y-3 text-sm">
              <div class="flex items-center">
                <svg class="w-4 h-4 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                RESTful API with JSON responses
              </div>
              <div class="flex items-center">
                <svg class="w-4 h-4 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                OAuth 2.0 and API key authentication
              </div>
              <div class="flex items-center">
                <svg class="w-4 h-4 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Webhooks for real-time updates
              </div>
            </div>
            
            <div class="mt-6 pt-6 border-t border-gray-100">
              <button class="inline-flex items-center text-green-600 hover:text-green-700 font-medium">
                View API Docs
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Documentation Sections -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Complete Documentation</h2>
      
      <div class="grid lg:grid-cols-3 gap-8">
        <!-- User Documentation Column -->
