                <span class="text-xs text-red-600 font-medium">10 min read</span>
              </article>
            </div>
          </div>
        </div>

        <!-- Developer Documentation Column -->
        <div class="space-y-6">
          <h3 class="text-lg font-bold text-gray-900 border-b-2 border-green-200 pb-2">Developer Documentation</h3>
          
          <div class="bg-white rounded-lg shadow border border-gray-100">
            <div class="p-6 space-y-4">
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">API Overview</h4>
                <p class="text-gray-600 text-sm mb-2">Authentication, rate limits, and best practices</p>
                <span class="text-xs text-blue-600 font-medium">Tech Guide</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Properties API</h4>
                <p class="text-gray-600 text-sm mb-2">CRUD operations for property data</p>
                <span class="text-xs text-green-600 font-medium">Reference</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Leads API</h4>
                <p class="text-gray-600 text-sm mb-2">Manage leads and prospect information</p>
                <span class="text-xs text-purple-600 font-medium">Reference</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Webhooks</h4>
                <p class="text-gray-600 text-sm mb-2">Real-time event notifications</p>
                <span class="text-xs text-orange-600 font-medium">Integration</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">SDKs & Libraries</h4>
                <p class="text-gray-600 text-sm mb-2">Official client libraries and tools</p>
                <span class="text-xs text-red-600 font-medium">Downloads</span>
              </article>
            </div>
          </div>
        </div>

        <!-- Tutorials Column -->
        <div class="space-y-6">
          <h3 class="text-lg font-bold text-gray-900 border-b-2 border-purple-200 pb-2">Tutorials & Examples</h3>
          
          <div class="bg-white rounded-lg shadow border border-gray-100">
            <div class="p-6 space-y-4">
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Build a Property Dashboard</h4>
                <p class="text-gray-600 text-sm mb-2">Create a custom dashboard with our API</p>
                <span class="text-xs text-blue-600 font-medium">Tutorial</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Automated Lead Capture</h4>
                <p class="text-gray-600 text-sm mb-2">Set up automatic lead imports from forms</p>
                <span class="text-xs text-green-600 font-medium">Tutorial</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Custom Reports</h4>
                <p class="text-gray-600 text-sm mb-2">Generate tailored analytics and insights</p>
                <span class="text-xs text-purple-600 font-medium">Tutorial</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Third-party Integrations</h4>
                <p class="text-gray-600 text-sm mb-2">Connect with CRM and accounting tools</p>
                <span class="text-xs text-orange-600 font-medium">Tutorial</span>
              </article>
              
              <article class="pb-4 border-b border-gray-100 last:border-b-0">
                <h4 class="font-semibold text-gray-900 mb-1">Data Migration Guide</h4>
                <p class="text-gray-600 text-sm mb-2">Import from legacy property systems</p>
                <span class="text-xs text-red-600 font-medium">Tutorial</span>
              </article>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Additional Resources -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Additional Resources</h2>
      
