<% content_for :title, @page_title %>
<div class="min-h-screen bg-gradient-to-b from-gray-50 to-white">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">About PropertyCRM</h1>
        <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
          Transforming property management with innovative technology and unparalleled service excellence.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- Mission Section -->
    <section class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Mission</h2>
        <div class="w-24 h-1 bg-blue-500 mx-auto rounded-full"></div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-100">
            <h3 class="text-2xl font-semibold text-gray-900 mb-4">Empowering Property Professionals</h3>
            <p class="text-gray-600 leading-relaxed mb-6">
              We believe that property management should be intuitive, efficient, and profitable. 
              Our platform brings together cutting-edge technology with deep industry expertise to 
              deliver solutions that actually work.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center text-gray-700">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Streamlined property operations
              </li>
              <li class="flex items-center text-gray-700">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Enhanced client relationships
              </li>
              <li class="flex items-center text-gray-700">
                <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                Data-driven insights
              </li>
            </ul>
          </div>
        </div>
        
        <div class="space-y-6">
          <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6 border border-blue-100">
            <h4 class="text-lg font-semibold text-blue-900 mb-3">Innovation First</h4>
            <p class="text-blue-700">
              We continuously evolve our platform based on real-world feedback from property professionals like you.
            </p>
          </div>
          
          <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-xl p-6 border border-green-100">
            <h4 class="text-lg font-semibold text-green-900 mb-3">Client Success</h4>
            <p class="text-green-700">
              Your success is our success. We're committed to providing tools that actually make your work easier.
            </p>
          </div>
          
          <div class="bg-gradient-to-r from-purple-50 to-violet-50 rounded-xl p-6 border border-purple-100">
            <h4 class="text-lg font-semibold text-purple-900 mb-3">Future Ready</h4>
            <p class="text-purple-700">
              Built on modern technology stack that scales with your business and adapts to industry changes.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Values</h2>
        <div class="w-24 h-1 bg-blue-500 mx-auto rounded-full"></div>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center group">
          <div class="bg-blue-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-200 transition-colors">
            <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Excellence</h3>
          <p class="text-gray-600">
            We strive for excellence in everything we do, from code quality to customer support.
          </p>
        </div>
        
        <div class="text-center group">
          <div class="bg-green-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-green-200 transition-colors">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Collaboration</h3>
          <p class="text-gray-600">
            We work closely with our clients to understand their needs and deliver tailored solutions.
          </p>
        </div>
        
        <div class="text-center group">
          <div class="bg-purple-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-purple-200 transition-colors">
            <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Integrity</h3>
          <p class="text-gray-600">
            We build trust through transparency, reliability, and honest communication at every step.
          </p>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="mb-16">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Journey</h2>
        <div class="w-24 h-1 bg-blue-500 mx-auto rounded-full"></div>
      </div>
      
      <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-semibold text-gray-900 mb-6">Building the Future of Property Management</h3>
            <div class="space-y-4">
              <div class="flex items-start">
                <div class="bg-blue-100 rounded-full p-2 mt-1 mr-4">
                  <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Founded with Purpose</h4>
                  <p class="text-gray-600">Started by property professionals who understood the real challenges in the industry.</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-green-100 rounded-full p-2 mt-1 mr-4">
                  <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Technology Focused</h4>
                  <p class="text-gray-600">Leveraged modern web technologies to create intuitive, powerful solutions.</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="bg-purple-100 rounded-full p-2 mt-1 mr-4">
                  <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Client Driven</h4>
                  <p class="text-gray-600">Every feature is built based on real feedback from property management professionals.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-blue-50 to-indigo-100 rounded-xl p-8 border border-blue-200">
            <h4 class="text-xl font-semibold text-blue-900 mb-4">Ready to Join Us?</h4>
            <p class="text-blue-700 mb-6">
              Experience the difference that purpose-built property management software can make for your business.
            </p>
            <div class="space-y-3">
              <%= link_to root_path, class: "inline-flex items-center justify-center w-full px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
                <%= icon('fas', 'tachometer-alt', class: 'w-5 h-5 mr-2') if respond_to?(:icon) %>
                Go to Dashboard
              <% end %>
              <%= link_to contact_path, class: "inline-flex items-center justify-center w-full px-6 py-3 border-2 border-blue-300 text-blue-700 font-medium rounded-lg hover:bg-blue-50 transition-colors" do %>
                Contact Us
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>