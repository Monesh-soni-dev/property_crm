<% content_for :title, @page_title %>
<div class="min-h-screen bg-gray-50">
  <!-- Header Section -->
  <section class="bg-gradient-to-r from-slate-800 to-slate-700 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Privacy Policy</h1>
        <p class="text-xl text-slate-300">
          Your privacy is important to us. This policy explains how we collect, use, and protect your information.
        </p>
        <div class="mt-6 text-sm text-slate-400">
          Last updated: <%= Date.current.strftime("%B %d, %Y") %>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-lg shadow-lg">
      <!-- Table of Contents -->
      <div class="bg-blue-50 p-6 rounded-t-lg border-b border-blue-100">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">Table of Contents</h2>
        <nav class="grid md:grid-cols-2 gap-2 text-sm">
          <a href="#information-collection" class="text-blue-600 hover:text-blue-800 hover:underline">1. Information We Collect</a>
          <a href="#information-use" class="text-blue-600 hover:text-blue-800 hover:underline">2. How We Use Information</a>
          <a href="#information-sharing" class="text-blue-600 hover:text-blue-800 hover:underline">3. Information Sharing</a>
          <a href="#data-security" class="text-blue-600 hover:text-blue-800 hover:underline">4. Data Security</a>
          <a href="#data-retention" class="text-blue-600 hover:text-blue-800 hover:underline">5. Data Retention</a>
          <a href="#your-rights" class="text-blue-600 hover:text-blue-800 hover:underline">6. Your Rights</a>
          <a href="#cookies" class="text-blue-600 hover:text-blue-800 hover:underline">7. Cookies & Tracking</a>
          <a href="#contact" class="text-blue-600 hover:text-blue-800 hover:underline">8. Contact Us</a>
        </nav>
      </div>

      <div class="p-8 space-y-12">
        <!-- Introduction -->
        <section>
          <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg p-6 border border-blue-100 mb-6">
            <h3 class="text-lg font-semibold text-blue-900 mb-3">Welcome to PropertyCRM</h3>
            <p class="text-blue-700">
              At PropertyCRM, we are committed to protecting your privacy and ensuring the security of your personal information. 
              This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our property management platform.
            </p>
          </div>
        </section>

        <!-- Information Collection -->
        <section id="information-collection">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-blue-200 pb-2">
            1. Information We Collect
          </h2>
          
          <div class="space-y-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-3">Personal Information</h3>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Name, email address, phone number
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Company information and business details
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Property and project data you input into the system
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Communication preferences and settings
                </li>
              </ul>
            </div>

            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-3">Technical Information</h3>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  IP addresses and device information
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Browser type and version
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Usage patterns and performance data
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  Log files and error reports
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Information Use -->
        <section id="information-use">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-blue-200 pb-2">
            2. How We Use Your Information
          </h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-blue-50 rounded-lg p-6 border border-blue-100">
              <h3 class="text-lg font-semibold text-blue-900 mb-3">Service Delivery</h3>
              <ul class="space-y-2 text-blue-700 text-sm">
                <li>• Provide and maintain our platform</li>
                <li>• Process your property management data</li>
                <li>• Enable collaboration features</li>
                <li>• Generate reports and analytics</li>
              </ul>
            </div>
            
            <div class="bg-green-50 rounded-lg p-6 border border-green-100">
              <h3 class="text-lg font-semibold text-green-900 mb-3">Communication</h3>
              <ul class="space-y-2 text-green-700 text-sm">
                <li>• Send important service updates</li>
                <li>• Respond to your inquiries</li>
                <li>• Provide customer support</li>
                <li>• Share feature announcements</li>
              </ul>
            </div>
            
            <div class="bg-purple-50 rounded-lg p-6 border border-purple-100">
              <h3 class="text-lg font-semibold text-purple-900 mb-3">Platform Improvement</h3>
              <ul class="space-y-2 text-purple-700 text-sm">
                <li>• Analyze usage patterns</li>
                <li>• Enhance user experience</li>
                <li>• Develop new features</li>
                <li>• Fix bugs and issues</li>
              </ul>
            </div>
            
            <div class="bg-orange-50 rounded-lg p-6 border border-orange-100">
              <h3 class="text-lg font-semibold text-orange-900 mb-3">Legal Compliance</h3>
              <ul class="space-y-2 text-orange-700 text-sm">
                <li>• Meet regulatory requirements</li>
                <li>• Protect user rights</li>
                <li>• Prevent fraud and abuse</li>
                <li>• Maintain security standards</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Data Security -->
        <section id="data-security">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-blue-200 pb-2">
            4. Data Security
          </h2>
          
          <div class="bg-gradient-to-r from-red-50 to-pink-50 rounded-lg p-6 border border-red-100 mb-6">
            <h3 class="text-lg font-semibold text-red-900 mb-3">🔒 Security Measures</h3>
            <p class="text-red-700 mb-4">
              We implement industry-standard security measures to protect your information:
            </p>
            <div class="grid md:grid-cols-2 gap-4">
              <ul class="space-y-2 text-red-700 text-sm">
                <li>• SSL/TLS encryption in transit</li>
                <li>• AES-256 encryption at rest</li>
                <li>• Multi-factor authentication</li>
                <li>• Regular security audits</li>
              </ul>
              <ul class="space-y-2 text-red-700 text-sm">
                <li>• Access controls and monitoring</li>
                <li>• Secure backup systems</li>
                <li>• Employee security training</li>
                <li>• Incident response procedures</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Your Rights -->
        <section id="your-rights">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-blue-200 pb-2">
            6. Your Rights
          </h2>
          
          <div class="space-y-4">
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">You have the right to:</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <ul class="space-y-3">
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                    <span class="text-gray-700"><strong>Access</strong> your personal data</span>
                  </li>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    <span class="text-gray-700"><strong>Correct</strong> inaccurate information</span>
                  </li>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-red-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    <span class="text-gray-700"><strong>Delete</strong> your account and data</span>
                  </li>
                </ul>
                <ul class="space-y-3">
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-purple-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <span class="text-gray-700"><strong>Export</strong> your data</span>
                  </li>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-orange-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728L5.636 5.636"></path>
                    </svg>
                    <span class="text-gray-700"><strong>Restrict</strong> data processing</span>
                  </li>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-indigo-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="text-gray-700"><strong>Object</strong> to data processing</span>
                  </li>
                </ul>
              </div>
            </div>
            
            <div class="bg-blue-50 rounded-lg p-6 border border-blue-100">
              <h3 class="text-lg font-semibold text-blue-900 mb-3">Exercise Your Rights</h3>
              <p class="text-blue-700 mb-4">
                To exercise any of these rights or if you have questions about your data, please contact us at:
              </p>
              <div class="bg-white rounded-lg p-4 border border-blue-200">
                <p class="text-blue-800 font-medium">privacy@propertycrm.com</p>
                <p class="text-blue-600 text-sm">We will respond to your request within 30 days</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="bg-gradient-to-r from-gray-900 to-slate-800 -mx-8 -mb-8 p-8 rounded-b-lg">
          <div class="text-center">
            <h2 class="text-2xl font-bold text-white mb-4">Questions About Privacy?</h2>
            <p class="text-gray-300 mb-6 max-w-2xl mx-auto">
              We're here to help. Contact our privacy team if you have any questions or concerns about how we handle your data.
            </p>
            <div class="space-y-3">
              <%= link_to contact_path, class: "inline-flex items-center px-6 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors mr-4" do %>
                Contact Support
              <% end %>
              <a href="mailto:privacy@propertycrm.com" class="inline-flex items-center px-6 py-3 border-2 border-gray-400 text-white font-medium rounded-lg hover:bg-gray-800 hover:text-gray-100 transition-colors">
                Email Privacy Team
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>