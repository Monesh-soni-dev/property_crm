<% content_for :title, @page_title %>
<div class="min-h-screen bg-gray-50">
  <!-- Header Section -->
  <section class="bg-gradient-to-r from-purple-600 to-pink-600 text-white py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Contact Us</h1>
        <p class="text-xl text-purple-100 max-w-3xl mx-auto leading-relaxed">
          We're here to help. Get in touch with our team and we'll get back to you as soon as possible.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Contact Methods -->
    <section class="mb-16">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl shadow-lg p-8 text-center border border-gray-100 hover:shadow-xl transition-shadow">
          <div class="bg-blue-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Email Support</h3>
          <p class="text-gray-600 mb-4">Get help from our support team</p>
          <a href="mailto:support@propertycrm.com" class="text-blue-600 hover:text-blue-700 font-medium">
            support@propertycrm.com
          </a>
          <div class="mt-4 text-sm text-gray-500">
            Response within 24 hours
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 text-center border border-gray-100 hover:shadow-xl transition-shadow">
          <div class="bg-green-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Phone Support</h3>
          <p class="text-gray-600 mb-4">Talk directly with our team</p>
          <a href="tel:+18007767378" class="text-green-600 hover:text-green-700 font-medium text-lg">
            1-800-PROPERTY
          </a>
          <div class="mt-4 text-sm text-gray-500">
            Mon-Fri, 9 AM - 6 PM EST
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 text-center border border-gray-100 hover:shadow-xl transition-shadow">
          <div class="bg-purple-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Live Chat</h3>
          <p class="text-gray-600 mb-4">Instant help when you need it</p>
          <button class="bg-purple-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-purple-700 transition-colors">
            Start Chat
          </button>
          <div class="mt-4 text-sm text-gray-500">
            Available during business hours
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form and Information -->
    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Send Us a Message</h2>
          
          <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="first_name" class="block text-sm font-medium text-gray-700 mb-2">First Name</label>
                <input type="text" id="first_name" name="first_name" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors">
              </div>
              <div>
                <label for="last_name" class="block text-sm font-medium text-gray-700 mb-2">Last Name</label>
                <input type="text" id="last_name" name="last_name" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors">
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                <input type="email" id="email" name="email" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors">
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                <input type="tel" id="phone" name="phone"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors">
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-2">Company Name</label>
              <input type="text" id="company" name="company"
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors">
            </div>

            <div>
              <label for="inquiry_type" class="block text-sm font-medium text-gray-700 mb-2">Type of Inquiry</label>
              <select id="inquiry_type" name="inquiry_type" required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors">
                <option value="">Select inquiry type</option>
                <option value="support">Technical Support</option>
                <option value="sales">Sales Question</option>
                <option value="billing">Billing Issue</option>
                <option value="feature">Feature Request</option>
                <option value="partnership">Partnership Opportunity</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
              <textarea id="message" name="message" rows="6" required
                        placeholder="Please describe your question or how we can help you..."
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-colors resize-none"></textarea>
            </div>

            <div class="flex items-start">
              <input id="privacy_agreement" name="privacy_agreement" type="checkbox" required
                     class="w-4 h-4 text-purple-600 border-gray-300 rounded focus:ring-purple-500 mt-1">
              <label for="privacy_agreement" class="ml-3 text-sm text-gray-600">
                I agree to the <%= link_to "Privacy Policy", privacy_path, class: "text-purple-600 hover:text-purple-700 underline" %> 
                and <%= link_to "Terms of Service", terms_path, class: "text-purple-600 hover:text-purple-700 underline" %>
              </label>
            </div>

            <button type="submit" 
                    class="w-full bg-purple-600 text-white py-3 px-6 rounded-lg font-medium hover:bg-purple-700 focus:ring-4 focus:ring-purple-300 transition-colors">
              Send Message
            </button>
          </form>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="space-y-8">
        <!-- Office Information -->
        <div class="bg-white rounded-xl shadow-lg p-6 border border-gray-100">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Office Information</h3>
          <div class="space-y-4 text-sm">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <div>
                <p class="text-gray-900 font-medium">Headquarters</p>
                <p class="text-gray-600">123 Business District<br>Technology Park, Suite 400<br>Innovation City, IC 12345</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <p class="text-gray-900 font-medium">Business Hours</p>
                <p class="text-gray-600">Monday - Friday<br>9:00 AM - 6:00 PM EST</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-gray-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0-9v9"></path>
              </svg>
              <div>
                <p class="text-gray-900 font-medium">Time Zone</p>
                <p class="text-gray-600">Eastern Standard Time (EST)</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Specialized Support -->
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-100 p-6">
          <h3 class="text-lg font-semibold text-blue-900 mb-4">Specialized Support</h3>
          <div class="space-y-4 text-sm">
            <div class="bg-white rounded-lg p-4 border border-blue-100">
              <h4 class="font-semibold text-blue-800 mb-1">Technical Support</h4>
              <p class="text-blue-700 text-xs mb-2">System issues, integrations, API questions</p>
              <a href="mailto:tech@propertycrm.com" class="text-blue-600 hover:text-blue-700 underline text-sm">
                tech@propertycrm.com
              </a>
            </div>

            <div class="bg-white rounded-lg p-4 border border-blue-100">
              <h4 class="font-semibold text-blue-800 mb-1">Sales Inquiries</h4>
              <p class="text-blue-700 text-xs mb-2">Pricing, plans, custom solutions</p>
              <a href="mailto:sales@propertycrm.com" class="text-blue-600 hover:text-blue-700 underline text-sm">
                sales@propertycrm.com
              </a>
            </div>

            <div class="bg-white rounded-lg p-4 border border-blue-100">
              <h4 class="font-semibold text-blue-800 mb-1">Billing Support</h4>
              <p class="text-blue-700 text-xs mb-2">Payments, invoices, account changes</p>
              <a href="mailto:billing@propertycrm.com" class="text-blue-600 hover:text-blue-700 underline text-sm">
                billing@propertycrm.com
              </a>
            </div>

            <div class="bg-white rounded-lg p-4 border border-blue-100">
              <h4 class="font-semibold text-blue-800 mb-1">Partnership Opportunities</h4>
              <p class="text-blue-700 text-xs mb-2">Integrations, reseller programs</p>
              <a href="mailto:partners@propertycrm.com" class="text-blue-600 hover:text-blue-700 underline text-sm">
                partners@propertycrm.com
              </a>
            </div>
          </div>
        </div>

        <!-- Emergency Support -->
        <div class="bg-gradient-to-br from-red-50 to-pink-50 rounded-xl border border-red-100 p-6">
          <h3 class="text-lg font-semibold text-red-900 mb-3">Emergency Support</h3>
          <p class="text-red-700 text-sm mb-4">
            For critical system outages affecting business operations, our emergency support team is available 24/7.
          </p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center">
              <svg class="w-4 h-4 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <span class="text-red-800 font-medium">Emergency: 1-800-911-PROP</span>
            </div>
            <div class="flex items-center">
              <svg class="w-4 h-4 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <span class="text-red-800">emergency@propertycrm.com</span>
            </div>
          </div>
        </div>

        <!-- Follow Us -->
        <div class="bg-gray-900 rounded-xl p-6 text-white">
          <h3 class="text-lg font-semibold mb-4">Follow Us</h3>
          <div class="flex space-x-4">
            <a href="#" class="bg-gray-800 p-2 rounded-lg hover:bg-gray-700 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
              </svg>
            </a>
            <a href="#" class="bg-gray-800 p-2 rounded-lg hover:bg-gray-700 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a href="#" class="bg-gray-800 p-2 rounded-lg hover:bg-gray-700 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>