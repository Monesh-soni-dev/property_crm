<% content_for :title, @page_title %>
<div class="min-h-screen bg-gray-50">
  <!-- Header Section -->
  <section class="bg-gradient-to-r from-green-600 to-emerald-700 text-white py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Help Center</h1>
        <p class="text-xl text-green-100 max-w-3xl mx-auto leading-relaxed mb-8">
          Find answers to common questions and get the support you need to make the most of PropertyCRM.
        </p>
        
        <!-- Search Box -->
        <div class="max-w-2xl mx-auto">
          <div class="relative">
            <input type="text" placeholder="Search for help articles..." 
                   class="w-full px-6 py-4 text-gray-700 bg-white rounded-lg shadow-lg text-lg focus:ring-4 focus:ring-green-300 focus:outline-none">
            <button class="absolute right-2 top-2 bg-green-600 text-white p-2 rounded-lg hover:bg-green-700 transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Quick Actions -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Quick Actions</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl shadow-lg p-6 text-center border border-gray-100 hover:shadow-xl transition-shadow group">
          <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-200 transition-colors">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Getting Started</h3>
          <p class="text-gray-600 text-sm">Setup guides and first steps</p>
        </div>
        
        <div class="bg-white rounded-xl shadow-lg p-6 text-center border border-gray-100 hover:shadow-xl transition-shadow group">
          <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-green-200 transition-colors">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">FAQ</h3>
          <p class="text-gray-600 text-sm">Common questions answered</p>
        </div>
        
        <div class="bg-white rounded-xl shadow-lg p-6 text-center border border-gray-100 hover:shadow-xl transition-shadow group">
          <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-purple-200 transition-colors">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Video Tutorials</h3>
          <p class="text-gray-600 text-sm">Learn with step-by-step videos</p>
        </div>
        
        <div class="bg-white rounded-xl shadow-lg p-6 text-center border border-gray-100 hover:shadow-xl transition-shadow group">
          <div class="bg-orange-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-orange-200 transition-colors">
            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Contact Support</h3>
          <p class="text-gray-600 text-sm">Get personalized help</p>
        </div>
      </div>
    </section>

    <!-- Popular Articles -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Popular Help Articles</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="space-y-6">
          <h3 class="text-xl font-semibold text-gray-900 border-b-2 border-green-200 pb-2">Getting Started</h3>
          
          <div class="space-y-4">
            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Setting Up Your First Property</h4>
              <p class="text-gray-600 text-sm mb-3">Learn how to add properties to your PropertyCRM account and configure basic settings.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                5 min read
                <span class="ml-4 text-green-600 font-medium">Most Popular</span>
              </div>
            </article>

            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Managing Leads and Prospects</h4>
              <p class="text-gray-600 text-sm mb-3">Discover how to capture, track, and convert leads into successful property deals.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                8 min read
              </div>
            </article>

            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">User Permissions and Team Setup</h4>
              <p class="text-gray-600 text-sm mb-3">Configure team access levels and manage user permissions effectively.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                6 min read
              </div>
            </article>

            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Data Import and Migration</h4>
              <p class="text-gray-600 text-sm mb-3">Import your existing property data and migrate from other systems.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                12 min read
              </div>
            </article>
          </div>
        </div>

        <div class="space-y-6">
          <h3 class="text-xl font-semibold text-gray-900 border-b-2 border-blue-200 pb-2">Advanced Features</h3>
          
          <div class="space-y-4">
            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Automated Workflows and Triggers</h4>
              <p class="text-gray-600 text-sm mb-3">Set up automation to streamline your property management processes.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                10 min read
                <span class="ml-4 text-purple-600 font-medium">Advanced</span>
              </div>
            </article>

            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Custom Reports and Analytics</h4>
              <p class="text-gray-600 text-sm mb-3">Create detailed reports and analyze your property portfolio performance.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                15 min read
              </div>
            </article>

            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">API Integration Guide</h4>
              <p class="text-gray-600 text-sm mb-3">Connect PropertyCRM with your existing tools and third-party services.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                20 min read
                <span class="ml-4 text-blue-600 font-medium">Technical</span>
              </div>
            </article>

            <article class="bg-white rounded-lg shadow p-6 border border-gray-100 hover:shadow-lg transition-shadow">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Backup and Data Export</h4>
              <p class="text-gray-600 text-sm mb-3">Learn how to backup your data and export information when needed.</p>
              <div class="flex items-center text-xs text-gray-500">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                7 min read
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Frequently Asked Questions</h2>
      <div class="bg-white rounded-lg shadow-lg">
        <div class="divide-y divide-gray-200">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">How do I add a new property to my account?</h3>
            <p class="text-gray-600">Navigate to the Properties section and click "Add New Property." Fill in the property details including address, type, and key information. You can also upload photos and documents at this stage.</p>
          </div>
          
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Can I import data from my existing property management system?</h3>
            <p class="text-gray-600">Yes, PropertyCRM supports data import from most major property management platforms. Use our import wizard in Settings > Data Import, or contact our support team for assistance with complex migrations.</p>
          </div>
          
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">How do I track leads and convert them to clients?</h3>
            <p class="text-gray-600">Use the Leads section to capture prospect information. Set up follow-up reminders, track communication history, and move leads through your sales pipeline. Convert qualified leads to active projects when ready.</p>
          </div>
          
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">What payment plans are available?</h3>
            <p class="text-gray-600">We offer flexible monthly and annual plans to suit different business sizes. Visit our pricing page or contact sales for custom enterprise solutions. All plans include core property management features.</p>
          </div>
          
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Is my data secure and backed up?</h3>
            <p class="text-gray-600">Absolutely. We use bank-level encryption, regular security audits, and automated daily backups. Your data is stored in secure, redundant data centers with 99.9% uptime guarantee.</p>
          </div>
          
          <div class="p-6 border-b-0">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">How can I get support if I need help?</h3>
            <p class="text-gray-600">Contact our support team via email, live chat, or phone during business hours. We also offer training sessions and have extensive documentation available in our help center.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Support -->
    <section class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl text-white p-12 text-center">
      <h2 class="text-3xl font-bold mb-4">Still Need Help?</h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Our support team is standing by to help you get the most out of PropertyCRM. 
        We're here to ensure your success.
      </p>
      
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <%= link_to contact_path, class: "bg-green-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-green-700 transition-colors" do %>
          Contact Support
        <% end %>
        
        <a href="mailto:help@propertycrm.com" class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-blue-600 transition-colors">
          Email Us
        </a>
        
        <%= link_to documentation_path, class: "bg-blue-500 text-white px-8 py-4 rounded-lg font-semibold hover:bg-blue-400 transition-colors" do %>
          View Documentation
        <% end %>
      </div>
      
      <div class="mt-8 text-blue-200 text-sm">
        <p>📞 Phone: 1-800-PROPERTY (1-800-776-7378)</p>
        <p>⏰ Support Hours: Monday - Friday, 9 AM - 6 PM EST</p>
      </div>
    </section>
  </div>
</div>