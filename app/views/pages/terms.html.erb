<% content_for :title, @page_title %>
<div class="min-h-screen bg-gray-50">
  <!-- Header Section -->
  <section class="bg-gradient-to-r from-indigo-800 to-purple-700 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Terms of Service</h1>
        <p class="text-xl text-indigo-200">
          Please read these terms carefully before using our PropertyCRM platform.
        </p>
        <div class="mt-6 text-sm text-indigo-300">
          Last updated: <%= Date.current.strftime("%B %d, %Y") %>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-white rounded-lg shadow-lg">
      <!-- Quick Summary -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 p-6 rounded-t-lg border-b border-blue-100">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">📋 Quick Summary</h2>
        <div class="grid md:grid-cols-3 gap-4 text-sm">
          <div class="bg-white rounded p-4 border border-blue-100">
            <h3 class="font-semibold text-blue-800 mb-2">✅ You Can</h3>
            <ul class="text-blue-700 space-y-1">
              <li>• Use our platform for business</li>
              <li>• Manage your properties</li>
              <li>• Store your data securely</li>
              <li>• Cancel anytime</li>
            </ul>
          </div>
          <div class="bg-white rounded p-4 border border-orange-100">
            <h3 class="font-semibold text-orange-800 mb-2">⚠️ Please Don't</h3>
            <ul class="text-orange-700 space-y-1">
              <li>• Share your login credentials</li>
              <li>• Violate others' rights</li>
              <li>• Attempt to hack our system</li>
              <li>• Use for illegal activities</li>
            </ul>
          </div>
          <div class="bg-white rounded p-4 border border-green-100">
            <h3 class="font-semibold text-green-800 mb-2">🛡️ We Promise</h3>
            <ul class="text-green-700 space-y-1">
              <li>• Protect your data</li>
              <li>• Provide reliable service</li>
              <li>• Support when you need it</li>
              <li>• Fair and transparent pricing</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="p-8 space-y-10">
        <!-- Acceptance of Terms -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            1. Acceptance of Terms
          </h2>
          <div class="bg-gray-50 rounded-lg p-6">
            <p class="text-gray-700 leading-relaxed mb-4">
              By accessing or using PropertyCRM ("the Service"), you agree to be bound by these Terms of Service ("Terms"). 
              If you disagree with any part of these terms, then you may not access the Service.
            </p>
            <div class="bg-blue-50 border border-blue-200 rounded p-4">
              <p class="text-blue-800 text-sm">
                <strong>Important:</strong> These terms constitute a legally binding agreement between you and PropertyCRM. 
                Please read them carefully and keep a copy for your records.
              </p>
            </div>
          </div>
        </section>

        <!-- Service Description -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            2. Service Description
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-4">
              <div class="bg-blue-50 rounded-lg p-6 border border-blue-100">
                <h3 class="text-lg font-semibold text-blue-900 mb-3">🏢 What We Provide</h3>
                <ul class="space-y-2 text-blue-700 text-sm">
                  <li>• Cloud-based property management platform</li>
                  <li>• Lead and project management tools</li>
                  <li>• Data storage and backup services</li>
                  <li>• Mobile and web application access</li>
                  <li>• Customer support and maintenance</li>
                </ul>
              </div>
              
              <div class="bg-green-50 rounded-lg p-6 border border-green-100">
                <h3 class="text-lg font-semibold text-green-900 mb-3">📊 Service Level</h3>
                <ul class="space-y-2 text-green-700 text-sm">
                  <li>• 99.9% uptime commitment</li>
                  <li>• Regular security updates</li>
                  <li>• Data backup every 24 hours</li>
                  <li>• Business hours support</li>
                </ul>
              </div>
            </div>
            
            <div class="space-y-4">
              <div class="bg-orange-50 rounded-lg p-6 border border-orange-100">
                <h3 class="text-lg font-semibold text-orange-900 mb-3">⚠️ Service Limitations</h3>
                <ul class="space-y-2 text-orange-700 text-sm">
                  <li>• Internet connection required</li>
                  <li>• Storage limits based on your plan</li>
                  <li>• Some features require additional setup</li>
                  <li>• Third-party integrations may vary</li>
                </ul>
              </div>
              
              <div class="bg-purple-50 rounded-lg p-6 border border-purple-100">
                <h3 class="text-lg font-semibold text-purple-900 mb-3">🔄 Updates & Changes</h3>
                <p class="text-purple-700 text-sm">
                  We may update, modify, or discontinue features with reasonable notice. 
                  Major changes will be communicated 30 days in advance.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- User Accounts -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            3. User Accounts and Responsibilities
          </h2>
          
          <div class="space-y-6">
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg p-6 border border-blue-100">
              <h3 class="text-lg font-semibold text-blue-900 mb-4">Account Security</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold text-blue-800 mb-2">Your Responsibilities:</h4>
                  <ul class="space-y-2 text-blue-700 text-sm">
                    <li>• Maintain accurate account information</li>
                    <li>• Use strong, unique passwords</li>
                    <li>• Keep login credentials confidential</li>
                    <li>• Report security issues immediately</li>
                    <li>• Ensure authorized users only</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-blue-800 mb-2">Our Responsibilities:</h4>
                  <ul class="space-y-2 text-blue-700 text-sm">
                    <li>• Secure data transmission</li>
                    <li>• Regular security monitoring</li>
                    <li>• Prompt incident response</li>
                    <li>• Account recovery assistance</li>
                    <li>• Security feature updates</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="bg-red-50 rounded-lg p-6 border border-red-100">
              <h3 class="text-lg font-semibold text-red-900 mb-3">🚫 Prohibited Activities</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <ul class="space-y-2 text-red-700 text-sm">
                  <li>• Sharing accounts with unauthorized users</li>
                  <li>• Attempting to hack or exploit the system</li>
                  <li>• Using the service for illegal activities</li>
                  <li>• Violating intellectual property rights</li>
                </ul>
                <ul class="space-y-2 text-red-700 text-sm">
                  <li>• Transmitting malware or viruses</li>
                  <li>• Spamming or sending unsolicited content</li>
                  <li>• Reverse engineering our software</li>
                  <li>• Interfering with service operations</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Payment Terms -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            4. Payment and Billing
          </h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-4">
              <div class="bg-green-50 rounded-lg p-6 border border-green-100">
                <h3 class="text-lg font-semibold text-green-900 mb-3">💳 Payment Terms</h3>
                <ul class="space-y-2 text-green-700 text-sm">
                  <li>• Monthly or annual billing cycles</li>
                  <li>• Secure payment processing</li>
                  <li>• Automatic renewal unless cancelled</li>
                  <li>• Prorated charges for plan changes</li>
                  <li>• All prices exclude applicable taxes</li>
                </ul>
              </div>
              
              <div class="bg-blue-50 rounded-lg p-6 border border-blue-100">
                <h3 class="text-lg font-semibold text-blue-900 mb-3">🔄 Refund Policy</h3>
                <ul class="space-y-2 text-blue-700 text-sm">
                  <li>• 30-day money-back guarantee</li>
                  <li>• Pro-rated refunds for downgrades</li>
                  <li>• No refunds for partial months</li>
                  <li>• Refund processing within 5-10 business days</li>
                </ul>
              </div>
            </div>
            
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">Billing Information</h3>
              <div class="space-y-4 text-gray-700 text-sm">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong>Billing Cycle:</strong> Charges occur on the same date each month/year
                  </div>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong>Payment Methods:</strong> Credit cards, debit cards, and bank transfers
                  </div>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong>Failed Payments:</strong> 7-day grace period before service suspension
                  </div>
                </div>
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong>Cancellation:</strong> No charges after cancellation confirmation
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Data and Privacy -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            5. Data Ownership and Privacy
          </h2>
          
          <div class="space-y-6">
            <div class="bg-gradient-to-r from-purple-50 to-pink-50 rounded-lg p-6 border border-purple-100">
              <h3 class="text-lg font-semibold text-purple-900 mb-4">🗂️ Your Data Rights</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h4 class="font-semibold text-purple-800 mb-3">You Own Your Data:</h4>
                  <ul class="space-y-2 text-purple-700 text-sm">
                    <li>• All property and project information</li>
                    <li>• Contact lists and lead data</li>
                    <li>• Documents and files you upload</li>
                    <li>• Custom settings and configurations</li>
                  </ul>
                </div>
                <div>
                  <h4 class="font-semibold text-purple-800 mb-3">Data Portability:</h4>
                  <ul class="space-y-2 text-purple-700 text-sm">
                    <li>• Export your data anytime</li>
                    <li>• Standard formats available</li>
                    <li>• No additional export fees</li>
                    <li>• Assistance with data migration</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="bg-blue-50 rounded-lg p-6 border border-blue-100">
              <h3 class="text-lg font-semibold text-blue-900 mb-3">🔒 Privacy Commitment</h3>
              <p class="text-blue-700 mb-4">
                We are committed to protecting your privacy and data security. For detailed information about how we 
                collect, use, and protect your data, please review our 
                <%= link_to "Privacy Policy", privacy_path, class: "text-blue-800 hover:text-blue-900 underline font-medium" %>.
              </p>
              <div class="bg-white rounded border border-blue-200 p-4">
                <p class="text-blue-800 text-sm">
                  <strong>Key Points:</strong> We never sell your data, use bank-level security, and comply with international privacy regulations.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Limitation of Liability -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            6. Limitation of Liability
          </h2>
          
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-yellow-900 mb-4">⚖️ Important Legal Information</h3>
            <div class="space-y-4 text-yellow-800 text-sm">
              <p>
                <strong>Service Availability:</strong> While we strive for 99.9% uptime, we cannot guarantee uninterrupted service. 
                We are not liable for temporary outages or maintenance periods.
              </p>
              <p>
                <strong>Data Loss:</strong> We maintain regular backups, but you are responsible for maintaining your own backup copies 
                of critical data. We recommend regular data exports.
              </p>
              <p>
                <strong>Third-Party Services:</strong> Integrations with third-party services are provided as-is. We are not responsible 
                for the availability or functionality of external services.
              </p>
              <p>
                <strong>Maximum Liability:</strong> Our total liability is limited to the amount you paid for the service in the 
                12 months preceding the claim.
              </p>
            </div>
          </div>
        </section>

        <!-- Termination -->
        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-indigo-200 pb-2">
            7. Account Termination
          </h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-green-50 rounded-lg p-6 border border-green-100">
              <h3 class="text-lg font-semibold text-green-900 mb-3">✅ Voluntary Cancellation</h3>
              <ul class="space-y-2 text-green-700 text-sm">
                <li>• Cancel anytime from your account settings</li>
                <li>• Access continues until end of billing period</li>
                <li>• Data export available for 30 days</li>
                <li>• No cancellation fees</li>
                <li>• Reactivation available within 90 days</li>
              </ul>
            </div>
            
            <div class="bg-red-50 rounded-lg p-6 border border-red-100">
              <h3 class="text-lg font-semibold text-red-900 mb-3">⛔ Involuntary Termination</h3>
              <ul class="space-y-2 text-red-700 text-sm">
                <li>• Violation of these terms</li>
                <li>• Illegal or harmful activities</li>
                <li>• Non-payment after grace period</li>
                <li>• Abuse of system resources</li>
                <li>• 30-day notice when possible</li>
              </ul>
            </div>
          </div>
          
          <div class="bg-gray-50 rounded-lg p-6 mt-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-3">Data Retention After Termination</h3>
            <div class="grid md:grid-cols-3 gap-4 text-sm">
              <div class="bg-white rounded p-4 border">
                <h4 class="font-semibold text-gray-800 mb-2">First 30 Days</h4>
                <p class="text-gray-600">Full data access and export capabilities available</p>
              </div>
              <div class="bg-white rounded p-4 border">
                <h4 class="font-semibold text-gray-800 mb-2">30-90 Days</h4>
                <p class="text-gray-600">Data archived but recoverable upon request</p>
              </div>
              <div class="bg-white rounded p-4 border">
                <h4 class="font-semibold text-gray-800 mb-2">After 90 Days</h4>
                <p class="text-gray-600">Data permanently deleted from our servers</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Contact Information -->
        <section class="bg-gradient-to-r from-gray-900 to-slate-800 -mx-8 -mb-8 p-8 rounded-b-lg">
          <div class="text-center">
            <h2 class="text-2xl font-bold text-white mb-4">Questions About These Terms?</h2>
            <p class="text-gray-300 mb-6 max-w-2xl mx-auto">
              We're here to help clarify any questions about our Terms of Service. Our legal and support teams are available to assist you.
            </p>
            <div class="space-y-3">
              <%= link_to contact_path, class: "inline-flex items-center px-6 py-3 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors mr-4" do %>
                Contact Support
              <% end %>
              <a href="mailto:legal@propertycrm.com" class="inline-flex items-center px-6 py-3 border-2 border-gray-400 text-white font-medium rounded-lg hover:bg-gray-800 hover:text-gray-100 transition-colors">
                Email Legal Team
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>