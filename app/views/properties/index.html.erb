
<% if user_signed_in? %>
  <% breadcrumbs ["Dashboard", root_path], ["Projects", projects_path], ["Properties", "#"] %>
<% else %>
  <% breadcrumbs ["Properties", "#"] %>
<% end %>

<!-- Page Header -->
<div class="bg-gradient-to-r from-slate-900 to-blue-900 rounded-3xl p-8 mb-8 text-white">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-4xl font-['Playfair_Display'] font-bold mb-2">
        <%= @project.present? ? "Properties in #{@project.name}" : "All Properties" %>
      </h1>
      <div class="flex items-center gap-6 text-blue-200">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
          <%= @properties.count %> Properties Available
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          <%= @project&.name || "Multiple Projects" %>
        </span>
      </div>
    </div>
    
    <div class="flex gap-3">
      <% if user_signed_in? %>
        <%= link_to new_property_path, class: "flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition-all transform hover:scale-105 shadow-lg" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Add Property
        <% end %>
        <%= link_to new_project_path, class: "flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-xl font-semibold transition-all transform hover:scale-105 shadow-lg" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          Add Project
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Filters Section -->
<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200 mb-8">
  <%= search_form_for @q, url: properties_path, class: "flex flex-wrap gap-4 items-end" do |f| %>
    <div class="min-w-48">
      <label class="block text-sm font-medium text-gray-700 mb-2">Status Filter</label>
      <%= f.select :status_eq, Property.statuses.keys.map { |s| [s.humanize, s] },
            { include_blank: "All Status" },
            class: "w-full border border-gray-300 rounded-xl px-4 py-3 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" %>
    </div>
    
    <div class="min-w-48">
      <label class="block text-sm font-medium text-gray-700 mb-2">Property Type</label>
      <%= f.select :property_type_eq, [['Apartment','apartment'], ['Villa','villa'], ['Plot','plot'], ['Commercial','commercial']],
            { include_blank: "All Types" },
            class: "w-full border border-gray-300 rounded-xl px-4 py-3 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" %>
    </div>
    
    <div class="min-w-48">
      <label class="block text-sm font-medium text-gray-700 mb-2">Price Range</label>
      <%= f.search_field :price_gteq, placeholder: "Min Price", class: "w-full border border-gray-300 rounded-xl px-4 py-3 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" %>
    </div>
    
    <div class="flex gap-2">
      <%= f.submit "Apply Filters", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-medium transition-all transform hover:scale-105 shadow-lg cursor-pointer" %>
      <%= link_to "Clear", request.path, class: "bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-3 rounded-xl font-medium transition-all" %>
    </div>
  <% end %>
</div>

<!-- Properties Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  <% @properties.each do |property| %>
    <%= link_to project_property_path(@project || property.project, property), class: "group block" do %>
      <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-200 hover:border-blue-300">
        <div class="h-64 bg-gradient-to-br from-slate-100 to-slate-200 relative overflow-hidden">
          <% if property.images.attached? %>
            <%= image_tag property.images.first, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
          <% else %>
            <div class="flex items-center justify-center h-full">
              <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
          <% end %>
          
          <!-- Status Badge -->
          <div class="absolute top-4 right-4">
            <span class="px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide backdrop-blur-md
              <%= property.available? ? 'bg-emerald-500/90 text-white' :
                 property.sold? ? 'bg-rose-500/90 text-white' :
                 property.blocked? ? 'bg-amber-500/90 text-white' :
                 'bg-gray-500/90 text-white' %>">
              <%= property.status&.humanize || 'Unknown' %>
            </span>
          </div>
          
          <!-- Property Type Badge -->
          <div class="absolute top-4 left-4">
            <span class="px-3 py-1.5 bg-white/90 backdrop-blur-md text-gray-800 text-xs font-semibold rounded-full">
              <%= property.property_type&.titleize || 'Apartment' %>
            </span>
          </div>
          
          <!-- Quick Actions (for authenticated users) -->
          <% if user_signed_in? && (property.project.user == current_user || current_user.admin?) %>
            <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="flex gap-2">
                <%= link_to (@project ? edit_project_property_path(@project, property) : edit_property_path(property)), 
                    class: "p-2 bg-white/90 backdrop-blur-md rounded-full hover:bg-white transition-all", 
                    onclick: "event.stopPropagation(); event.preventDefault(); window.location.href = this.href;" do %>
                  <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
                
                <%= link_to (@project ? project_property_path(@project, property) : property), 
                    method: :delete,
                    data: { confirm: "Are you sure?" },
                    class: "p-2 bg-white/90 backdrop-blur-md rounded-full hover:bg-white transition-all", 
                    onclick: "event.stopPropagation();" do %>
                  <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        
        <div class="p-6">
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-blue-600 transition-colors"><%= property.title %></h3>
              <div class="flex items-center text-gray-500 text-sm mt-1">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <%= property.project.name %> • Floor <%= property.floor %>
              </div>
            </div>
            <div class="text-right">
              <% if property.price.present? && property.price > 0 %>
                <p class="text-2xl font-bold text-blue-600">₹<%= number_with_delimiter(property.price / 100000) %>L</p>
              <% else %>
                <p class="text-2xl font-bold text-gray-400">Price not set</p>
              <% end %>
              <p class="text-xs text-gray-500">Total Price</p>
            </div>
          </div>
          
          <% if property.description.present? %>
            <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= truncate(property.description, length: 120) %></p>
          <% end %>
          
          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <div class="flex items-center gap-4 text-sm text-gray-600">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"></path>
                </svg>
                <%= property.area %> sq ft
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                <%= property.bedrooms %> BHK
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path>
                </svg>
                <%= property.bathrooms %> Bath
              </span>
            </div>
            
            <div class="flex items-center text-blue-600 font-medium text-sm group">
              View Details
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<%== @pagy.series_nav if @pagy.pages > 1 %>