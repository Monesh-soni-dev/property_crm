
<% if user_signed_in? %>
  <% breadcrumbs ["Projects", projects_path], ["Properties", "#"] %>
<% else %>
  <% breadcrumbs ["Properties", "#"] %>
<% end %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-['Playfair_Display'] font-semibold">
      <%= @project.present? ? "Properties for #{@project.name}" : "All Properties" %>
    </h1>
    <p class="text-sm text-gray-400 mt-1"><%= @properties.count %> units · <%= @project&.name || "All projects" %></p>
  </div>
  <div class="flex gap-2">
    <%= search_form_for @q, url: properties_path, class: "flex gap-2" do |f| %>
      <%= f.select :status_eq, Property.statuses.keys.map { |s| [s.humanize, s] },
            { include_blank: "All status" },
            class: "text-xs border border-gray-200 rounded-lg px-3 py-2 bg-white" %>
      <%= f.select :property_type_eq, [['Apartment','apartment'], ['Villa','villa'], ['Plot','plot'], ['Commercial','commercial']],
            { include_blank: "All types" },
            class: "text-xs border border-gray-200 rounded-lg px-3 py-2 bg-white" %>
      <%= f.submit "Filter", class: "text-xs bg-white border border-gray-200 rounded-lg px-3 py-2 cursor-pointer hover:bg-gray-50" %>
    <% end %>
    <% if @project.present? && user_signed_in? %>
      <%= link_to new_project_property_path(@project), class: "flex items-center gap-1.5 bg-[#1a2e4a] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[#2a4a72] transition" do %>
        <span class="text-lg leading-none">+</span> Add unit
      <% end %>
    <% elsif !@project.present? && user_signed_in? %>
      <%= link_to "Choose a project", projects_path, class: "flex items-center gap-1.5 bg-[#1a2e4a] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[#2a4a72] transition" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-3 gap-4">
  <% @properties.each do |property| %>
    <%= link_to project_property_path(@project || property.project, property),
          class: "bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-blue-400 transition group block" do %>
      <div class="h-32 bg-stone-100 relative flex items-center justify-center">
        <% if property.images.attached? %>
          <%= image_tag property.images.first, class: "w-full h-full object-cover" %>
        <% else %>
          <%= inline_svg "home.svg", class: "w-10 h-10 fill-gray-300" %>
        <% end %>
        <span class="absolute top-2 right-2 px-2.5 py-0.5 rounded-full text-[10px] font-semibold
          <%= property.available? ? 'bg-green-50 text-green-800' : property.sold? ? 'bg-red-50 text-red-800' : 'bg-amber-50 text-amber-800' %>">
          <%= property.status&.humanize || 'Unknown' %>
        </span>
      </div>
      <div class="p-3.5">
        <p class="text-sm font-semibold text-gray-800"><%= property.title %></p>
        <p class="text-xs text-gray-400 mt-0.5"><%= property.project.name %> · <%= property.property_type&.titleize %> · Floor <%= property.floor %></p>
        <% if property.description.present? %>
          <p class="text-sm text-gray-500 mt-2 line-clamp-2"><%= property.description %></p>
        <% end %>
        <div class="flex gap-2.5 mt-2 text-xs text-gray-500">
          <span><%= property.area %> sq ft</span>
          <span><%= property.bedrooms %> bed</span>
          <span><%= property.bathrooms %> bath</span>
        </div>
        <p class="text-sm font-semibold text-[#1a2e4a] mt-2">
          ₹ <%= number_with_delimiter(property.price) %>
        </p>
        <% if user_signed_in? && (property.project.user == current_user || current_user.admin?) %>
          <div class="flex gap-2 mt-3">
            <%= link_to "Edit", @project ? edit_project_property_path(@project, property) : edit_property_path(property), class: "text-xs text-amber-700 hover:text-amber-600 font-medium transition duration-200" %>
            <%= link_to "Delete", @project ? project_property_path(@project, property) : property, method: :delete,
                data: { confirm: "Are you sure you want to delete this property?" },
                class: "text-xs text-red-600 hover:text-red-800 font-medium transition duration-200" %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>

<%== @pagy.series_nav if @pagy.pages > 1 %>