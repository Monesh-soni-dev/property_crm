<% 
  form_model = @project.present? ? [@project, property] : property
%>
<%= form_with(model: form_model, class: "space-y-6", local: true, multipart: true) do |form| %>
  <% if property.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There were <%= pluralize(property.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc pl-5 space-y-1">
              <% property.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Project Selection -->
    <div>
      <%= form.label :project_id, "Select Project", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <span class="text-red-500">*</span>
      <%= form.collection_select :project_id, 
          current_user.projects.order(:name), :id, :name, 
          { prompt: 'Select a project' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", required: true } %>
      <p class="text-sm text-gray-500 mt-1">Choose which project this property belongs to</p>
    </div>

    <!-- Property Title -->
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <span class="text-red-500">*</span>
      <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., Premium 3BHK Apartment", required: true %>
    </div>
  </div>

  <!-- Property Type -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :property_type, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <span class="text-red-500">*</span>
      <%= form.select :property_type, [
            ['1BHK Apartment', '1bhk'], 
            ['2BHK Apartment', '2bhk'], 
            ['3BHK Apartment', '3bhk'], 
            ['4BHK Apartment', '4bhk'], 
            ['Villa', 'villa'], 
            ['Plot/Land', 'plot'], 
            ['Commercial Office', 'commercial_office'], 
            ['Commercial Shop', 'commercial_shop'], 
            ['Warehouse', 'warehouse'],
            ['Duplex', 'duplex'],
            ['Penthouse', 'penthouse']
          ], 
          { include_blank: 'Select property type' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", 
            required: true, 
            id: "property_type_select",
            onchange: "toggleFieldsByPropertyType()" } %>
      <p class="text-sm text-gray-500 mt-1">Choose the type of property</p>
    </div>
    <div></div> <!-- Empty div to maintain grid layout -->
  </div>

  <!-- Unit Number and Floor (conditional based on property type) -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="unit_floor_fields">
    <!-- Unit Number -->
    <div>
      <%= form.label :unit_number, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :unit_number, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., A-101, Plot 25, Unit 305", id: "property_unit_number" %>
      <p class="text-sm text-gray-500 mt-1" id="unit_help_text">Unit/Plot identification number</p>
    </div>
    <!-- Floor -->
    <div id="floor_field">
      <%= form.label :floor, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :floor, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Floor number (0 for ground floor)", min: 0, id: "property_floor" %>
      <p class="text-sm text-gray-500 mt-1">Floor number (not applicable for plots)</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Price -->
    <div>
      <%= form.label :price, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <span class="text-red-500">*</span>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <span class="text-gray-500 text-sm font-medium">₹</span>
        </div>
        <%= form.number_field :price, class: "w-full pl-8 pr-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "2500000", required: true, min: 1 %>
      </div>
      <p class="text-sm text-gray-500 mt-1">Price in Indian Rupees (e.g., ₹25,00,000)</p>
    </div>

    <!-- Area -->
    <div>
      <%= form.label :area, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <span class="text-red-500">*</span>
      <div class="relative">
        <%= form.number_field :area, class: "w-full pl-3 pr-16 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "1200", required: true, min: 1 %>
        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
          <span class="text-gray-500 text-sm font-medium">sq ft</span>
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-1">Total area in square feet</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="bedroom_bathroom_fields">
    <!-- Bedrooms -->
    <div>
      <%= form.label :bedrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bedrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "3", min: 0, max: 10, id: "property_bedrooms" %>
      <p class="text-sm text-gray-500 mt-1">Number of bedrooms</p>
    </div>

    <!-- Bathrooms -->
    <div>
      <%= form.label :bathrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bathrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "2", min: 0, max: 10, id: "property_bathrooms" %>
      <p class="text-sm text-gray-500 mt-1">Number of bathrooms/toilets</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Facing -->
    <div>
      <%= form.label :facing, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :facing, [
            ['North', 'north'], 
            ['South', 'south'], 
            ['East', 'east'], 
            ['West', 'west'], 
            ['North-East', 'north_east'], 
            ['North-West', 'north_west'], 
            ['South-East', 'south_east'], 
            ['South-West', 'south_west']
          ], 
          { include_blank: 'Select facing direction' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" } %>
    </div>

    <!-- Status -->
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status, [
            ['Available for Sale', 'available'], 
            ['Blocked/Hold', 'blocked'], 
            ['Booked', 'booked'], 
            ['Registration in Progress', 'registered'], 
            ['Sold', 'sold']
          ], 
          { selected: property.status || 'available' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" } %>
    </div>
  </div>

  <!-- Property Description -->
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Describe the property features, amenities, nearby locations, etc." %>
  </div>

  <!-- Property Images -->
  <div>
    <%= form.label :images, "Property Images", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="image-upload-container">
      <%= form.file_field :images, multiple: true, accept: "image/*", 
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          onchange: "previewImages(this)" %>
      <p class="text-sm text-gray-500 mt-1">Select multiple images (JPG, PNG, GIF, WebP) - Drag to reorder</p>
      
      <!-- Image Preview Container -->
      <div id="image-preview-container" class="mt-4">
        <% if property.persisted? && property.images.attached? %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="existing-images">
            <% property.images.each_with_index do |image, index| %>
              <div class="relative group image-item" data-index="<%= index %>">
                <%= image_tag image, class: "w-full h-32 object-cover rounded-lg border shadow-sm" %>
                <div class="absolute inset-0 bg-black bg-opacity-50 opacity-0 group-hover:opacity-100 transition-opacity rounded-lg flex items-center justify-center">
                  <button type="button" onclick="removeExistingImage(<%= index %>)" class="bg-red-600 text-white p-2 rounded-full hover:bg-red-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </button>
                </div>
                <div class="absolute top-2 left-2 bg-blue-600 text-white text-xs px-2 py-1 rounded">
                  <%= index + 1 %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        <div id="new-image-previews" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mt-4"></div>
      </div>
    </div>
  </div>

  <!-- Property Videos -->
  <div>
    <%= form.label :videos, "Property Videos", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="video-upload-container">
      <%= form.file_field :videos, multiple: true, accept: "video/*", 
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          onchange: "previewVideos(this)" %>
      <p class="text-sm text-gray-500 mt-1">Select multiple videos (MP4, AVI, MOV, WebM) - Max 100MB per video</p>
      
      <!-- Video Preview Container -->
      <div id="video-preview-container" class="mt-4">
        <% if property.persisted? && property.videos.attached? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="existing-videos">
            <% property.videos.each_with_index do |video, index| %>
              <div class="relative group video-item" data-index="<%= index %>">
                <video class="w-full h-40 object-cover rounded-lg border shadow-sm" controls>
                  <source src="<%= url_for(video) %>" type="<%= video.content_type %>">
                  Your browser does not support the video tag.
                </video>
                <div class="absolute top-2 right-2">
                  <button type="button" onclick="removeExistingVideo(<%= index %>)" class="bg-red-600 text-white p-2 rounded-full hover:bg-red-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </button>
                </div>
                <p class="text-xs text-gray-600 mt-1 px-2"><%= video.filename %></p>
              </div>
            <% end %>
          </div>
        <% end %>
        <div id="new-video-previews" class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4"></div>
      </div>
    </div>
  </div>

  <!-- Location & Additional Details Section -->
  <div class="space-y-4">
    <div class="border-t border-gray-200 pt-4">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Location & Additional Details</h3>
      <p class="text-sm text-gray-500 mb-4">Add location and additional property details</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- City -->
      <div>
        <%= form.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <span class="text-red-500">*</span>
        <%= form.text_field :city, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., Mumbai", required: true %>
      </div>
      
      <!-- State -->
      <div>
        <%= form.label :state, "State", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <span class="text-red-500">*</span>
        <%= form.text_field :state, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., Maharashtra", required: true %>
      </div>
      
      <!-- Pincode -->
      <div>
        <%= form.label :pincode, "Pincode", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :pincode, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., 400001" %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Address -->
      <div class="md:col-span-2">
        <%= form.label :address, "Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :address, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Complete property address with landmark" %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Features -->
      <div class="md:col-span-2">
        <%= form.label :features, "Features & Amenities", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :features, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., 24/7 Water Supply, Power Backup, Security, Garden, Parking, etc." %>
      </div>
      
      <!-- Age of Property -->
      <div>
        <%= form.label :age_of_property, "Age of Property (years)", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.number_field :age_of_property, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., 5", min: 0 %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Possession Status -->
      <div>
        <%= form.label :possession_status, "Possession Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :possession_status, options_for_select([
          ['Ready to Move', 'ready_to_move'],
          ['Under Construction', 'under_construction'],
          ['Immediate Possession', 'immediate_possession']
        ], { prompt: 'Select possession status' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <!-- Parking -->
      <div>
        <%= form.label :parking, "Parking", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :parking, options_for_select([
          ['Available', 'available'],
          ['Not Available', 'not_available'],
          ['Covered', 'covered'],
          ['Open', 'open']
        ], { prompt: 'Select parking option' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <!-- Furnishing Status -->
      <div>
        <%= form.label :furnishing_status, "Furnishing Status", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :furnishing_status, options_for_select([
          ['Furnished', 'furnished'],
          ['Semi Furnished', 'semi_furnished'],
          ['Unfurnished', 'unfurnished']
        ], { prompt: 'Select furnishing status' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Water Supply -->
      <div>
        <%= form.label :water_supply, "Water Supply", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :water_supply, options_for_select([
          ['Municipal', 'municipal'],
          ['Borewell', 'borewell'],
          ['Both', 'both']
        ], { prompt: 'Select water supply' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <!-- Power Backup -->
      <div>
        <%= form.label :power_backup, "Power Backup", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :power_backup, options_for_select([
          ['Available', 'available'],
          ['Not Available', 'not_available']
        ], { prompt: 'Select power backup option' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <!-- Transaction Type -->
      <div>
        <%= form.label :transaction_type, "Transaction Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :transaction_type, options_for_select([
          ['Resale', 'resale'],
          ['New Booking', 'new_booking']
        ], { prompt: 'Select transaction type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Ownership Type -->
      <div>
        <%= form.label :ownership_type, "Ownership Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :ownership_type, options_for_select([
          ['Freehold', 'freehold'],
          ['Leasehold', 'leasehold']
        ], { prompt: 'Select ownership type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <!-- Boundary Wall -->
      <div>
        <%= form.label :boundary_wall, "Boundary Wall", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :boundary_wall, options_for_select([
          ['Compound', 'compound'],
          ['Individual', 'individual']
        ], { prompt: 'Select boundary wall type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <!-- Flooring Type -->
      <div>
        <%= form.label :flooring_type, "Flooring Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :flooring_type, options_for_select([
          ['Marble', 'marble'],
          ['Tiles', 'tiles'],
          ['Wooden', 'wooden'],
          ['Vitrified', 'vitrified']
        ], { prompt: 'Select flooring type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Road Width -->
      <div>
        <%= form.label :road_width, "Road Width", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :road_width, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., 30 feet" %>
      </div>
      
      <!-- Location Advantage -->
      <div>
        <%= form.label :location_advantage, "Location Advantages", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :location_advantage, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., Near metro station, Schools, Hospitals, Market, etc." %>
      </div>
    </div>
  </div>

  <!-- Contact Information Section -->
  <div class="space-y-4">
    <div class="border-t border-gray-200 pt-4">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Contact Information</h3>
      <p class="text-sm text-gray-500 mb-4">Add contact details for this property (all fields are optional)</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Contact Person -->
      <div>
        <%= form.label :contact_person, "Contact Person", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :contact_person, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., Rajesh Kumar, Sales Manager" %>
      </div>

      <!-- Contact Phone -->
      <div>
        <%= form.label :contact_phone, "Contact Phone", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.telephone_field :contact_phone, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "+91 98765 43210", pattern: "[+][9][1][0-9]{10}" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Contact Email -->
      <div>
        <%= form.label :contact_email, "Contact Email", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.email_field :contact_email, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "sales@example.com" %>
      </div>

      <!-- Website -->
      <div>
        <%= form.label :website, "Website", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.url_field :website, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "https://www.propertybuilder.in" %>
      </div>
    </div>

    <!-- Additional Contact -->
    <div>
      <%= form.label :additional_contact, "Additional Contact Details", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :additional_contact, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Office timing: 10 AM - 7 PM, Alternate number: +91 12345 67890, Office address: Mumbai, Maharashtra" %>
    </div>
  </div>

  <!-- Submit Button -->
  <div class="flex justify-end space-x-4">
    <% if @project.present? %>
      <%= link_to "Cancel", project_path(@project), class: "px-6 py-3 border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50 font-medium transition-all" %>
    <% else %>
      <%= link_to "Cancel", properties_path, class: "px-6 py-3 border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50 font-medium transition-all" %>
    <% end %>
    <%= form.submit class: "px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-all transform hover:scale-105 shadow-lg" %>
  </div>
<% end %>

<!-- JavaScript for Form Enhancement -->
<style>
  /* Fix z-index and positioning for currency and unit symbols */
  .relative input {
    position: relative;
    z-index: 1;
  }
  
  /* Ensure symbols are properly positioned and don't overlap */
  .absolute.inset-y-0 {
    z-index: 2;
    pointer-events: none;
  }
  
  /* Ensure adequate padding for symbols */
  .absolute.inset-y-0.left-0 + input {
    padding-left: 2rem;
  }
  
  .absolute.inset-y-0.right-0 {
    right: 0;
  }
  
  /* Smooth transitions for field visibility */
  #floor_field, #bedroom_bathroom_fields, #unit_floor_fields {
    transition: all 0.3s ease;
  }
  
  /* Image and video preview styling */
  .image-item, .video-item {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .image-item:hover, .video-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }
  
  /* Ensure proper spacing between asterisks and labels */
  label span.text-red-500 {
    margin-left: 2px;
  }
  
  /* Prevent form field overlap */
  .grid.gap-6 > div {
    min-width: 0;
  }
</style>
<script>
  // Keep it simple - use standard form submission with multipart
  function previewImages(input) {
    const container = document.getElementById('new-image-previews');
    console.log('Image upload triggered, files:', input.files.length);
    
    // Clear previous previews
    container.innerHTML = '';
    
    if (input.files && input.files.length > 0) {
      Array.from(input.files).forEach((file, index) => {
        if (file.type.startsWith('image/')) {
          const reader = new FileReader();
          reader.onload = function(e) {
            const imageDiv = document.createElement('div');
            imageDiv.className = 'relative group image-item';
            imageDiv.innerHTML = '<img src="' + e.target.result + '" class="w-full h-32 object-cover rounded-lg border shadow-sm" />' +
              '<div class="absolute top-2 left-2 bg-blue-600 text-white text-xs px-2 py-1 rounded">' +
                (index + 1) +
              '</div>' +
              '<p class="text-xs text-gray-600 mt-1 px-2">' + file.name + '</p>';
            container.appendChild(imageDiv);
          };
          reader.readAsDataURL(file);
        }
      });
    }
  }

  // Simple video preview
  function previewVideos(input) {
    const container = document.getElementById('new-video-previews');
    
    // Clear previous previews  
    container.innerHTML = '';
    
    if (input.files && input.files.length > 0) {
      Array.from(input.files).forEach((file, index) => {
        if (file.type.startsWith('video/')) {
          // Check file size (100MB limit)
          if (file.size > 100 * 1024 * 1024) {
            alert('Video \"' + file.name + '\" is too large. Maximum size is 100MB.');
            return;
          }

          const videoDiv = document.createElement('div');
          videoDiv.className = 'relative group video-item';
          videoDiv.innerHTML = '<div class="w-full h-40 bg-gray-100 rounded-lg border flex items-center justify-center">' +
              '<div class="text-center">' +
                '<svg class="w-8 h-8 text-gray-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
                  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>' +
                '</svg>' +
                '<p class="text-xs text-gray-600">' + file.name + '</p>' +
              '</div>' +
            '</div>';
          container.appendChild(videoDiv);
        }
      });
    }
  }
  function toggleFieldsByPropertyType() {
    const propertyType = document.getElementById('property_type_select').value;
    const unitFloorFields = document.getElementById('unit_floor_fields');
    const bedroomBathroomFields = document.getElementById('bedroom_bathroom_fields');
    const floorField = document.getElementById('floor_field');
    const unitField = document.getElementById('property_unit_number');
    const unitHelpText = document.getElementById('unit_help_text');
    
    // Define residential types that need unit numbers and floors
    var residentialTypes = ['1bhk', '2bhk', '3bhk', '4bhk', 'villa', 'duplex', 'penthouse'];
    var plotTypes = ['plot'];
    var commercialTypes = ['commercial_office', 'commercial_shop', 'warehouse'];
    
    // Show/hide unit and floor fields based on property type
    if (plotTypes.includes(propertyType)) {
      // For plots - show unit field only, hide floor field
      unitFloorFields.style.display = 'grid';
      floorField.style.display = 'none';
      document.getElementById('unit_floor_fields').style.gridTemplateColumns = '1fr 1fr'; // Keep two column layout but second column empty
      unitField.placeholder = 'e.g., Plot 25, Survey No. 123/A';
      unitHelpText.textContent = 'Plot number or survey number';
      document.querySelector('#property_floor').removeAttribute('required');
      
      // Hide bedroom/bathroom fields for plots
      bedroomBathroomFields.style.display = 'none';
      document.querySelector('#property_bedrooms').removeAttribute('required');
      document.querySelector('#property_bathrooms').removeAttribute('required');
    } else if (residentialTypes.includes(propertyType)) {
      // For residential - show both unit and floor fields
      unitFloorFields.style.display = 'grid';
      floorField.style.display = 'block';
      document.getElementById('unit_floor_fields').style.gridTemplateColumns = '1fr 1fr';
      unitField.placeholder = 'e.g., A-101, Tower B-205';
      unitHelpText.textContent = 'Unit/Apartment number';
      
      // Show bedroom/bathroom fields for residential
      bedroomBathroomFields.style.display = 'grid';
      if (propertyType.includes('bhk') || propertyType === 'villa' || propertyType === 'duplex' || propertyType === 'penthouse') {
        document.querySelector('#property_bedrooms').setAttribute('required', 'true');
        document.querySelector('#property_bathrooms').setAttribute('required', 'true');
      }
    } else if (commercialTypes.includes(propertyType)) {
      // For commercial - show both unit and floor fields
      unitFloorFields.style.display = 'grid';
      floorField.style.display = 'block';
      document.getElementById('unit_floor_fields').style.gridTemplateColumns = '1fr 1fr';
      
      if (propertyType === 'warehouse') {
        unitField.placeholder = 'e.g., Warehouse A, Godown 5';
        unitHelpText.textContent = 'Warehouse identification';
      } else {
        unitField.placeholder = 'e.g., Shop 12, Office 305';
        unitHelpText.textContent = 'Shop/Office number';
      }
      
      // Hide bedroom/bathroom fields for commercial
      bedroomBathroomFields.style.display = 'none';
      document.querySelector('#property_bedrooms').removeAttribute('required');
      document.querySelector('#property_bathrooms').removeAttribute('required');
    } else {
      // Default - hide all conditional fields
      unitFloorFields.style.display = 'none';
      bedroomBathroomFields.style.display = 'none';
    }

    // Auto-fill bedroom count for BHK apartments
    const bedroomField = document.querySelector('#property_bedrooms');
    if (propertyType.includes('bhk') && bedroomField && !bedroomField.value) {
      const bhkNumber = propertyType.charAt(0);
      bedroomField.value = bhkNumber;
    }
  }

  function removeImage(button) {
    const container = button.closest('.relative');
    if (container) {
      container.remove();
    }
  }

  function removeVideo(button) {
    const container = button.closest('.relative');
    if (container) {
      container.remove();
    }
  }


</script>