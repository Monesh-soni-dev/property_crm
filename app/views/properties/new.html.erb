<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8">
      <%= link_to "← Back to Properties", @project ? project_properties_path(@project) : properties_path, class: "text-amber-700 hover:text-amber-600 mb-4 inline-block font-medium transition duration-200" %>
      <h1 class="text-3xl font-bold text-gray-900">Add New Property</h1>
      <p class="text-gray-600 mt-2">Add a new property to <%= @project ? @project.name : 'the system' %></p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
      <%= render "form", property: @property %>
    </div>
  </div>
</div>