<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8">
      <% if @project.present? %>
        <%= link_to "← Back to #{@project.name}", project_path(@project), class: "text-blue-600 hover:text-blue-700 mb-4 inline-block font-medium transition duration-200 flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Project
        <% end %>
      <% else %>
        <%= link_to properties_path, class: "text-blue-600 hover:text-blue-700 mb-4 inline-block font-medium transition duration-200 flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Properties
        <% end %>
      <% end %>
      <h1 class="text-3xl font-bold text-gray-900">Add New Property</h1>
      <p class="text-gray-600 mt-2">Add a new property to <%= @project ? @project.name : 'the system' %></p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
      <%= render "form", property: @property %>
    </div>
  </div>
</div>