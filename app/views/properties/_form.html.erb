<%= form_with(model: property, class: "space-y-6") do |form| %>
  <% if property.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There were <%= pluralize(property.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc pl-5 space-y-1">
              <% property.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Project Selection -->
    <div>
      <%= form.label :project_id, "Select Project", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.collection_select :project_id, 
          current_user.projects.order(:name), :id, :name, 
          { prompt: 'Select a project' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" } %>
      <p class="text-sm text-gray-500 mt-1">Choose which project this property belongs to</p>
    </div>

    <!-- Property Title -->
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Enter property title" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Unit Number -->
    <div>
      <%= form.label :unit_number, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :unit_number, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., A-101" %>
    </div>
    <!-- Floor -->
    <div>
      <%= form.label :floor, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :floor, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Floor number" %>
    </div>

    <!-- Property Type -->
    <div>
      <%= form.label :property_type, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :property_type, [['Apartment', 'apartment'], ['Villa', 'villa'], ['Plot', 'plot'], ['Commercial', 'commercial']], { include_blank: 'Select type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Price -->
    <div>
      <%= form.label :price, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :price, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Price in rupees" %>
    </div>

    <!-- Area -->
    <div>
      <%= form.label :area, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :area, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Area in sq ft" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Bedrooms -->
    <div>
      <%= form.label :bedrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bedrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Number of bedrooms" %>
    </div>

    <!-- Bathrooms -->
    <div>
      <%= form.label :bathrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bathrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Number of bathrooms" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Facing -->
    <div>
      <%= form.label :facing, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :facing, [['North', 'north'], ['South', 'south'], ['East', 'east'], ['West', 'west'], ['North-East', 'north_east'], ['North-West', 'north_west'], ['South-East', 'south_east'], ['South-West', 'south_west']], { include_blank: 'Select facing' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Status -->
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status, [['Available', 'available'], ['Blocked', 'blocked'], ['Booked', 'booked'], ['Registered', 'registered'], ['Sold', 'sold']], { selected: property.status || 'available' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <!-- Property Description -->
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Describe the property..." %>
  </div>

  <!-- Property Images -->
  <div>
    <%= form.label :images, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :images, multiple: true, accept: "image/*", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-500 mt-1">Select multiple images (JPG, PNG, GIF, etc.)</p>
    <% if property.persisted? && property.images.attached? %>
      <div class="mt-3">
        <p class="text-sm font-medium text-gray-700 mb-2">Current Images:</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          <% property.images.each do |image| %>
            <div class="relative">
              <%= image_tag image, class: "w-full h-24 object-cover rounded-lg border" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Property Videos -->
  <div>
    <%= form.label :videos, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :videos, multiple: true, accept: "video/*", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-500 mt-1">Select multiple videos (MP4, AVI, MOV, etc.)</p>
    <% if property.persisted? && property.videos.attached? %>
      <div class="mt-3">
        <p class="text-sm font-medium text-gray-700 mb-2">Current Videos:</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
          <% property.videos.each do |video| %>
            <div class="relative">
              <video class="w-full h-32 object-cover rounded-lg border" controls>
                <%= video_tag video, class: "w-full h-32 object-cover rounded-lg border" %>
              </video>
              <p class="text-xs text-gray-500 mt-1"><%= video.filename %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Contact Information Section -->
  <div class="space-y-4">
    <div class="border-t border-gray-200 pt-4">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Contact Information</h3>
      <p class="text-sm text-gray-500 mb-4">Add contact details for this property (all fields are optional)</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Contact Person -->
      <div>
        <%= form.label :contact_person, "Contact Person", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :contact_person, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., John Doe, Sales Manager" %>
      </div>

      <!-- Contact Phone -->
      <div>
        <%= form.label :contact_phone, "Contact Phone", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.telephone_field :contact_phone, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "+1 (555) 123-4567" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Contact Email -->
      <div>
        <%= form.label :contact_email, "Contact Email", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.email_field :contact_email, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "contact@example.com" %>
      </div>

      <!-- Website -->
      <div>
        <%= form.label :website, "Website", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.url_field :website, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "https://www.example.com" %>
      </div>
    </div>

    <!-- Additional Contact -->
    <div>
      <%= form.label :additional_contact, "Additional Contact Details", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :additional_contact, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Any other contact information, office hours, or special instructions..." %>
    </div>
  </div>

  <!-- Submit Button -->
  <div class="flex justify-end space-x-4">
    <%= link_to "Cancel", @project ? project_properties_path(@project) : properties_path, class: "px-6 py-3 border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50 font-medium transition-all" %>
    <%= form.submit class: "px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-all transform hover:scale-105 shadow-lg" %>
  </div>
<% end %>