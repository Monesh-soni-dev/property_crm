<% 
  form_model = @project.present? ? [@project, property] : property
  def field_name_with_label(attribute)
    field_labels = {
      title: 'Title',
      project_id: 'Project',
      property_type: 'Property Type',
      unit_number: 'Unit Number',
      floor: 'Floor',
      price: 'Price',
      area: 'Area',
      bedrooms: 'Bedrooms',
      bathrooms: 'Bathrooms',
      facing: 'Facing',
      status: 'Status',
      description: 'Description',
      city: 'City',
      state: 'State',
      pincode: 'Pincode',
      address: 'Address',
      features: 'Features & Amenities',
      age_of_property: 'Age of Property',
      possession_status: 'Possession Status',
      parking: 'Parking',
      furnishing_status: 'Furnishing Status',
      water_supply: 'Water Supply',
      power_backup: 'Power Backup',
      transaction_type: 'Transaction Type',
      ownership_type: 'Ownership Type',
      boundary_wall: 'Boundary Wall',
      flooring_type: 'Flooring Type',
      road_width: 'Road Width',
      location_advantage: 'Location Advantages',
      contact_person: 'Contact Person',
      contact_phone: 'Contact Phone',
      contact_email: 'Contact Email',
      website: 'Website',
      additional_contact: 'Additional Contact Details'
    }
    
    field_labels[attribute.to_sym] || attribute.to_s.humanize
  end
%>
<%= form_with(model: form_model, class: "max-w-6xl mx-auto bg-white rounded-2xl shadow-xl p-8 space-y-8", local: true, multipart: true) do |form| %>
  <% if property.errors.any? %>
    <div class="bg-gradient-to-r from-red-50 to-pink-50 border-l-4 border-red-500 rounded-xl p-6 shadow-md">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <div class="w-10 h-10 bg-red-500 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <div class="ml-4 flex-1">
          <h3 class="text-lg font-semibold text-red-800 mb-2">
            <%= property.errors.count == 1 ? 'Error' : 'Errors' %> Found
          </h3>
          <div class="text-sm text-red-700 space-y-2">
            <% property.errors.each do |error| %>
              <div class="flex items-center bg-white/50 rounded-lg px-3 py-2">
                <svg class="w-4 h-4 text-red-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium"><%= field_name_with_label(error.attribute) %></span>
                <span class="text-red-500 mx-2">*</span>
                <span><%= error.message %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Basic Information Section -->
  <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border border-blue-100">
    <div class="flex items-center mb-6">
      <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center mr-3">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-800">Basic Information</h2>
        <p class="text-sm text-gray-600">Essential property details</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Project Selection -->
      <div class="group">
        <%= form.label :project_id, "Select Project <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-blue-600 transition-colors" %>
        <%= form.collection_select :project_id, 
            current_user.projects.order(:name), :id, :name, 
            { prompt: 'Select a project' }, 
            { class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all hover:border-blue-300 bg-white shadow-sm", required: true } %>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Choose which project this property belongs to
        </p>
      </div>

      <!-- Property Title -->
      <div class="group">
        <%= form.label :title, "Title <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-blue-600 transition-colors" %>
        <%= form.text_field :title, class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all hover:border-blue-300 bg-white shadow-sm", placeholder: "e.g., Premium 3BHK Apartment", required: true %>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Give your property a descriptive title
        </p>
      </div>
    </div>
  </div>

  <!-- Property Details Section -->
  <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl p-6 border border-purple-100">
    <div class="flex items-center mb-6">
      <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center mr-3">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-800">Property Details</h2>
        <p class="text-sm text-gray-600">Type, size, and specifications</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="group">
        <%= form.label :property_type, "Property Type <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-purple-600 transition-colors" %>
        <%= form.select :property_type, [
              ['1BHK Apartment', '1bhk'], 
              ['2BHK Apartment', '2bhk'], 
              ['3BHK Apartment', '3bhk'], 
              ['4BHK Apartment', '4bhk'], 
              ['Villa', 'villa'], 
              ['Plot/Land', 'plot'], 
              ['Commercial Office', 'commercial_office'], 
              ['Commercial Shop', 'commercial_shop'], 
              ['Warehouse', 'warehouse'],
              ['Duplex', 'duplex'],
              ['Penthouse', 'penthouse']
            ], 
            { include_blank: 'Select property type' }, 
            { class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all hover:border-purple-300 bg-white shadow-sm", 
              required: true, 
              id: "property_type_select",
              onchange: "toggleFieldsByPropertyType()" } %>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Choose the type of property
        </p>
      </div>
    </div>
  </div>

  <!-- Unit Number and Floor (conditional based on property type) -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="unit_floor_fields">
    <!-- Unit Number -->
    <div>
      <%= form.label :unit_number, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :unit_number, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., A-101, Plot 25, Unit 305", id: "property_unit_number" %>
      <p class="text-sm text-gray-500 mt-1" id="unit_help_text">Unit/Plot identification number</p>
    </div>
    <!-- Floor -->
    <div id="floor_field">
      <%= form.label :floor, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :floor, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Floor number (0 for ground floor)", min: 0, id: "property_floor" %>
      <p class="text-sm text-gray-500 mt-1">Floor number (not applicable for plots)</p>
    </div>
  </div>

  <!-- Pricing & Size Section -->
  <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl p-6 border border-green-100">
    <div class="flex items-center mb-6">
      <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center mr-3">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-800">Pricing & Size</h2>
        <p class="text-sm text-gray-600">Financial details and dimensions</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Price -->
      <div class="group">
        <%= form.label :price, "Price <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-green-600 transition-colors" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="text-gray-600 font-semibold">₹</span>
          </div>
          <%= form.number_field :price, class: "w-full pl-10 pr-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all hover:border-green-300 bg-white shadow-sm", placeholder: "2500000", required: true, min: 1 %>
        </div>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Price in Indian Rupees (e.g., ₹25,00,000)
        </p>
      </div>

      <!-- Area -->
      <div class="group">
        <%= form.label :area, "Area <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-green-600 transition-colors" %>
        <div class="relative">
          <%= form.number_field :area, class: "w-full pl-4 pr-16 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all hover:border-green-300 bg-white shadow-sm", placeholder: "1200", required: true, min: 1 %>
          <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
            <span class="text-gray-600 font-semibold text-sm">sq ft</span>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Total area in square feet
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="bedroom_bathroom_fields">
    <!-- Bedrooms -->
    <div>
      <%= form.label :bedrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bedrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "3", min: 0, max: 10, id: "property_bedrooms" %>
      <p class="text-sm text-gray-500 mt-1">Number of bedrooms</p>
    </div>

    <!-- Bathrooms -->
    <div>
      <%= form.label :bathrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bathrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "2", min: 0, max: 10, id: "property_bathrooms" %>
      <p class="text-sm text-gray-500 mt-1">Number of bathrooms/toilets</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Facing -->
    <div>
      <%= form.label :facing, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :facing, [
            ['North', 'north'], 
            ['South', 'south'], 
            ['East', 'east'], 
            ['West', 'west'], 
            ['North-East', 'north_east'], 
            ['North-West', 'north_west'], 
            ['South-East', 'south_east'], 
            ['South-West', 'south_west']
          ], 
          { include_blank: 'Select facing direction' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" } %>
    </div>

    <!-- Status -->
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status, [
            ['Available for Sale', 'available'], 
            ['Blocked/Hold', 'blocked'], 
            ['Booked', 'booked'], 
            ['Registration in Progress', 'registered'], 
            ['Sold', 'sold']
          ], 
          { selected: property.status || 'available' }, 
          { class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" } %>
    </div>
  </div>

  <!-- Property Description -->
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Describe the property features, amenities, nearby locations, etc." %>
  </div>

  <!-- Property Images -->
  <div>
    <%= form.label :images, "Property Images", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="image-upload-container">
      <%= form.file_field :images, multiple: true, accept: "image/*", 
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          onchange: "previewImages(this)" %>
      <p class="text-sm text-gray-500 mt-1">Select multiple images (JPG, PNG, GIF, WebP) - Drag to reorder</p>
      
      <!-- Image Preview Container -->
      <div id="image-preview-container" class="mt-4">
        <% if property.persisted? && property.images.attached? %>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="existing-images">
            <% property.images.each_with_index do |image, index| %>
              <div class="relative group image-item" data-index="<%= index %>">
                <%= image_tag image, class: "w-full h-32 object-cover rounded-lg border shadow-sm" %>
                <div class="absolute inset-0 bg-black bg-opacity-50 opacity-0 group-hover:opacity-100 transition-opacity rounded-lg flex items-center justify-center">
                  <button type="button" onclick="removeExistingImage(<%= index %>)" class="bg-red-600 text-white p-2 rounded-full hover:bg-red-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </button>
                </div>
                <div class="absolute top-2 left-2 bg-blue-600 text-white text-xs px-2 py-1 rounded">
                  <%= index + 1 %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        <div id="new-image-previews" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mt-4"></div>
      </div>
    </div>
  </div>

  <!-- Property Videos -->
  <div>
    <%= form.label :videos, "Property Videos", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="video-upload-container">
      <%= form.file_field :videos, multiple: true, accept: "video/*", 
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          onchange: "previewVideos(this)" %>
      <p class="text-sm text-gray-500 mt-1">Select multiple videos (MP4, AVI, MOV, WebM) - Max 100MB per video</p>
      
      <!-- Video Preview Container -->
      <div id="video-preview-container" class="mt-4">
        <% if property.persisted? && property.videos.attached? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="existing-videos">
            <% property.videos.each_with_index do |video, index| %>
              <div class="relative group video-item" data-index="<%= index %>">
                <video class="w-full h-40 object-cover rounded-lg border shadow-sm" controls>
                  <source src="<%= url_for(video) %>" type="<%= video.content_type %>">
                  Your browser does not support the video tag.
                </video>
                <div class="absolute top-2 right-2">
                  <button type="button" onclick="removeExistingVideo(<%= index %>)" class="bg-red-600 text-white p-2 rounded-full hover:bg-red-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  </button>
                </div>
                <p class="text-xs text-gray-600 mt-1 px-2"><%= video.filename %></p>
              </div>
            <% end %>
          </div>
        <% end %>
        <div id="new-video-previews" class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4"></div>
      </div>
    </div>
  </div>

  <!-- Location & Additional Details Section -->
  <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-xl p-6 border border-orange-100">
    <div class="flex items-center mb-6">
      <div class="w-8 h-8 bg-orange-600 rounded-lg flex items-center justify-center mr-3">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-800">Location & Additional Details</h2>
        <p class="text-sm text-gray-600">Add location and additional property details</p>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- City -->
      <div class="group">
        <%= form.label :city, "City <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-orange-600 transition-colors" %>
        <%= form.text_field :city, class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-all hover:border-orange-300 bg-white shadow-sm", placeholder: "e.g., Mumbai", required: true %>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          City where property is located
        </p>
      </div>
      
      <!-- State -->
      <div class="group">
        <%= form.label :state, "State <span style='color: red;'>*</span>".html_safe, class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-orange-600 transition-colors" %>
        <%= form.text_field :state, class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-all hover:border-orange-300 bg-white shadow-sm", placeholder: "e.g., Maharashtra", required: true %>
        <p class="text-xs text-gray-500 mt-2 flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          State where property is located
        </p>
      </div>
      
      <!-- Pincode -->
      <div class="group">
        <%= form.label :pincode, "Pincode", class: "block text-sm font-semibold text-gray-700 mb-2 group-hover:text-orange-600 transition-colors" %>
