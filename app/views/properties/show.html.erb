<div class="max-w-6xl mx-auto px-4 py-6">
  <!-- Back Navigation -->
  <div class="mb-6">
    <%= link_to (@project ? project_properties_path(@project) : properties_path), class: "text-blue-600 hover:text-blue-800 font-medium" do %>
      ← Back to Properties
    <% end %>
  </div>

  <!-- Property Header -->
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden mb-6">
    <!-- Property Images - Full Size Display -->
    <div class="relative h-96 md:h-[500px] bg-gray-100">
      <% if @property.images.attached? %>
        <% if @property.images.count > 1 %>
          <!-- Simple Image Display for Multiple Images -->
          <div id="imageCarousel" class="relative w-full h-full">
            <% @property.images.each_with_index do |image, index| %>
              <%= image_tag image, 
                  class: "carousel-image w-full h-full object-cover absolute inset-0 cursor-pointer #{index == 0 ? 'block' : 'hidden'}", 
                  data: { index: index },
                  onclick: "openImageModal(this.src)" %>
            <% end %>
            
            <!-- Simple Navigation -->
            <button id="prevBtn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-white shadow-md p-2 rounded">
              ‹
            </button>
            <button id="nextBtn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-white shadow-md p-2 rounded">
              ›
            </button>
            
            <!-- Image Counter and Auto-play Controls -->
            <div class="absolute bottom-4 left-4 bg-black bg-opacity-50 text-white px-3 py-1 rounded text-sm">
              <span id="currentImage">1</span> of <%= @property.images.count %>
            </div>
            
            <!-- Auto-play Control -->
            <div class="absolute bottom-4 right-4 bg-black bg-opacity-50 text-white px-3 py-1 rounded text-sm">
              <button id="pausePlayBtn" class="flex items-center gap-1">
                <span id="pausePlayIcon">⏸️</span>
                <span id="pausePlayText">Pause</span>
              </button>
            </div>
          </div>
        <% else %>
          <%= image_tag @property.images.first, class: "w-full h-full object-cover cursor-pointer", onclick: "openImageModal(this.src)" %>
        <% end %>
      <% else %>
        <div class="flex items-center justify-center h-full text-gray-400">
          No images available
        </div>
      <% end %>
      
      <!-- Status Badge -->
      <div class="absolute top-4 right-4">
        <span class="px-3 py-1 rounded text-sm font-medium
          <%= case @property.status
              when 'available' then 'bg-green-100 text-green-800'
              when 'sold' then 'bg-red-100 text-red-800'
              when 'booked' then 'bg-blue-100 text-blue-800'
              when 'blocked' then 'bg-yellow-100 text-yellow-800'
              when 'registered' then 'bg-purple-100 text-purple-800'
              else 'bg-gray-100 text-gray-800'
              end %>">
          <%= @property.status&.humanize || 'Unknown' %>
        </span>
      </div>
    </div>
    
    <!-- Property Details -->
    <div class="p-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @property.title %></h1>
          <p class="text-gray-600"><%= @property.project.name %> • Unit <%= @property.unit_number %> • Floor <%= @property.floor %></p>
        </div>
        <div class="text-right">
          <% if @property.price.present? && @property.price > 0 %>
            <div class="text-2xl font-bold text-gray-900">₹<%= number_with_delimiter(@property.price) %></div>
            <div class="text-sm text-gray-500">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %> per sq ft</div>
          <% else %>
            <div class="text-lg text-gray-500">Price not set</div>
          <% end %>
        </div>
      </div>
      
      <% if @property.description.present? %>
        <div class="text-gray-700 mb-4">
          <%= simple_format(@property.description) %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Property Information Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    
    <!-- Property Overview -->
    <div class="bg-white border border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Property Overview</h2>
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center p-4 bg-blue-50 rounded-lg">
            <div class="text-2xl font-bold text-blue-600"><%= @property.area %></div>
            <div class="text-sm text-gray-600">sq ft</div>
          </div>
          <div class="text-center p-4 bg-green-50 rounded-lg">
            <div class="text-2xl font-bold text-green-600"><%= @property.bedrooms %></div>
            <div class="text-sm text-gray-600">Bedrooms</div>
          </div>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center p-4 bg-purple-50 rounded-lg">
            <div class="text-2xl font-bold text-purple-600"><%= @property.bathrooms %></div>
            <div class="text-sm text-gray-600">Bathrooms</div>
          </div>
          <div class="text-center p-4 bg-orange-50 rounded-lg">
            <div class="text-2xl font-bold text-orange-600"><%= @property.floor %></div>
            <div class="text-sm text-gray-600">Floor</div>
          </div>
        </div>
        
        <div class="pt-4 border-t border-gray-200">
          <div class="flex justify-between items-center mb-2">
            <span class="text-gray-600">Property Type</span>
            <span class="font-medium"><%= @property.property_type&.titleize || 'Not specified' %></span>
          </div>
          <div class="flex justify-between items-center mb-2">
            <span class="text-gray-600">Facing</span>
            <span class="font-medium"><%= @property.facing || 'Not specified' %></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Unit Number</span>
            <span class="font-medium"><%= @property.unit_number %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Project & Contact Information -->
    <div class="space-y-6">
      
      <!-- Project Information -->
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Project Information</h2>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Project Name</span>
            <span class="font-medium">
              <%= link_to @property.project.name, @property.project, class: "text-blue-600 hover:text-blue-800" %>
            </span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Location</span>
            <span class="font-medium"><%= @property.project.location || 'Not specified' %></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Status</span>
            <span class="font-medium">
              <span class="px-2 py-1 rounded text-sm
                <%= case @property.status
                    when 'available' then 'bg-green-100 text-green-800'
                    when 'sold' then 'bg-red-100 text-red-800'
                    when 'booked' then 'bg-blue-100 text-blue-800'
                    when 'blocked' then 'bg-yellow-100 text-yellow-800'
                    when 'registered' then 'bg-purple-100 text-purple-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= @property.status&.humanize || 'Unknown' %>
              </span>
            </span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Listed Date</span>
            <span class="font-medium"><%= @property.created_at.strftime('%B %d, %Y') %></span>
          </div>
        </div>
      </div>
      
      <!-- Contact Information -->
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Contact Information</h2>
        <% if @property.contact_person.present? || @property.contact_phone.present? || @property.contact_email.present? || @property.website.present? %>
          <div class="space-y-3">
            <% if @property.contact_person.present? %>
              <div class="flex justify-between items-center">
                <span class="text-gray-600">Contact Person</span>
                <span class="font-medium"><%= @property.contact_person %></span>
              </div>
            <% end %>

            <% if @property.contact_phone.present? %>
              <div class="flex justify-between items-center">
                <span class="text-gray-600">Phone</span>
                <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" class="text-blue-600 hover:text-blue-800 font-medium">
                  <%= @property.contact_phone %>
                </a>
              </div>
            <% end %>

            <% if @property.contact_email.present? %>
              <div class="flex justify-between items-center">
                <span class="text-gray-600">Email</span>
                <a href="mailto:<%= @property.contact_email %>" class="text-blue-600 hover:text-blue-800 font-medium">
                  <%= @property.contact_email %>
                </a>
              </div>
            <% end %>

            <% if @property.website.present? %>
              <div class="flex justify-between items-center">
                <span class="text-gray-600">Website</span>
                <a href="<%= @property.website %>" target="_blank" class="text-blue-600 hover:text-blue-800 font-medium">
                  Visit Website
                </a>
              </div>
            <% end %>

            <% if @property.additional_contact.present? %>
              <div class="pt-3 border-t border-gray-200">
                <span class="text-gray-600 block mb-2">Additional Information</span>
                <div class="text-gray-800"><%= simple_format(@property.additional_contact) %></div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500">No contact information available.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Interested in Our Properties Section -->
  <% if @property.status == 'available' && (!user_signed_in? || @property.project.user_id != current_user&.id) %>
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-8 mb-6">
      <div class="text-center mb-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">💡 Interested in Our Properties?</h2>
        <p class="text-gray-700">Connect with our property experts to schedule a visit or get more information about this amazing property!</p>
      </div>

      <% if user_signed_in? %>
        <!-- Authenticated User - Show Interest Form -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Interest Form -->
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">📋 Express Your Interest</h3>
            
            <%= form_with model: [@property.project, Lead.new], local: true, class: "space-y-4" do |form| %>
              <%= form.hidden_field :property_id, value: @property.id %>
              
              <div>
                <%= form.text_field :customer_name, placeholder: "Your Full Name", value: current_user.first_name&.to_s + " " + current_user.last_name&.to_s, required: true,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.email_field :customer_email, placeholder: "Your Email Address", value: current_user.email, required: true,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.telephone_field :customer_phone, placeholder: "Your Phone Number", required: true,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.text_area :notes, placeholder: "Any specific questions or requirements?", rows: 3,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.submit "🚀 I'm Interested - Contact Me!", 
                    class: "w-full bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-all transform hover:scale-105 shadow-lg" %>
              </div>
            <% end %>
          </div>

          <!-- Direct Contact Options -->
          <div class="space-y-6">
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">📞 Direct Contact</h3>
              <div class="space-y-4">
                <% if @property.contact_phone.present? %>
                  <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" 
                     class="flex items-center gap-3 p-3 bg-green-50 rounded-lg hover:bg-green-100 transition-colors group">
                    <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white">
                      📱
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-green-700">Call Now</div>
                      <div class="text-gray-600"><%= @property.contact_phone %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.contact_email.present? %>
                  <a href="mailto:<%= @property.contact_email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>" 
                     class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors group">
                    <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center text-white">
                      ✉️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-blue-700">Send Email</div>
                      <div class="text-gray-600"><%= @property.contact_email %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.project.user&.email.present? %>
                  <a href="mailto:<%= @property.project.user.email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>" 
                     class="flex items-center gap-3 p-3 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors group">
                    <div class="w-10 h-10 bg-purple-500 rounded-full flex items-center justify-center text-white">
                      🏗️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-purple-700">Contact Builder</div>
                      <div class="text-gray-600"><%= @property.project.user&.first_name&.to_s + " " + @property.project.user&.last_name&.to_s || @property.project.user&.email %></div>
                    </div>
                  </a>
                <% end %>
              </div>
            </div>

            <!-- Quick Actions -->
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">🎯 Quick Actions</h3>
              <div class="space-y-3">
                <% if @property.website.present? %>
                  <a href="<%= @property.website %>" target="_blank" 
                     class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                    <span class="font-medium text-gray-900">🌐 Visit Project Website</span>
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                <% end %>
                
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <span class="font-medium text-gray-900">💰 Price: ₹<%= number_with_delimiter(@property.price) %></span>
                  <span class="text-sm text-gray-500">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %>/sq ft</span>
                </div>
                
                <div class="p-3 bg-yellow-50 rounded-lg border border-yellow-200">
                  <p class="text-sm text-yellow-800 font-medium">
                    ⚡ This property is available now! Contact us quickly to schedule a visit.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Guest User - Interest Form -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Interest Form -->
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <%= render 'interests/form' %>
          </div>

          <!-- Guest Contact Options -->
          <div class="space-y-6">
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">📞 Contact Options</h3>
              <p class="text-sm text-gray-600 mb-4">You can also contact us directly without creating an account:</p>
              
              <div class="space-y-4">
                <% if @property.contact_phone.present? %>
                  <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" 
                     class="flex items-center gap-3 p-3 bg-green-50 rounded-lg hover:bg-green-100 transition-colors group">
                    <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white">
                      📱
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-green-700">Call Now</div>
                      <div class="text-gray-600"><%= @property.contact_phone %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.contact_email.present? %>
                  <a href="mailto:<%= @property.contact_email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>&body=Hi,%0D%0A%0D%0AI am interested in the property:<%= @property.title %> in <%= @property.project.name %>.%0D%0A%0D%0ACould you please provide more details?%0D%0A%0D%0AThank you!" 
                     class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors group">
                    <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center text-white">
                      ✉️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-blue-700">Send Email</div>
                      <div class="text-gray-600"><%= @property.contact_email %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.project.user&.email.present? %>
                  <a href="mailto:<%= @property.project.user.email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>&body=Hi,%0D%0A%0D%0AI am interested in your property:<%= @property.title %> in <%= @property.project.name %>.%0D%0A%0D%0ACould you please provide more details?%0D%0A%0D%0AThank you!" 
                     class="flex items-center gap-3 p-3 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors group">
                    <div class="w-10 h-10 bg-purple-500 rounded-full flex items-center justify-center text-white">
                      🏗️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-purple-700">Contact Builder</div>
                      <div class="text-gray-600"><%= @property.project.user&.first_name&.to_s + " " + @property.project.user&.last_name&.to_s || @property.project.user&.email %></div>
                    </div>
                  </a>
                <% end %>
              </div>
            </div>

            <!-- Property Info -->
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">🏠 Property Details</h3>
              
              <div class="space-y-3">
                <% if @property.website.present? %>
                  <a href="<%= @property.website %>" target="_blank" 
                     class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                    <span class="font-medium text-gray-900">🌐 Visit Project Website</span>
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                <% end %>
                
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <span class="font-medium text-gray-900">💰 Price: ₹<%= number_with_delimiter(@property.price) %></span>
                  <span class="text-sm text-gray-500">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %>/sq ft</span>
                </div>
                
                <div class="p-3 bg-yellow-50 rounded-lg border border-yellow-200">
                  <p class="text-sm text-yellow-800 font-medium">
                    ⚡ This property is available now! Sign up to get priority access.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Action Buttons -->
  <% if user_signed_in? && (@property.project.user == current_user || current_user.admin?) %>
    <div class="mt-6 bg-white border border-gray-200 rounded-lg p-6">
      <div class="flex gap-4">
        <%= link_to 'Edit Property', edit_property_path(@property), 
            class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
        <%= link_to 'Delete', @property, method: :delete, 
            confirm: 'Are you sure?', 
            class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
      </div>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const carousel = document.getElementById('imageCarousel');
  if (!carousel) return;

  const images = carousel.querySelectorAll('.carousel-image');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const currentImageSpan = document.getElementById('currentImage');
  const pausePlayBtn = document.getElementById('pausePlayBtn');
  const pausePlayIcon = document.getElementById('pausePlayIcon');
  const pausePlayText = document.getElementById('pausePlayText');
  
  let currentIndex = 0;
  let autoPlayInterval;
  let isPlaying = true;

  function showImage(index) {
    images.forEach((img, i) => {
      img.style.display = i === index ? 'block' : 'none';
    });
    if (currentImageSpan) {
      currentImageSpan.textContent = index + 1;
    }
  }

  function nextImage() {
    currentIndex = currentIndex < images.length - 1 ? currentIndex + 1 : 0;
    showImage(currentIndex);
  }

  function prevImage() {
    currentIndex = currentIndex > 0 ? currentIndex - 1 : images.length - 1;
    showImage(currentIndex);
  }

  function startAutoPlay() {
    if (images.length > 1) {
      autoPlayInterval = setInterval(nextImage, 4000); // Change every 4 seconds
      isPlaying = true;
      if (pausePlayIcon) pausePlayIcon.textContent = '⏸️';
      if (pausePlayText) pausePlayText.textContent = 'Pause';
    }
  }

  function pauseAutoPlay() {
    clearInterval(autoPlayInterval);
    isPlaying = false;
    if (pausePlayIcon) pausePlayIcon.textContent = '▶️';
    if (pausePlayText) pausePlayText.textContent = 'Play';
  }

  function toggleAutoPlay() {
    if (isPlaying) {
      pauseAutoPlay();
    } else {
      startAutoPlay();
    }
  }

  // Event listeners
  prevBtn?.addEventListener('click', function() {
    pauseAutoPlay();
    prevImage();
  });

  nextBtn?.addEventListener('click', function() {
    pauseAutoPlay();
    nextImage();
  });

  pausePlayBtn?.addEventListener('click', function() {
    toggleAutoPlay();
  });

  // Initialize carousel
  showImage(0);
  startAutoPlay();

  // Pause auto-play when mouse hovers over carousel
  carousel?.addEventListener('mouseenter', function() {
    if (isPlaying) {
      clearInterval(autoPlayInterval);
    }
  });

  carousel?.addEventListener('mouseleave', function() {
    if (isPlaying) {
      startAutoPlay();
    }
  });
});

// Image Modal Functions
function openImageModal(imageSrc) {
  const modal = document.getElementById('imageModal');
  const modalImage = document.getElementById('modalImage');
  
  if (modal && modalImage) {
    modalImage.src = imageSrc;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden'; // Prevent background scroll
  }
}

function closeImageModal() {
  const modal = document.getElementById('imageModal');
  
  if (modal) {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = 'auto'; // Restore scroll
  }
}

// Close modal when clicking outside of image
function modalOverlayClick(event) {
  if (event.target.id === 'imageModal') {
    closeImageModal();
  }
}

// Keyboard navigation for modal
document.addEventListener('keydown', function(event) {
  const modal = document.getElementById('imageModal');
  
  if (modal && !modal.classList.contains('hidden')) {
    if (event.key === 'Escape') {
      closeImageModal();
    }
  }
});
</script>

<!-- Image Modal -->
<div id="imageModal" class="hidden fixed inset-0 z-50 bg-black bg-opacity-90 items-center justify-center" onclick="modalOverlayClick(event)">
  <div class="relative max-w-full max-h-full">
    <img id="modalImage" src="" alt="Property Image" class="max-w-full max-h-full object-contain">
    <button 
      onclick="closeImageModal()" 
      class="absolute top-4 right-4 text-white text-3xl hover:text-gray-300 bg-black bg-opacity-50 rounded-full w-10 h-10 flex items-center justify-center">
      &times;
    </button>
  </div>
</div>