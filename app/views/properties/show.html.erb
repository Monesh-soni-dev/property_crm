<div class="min-h-screen bg-gray-50">
  <!-- Back Navigation -->
  <div class="mb-6">
    <%= link_to (@project ? project_properties_path(@project) : properties_path), class: "inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-medium transition-all hover:gap-3" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to Properties
    <% end %>
  </div>

  <!-- Property Header with Image Carousel -->
  <div class="bg-white rounded-3xl shadow-lg overflow-hidden mb-8">
    <div class="relative h-80 bg-gradient-to-br from-slate-100 to-slate-200">
      <% if @property.images.attached? %>
        <% if @property.images.count > 1 %>
          <!-- Image Carousel for Multiple Images -->
          <div id="imageCarousel" class="relative w-full h-full">
            <% @property.images.each_with_index do |image, index| %>
              <%= image_tag image, 
                  class: "carousel-image w-full h-full object-cover absolute inset-0 transition-opacity duration-300 #{index == 0 ? 'opacity-100' : 'opacity-0'}", 
                  data: { index: index } %>
            <% end %>
            
            <!-- Navigation Arrows -->
            <button id="prevBtn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-3 rounded-full transition-all" style="z-index: 10;">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>
            <button id="nextBtn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white p-3 rounded-full transition-all" style="z-index: 10;">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
            
            <!-- Image Counter -->
            <div class="absolute bottom-4 left-4 bg-black/50 text-white px-3 py-1 rounded-full text-sm" style="z-index: 10;">
              <span id="currentImage">1</span> / <%= @property.images.count %>
            </div>
            
            <!-- Dots Navigation -->
            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2" style="z-index: 10;">
              <% @property.images.each_with_index do |_, index| %>
                <button class="carousel-dot w-2 h-2 rounded-full transition-all <%= index == 0 ? 'bg-white' : 'bg-white/50' %>" data-index="<%= index %>"></button>
              <% end %>
            </div>
          </div>
        <% else %>
          <!-- Single Image -->
          <%= image_tag @property.images.first, class: "w-full h-full object-cover" %>
        <% end %>
      <% else %>
        <div class="flex items-center justify-center h-full">
          <svg class="w-24 h-24 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
        </div>
      <% end %>
      
      <!-- Status Overlay -->
      <div class="absolute top-6 right-6" style="z-index: 10;">
        <span class="px-4 py-2 rounded-full text-sm font-bold uppercase tracking-wide backdrop-blur-md border-2
          <%= @property.available? ? 'bg-emerald-500/90 text-white border-emerald-400' :
             @property.sold? ? 'bg-rose-500/90 text-white border-rose-400' :
             @property.booked? ? 'bg-blue-500/90 text-white border-blue-400' :
             'bg-gray-500/90 text-white border-gray-400' %>">
          <%= @property.status&.humanize || 'Unknown' %>
        </span>
      </div>
      
      <!-- Property Type Badge -->
      <div class="absolute top-6 left-6">
        <span class="px-4 py-2 bg-white/90 backdrop-blur-md text-gray-800 text-sm font-bold rounded-full border border-gray-200">
          <%= @property.property_type&.titleize || 'Apartment' %>
        </span>
      </div>
    </div>
    
    <div class="p-8">
      <div class="flex items-start justify-between mb-6">
        <div class="flex-1">
          <h1 class="text-4xl font-['Playfair_Display'] font-bold text-gray-900 mb-4"><%= @property.title %></h1>
          <div class="flex items-center text-gray-600 mb-4">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-lg"><%= @property.project.name %> • Floor <%= @property.floor %></span>
          </div>
          
          <% if @property.description.present? %>
            <div class="text-gray-700 text-lg leading-relaxed">
              <%= simple_format(@property.description) %>
            </div>
          <% else %>
            <p class="text-gray-500 italic">No description available for this property.</p>
          <% end %>
        </div>

  <!-- Property Details Cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Price Card -->
    <div class="bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-2xl p-6 text-center">
      <div class="w-12 h-12 mx-auto rounded-xl bg-blue-500 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <% if @property.price.present? && @property.price > 0 %>
        <div class="text-2xl font-bold text-blue-700">₹<%= number_with_delimiter(@property.price / 100000) %>L</div>
      <% else %>
        <div class="text-2xl font-bold text-gray-400">Price not set</div>
      <% end %>
      <div class="text-sm text-blue-600 font-medium">Total Price</div>
    </div>

    <!-- Area Card -->
    <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 border border-emerald-200 rounded-2xl p-6 text-center">
      <div class="w-12 h-12 mx-auto rounded-xl bg-emerald-500 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"></path>
        </svg>
      </div>
      <div class="text-2xl font-bold text-emerald-700"><%= @property.area %> sq ft</div>
      <div class="text-sm text-emerald-600 font-medium">Total Area</div>
    </div>

    <!-- Bedrooms Card -->
    <div class="bg-gradient-to-br from-amber-50 to-amber-100 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="w-12 h-12 mx-auto rounded-xl bg-amber-500 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
        </svg>
      </div>
      <div class="text-2xl font-bold text-amber-700"><%= @property.bedrooms %></div>
      <div class="text-sm text-amber-600 font-medium">Bedrooms</div>
    </div>
    <!-- Bathrooms Card -->
    <div class="bg-gradient-to-br from-rose-50 to-rose-100 border border-rose-200 rounded-2xl p-6 text-center">
      <div class="w-12 h-12 mx-auto rounded-xl bg-rose-500 flex items-center justify-center mb-3">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path>
        </svg>
      </div>
      <div class="text-2xl font-bold text-rose-700"><%= @property.bathrooms %></div>
      <div class="text-sm text-rose-600 font-medium">Bathrooms</div>
    </div>
  </div>

  <!-- Additional Property Information -->
  <div class="bg-white rounded-3xl shadow-lg p-8">
    <h2 class="text-2xl font-['Playfair_Display'] font-bold text-gray-900 mb-6">Property Information</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-6">
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <span class="text-gray-600 font-medium">Project Name:</span>
          <span class="text-gray-900 font-semibold"><%= @property.project.name %></span>
        </div>
        
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <span class="text-gray-600 font-medium">Floor Number:</span>
          <span class="text-gray-900 font-semibold">Floor <%= @property.floor %></span>
        </div>
        
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <span class="text-gray-600 font-medium">Property Type:</span>
          <span class="text-gray-900 font-semibold"><%= @property.property_type&.titleize || 'Apartment' %></span>
        </div>
      </div>
      
      <div class="space-y-6">
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <span class="text-gray-600 font-medium">Current Status:</span>
          <span class="px-3 py-1 rounded-full text-sm font-semibold
            <%= @property.available? ? 'bg-emerald-100 text-emerald-800' :
               @property.sold? ? 'bg-rose-100 text-rose-800' :
               @property.booked? ? 'bg-blue-100 text-blue-800' :
               'bg-gray-100 text-gray-800' %>">
            <%= @property.status&.humanize || 'Unknown' %>
          </span>
        </div>
        
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <span class="text-gray-600 font-medium">Price per sq ft:</span>
          <span class="text-gray-900 font-semibold">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %></span>
        </div>
        
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <span class="text-gray-900 font-semibold"><%= @property.created_at.strftime('%B %d, %Y') %></span>
        </div>
      </div>
    </div>
  </div>
</div>
          <span class="text-gray-900 font-semibold"><%= @property.created_at.strftime('%B %d, %Y') %></span>
        </div>
      </div>
    </div>
  </div>
</div>

        <div class="bg-purple-50 rounded-lg p-4">
          <div class="text-2xl font-bold text-purple-600"><%= @property.bathrooms %></div>
          <div class="text-sm text-gray-600">Bathrooms</div>
        </div>
      </div>

      <!-- Property Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-3">Property Details</h3>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-600">Unit Number:</span>
              <span class="font-medium"><%= @property.unit_number %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Floor:</span>
              <span class="font-medium"><%= @property.floor %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Type:</span>
              <span class="font-medium"><%= @property.property_type&.titleize %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Facing:</span>
              <span class="font-medium"><%= @property.facing %></span>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-3">Project Information</h3>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-600">Project:</span>
              <span class="font-medium"><%= link_to @property.project.name, @property.project, class: "text-blue-600 hover:text-blue-700" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Status:</span>
              <span class="font-medium"><%= @property.project.status&.humanize || 'Unknown' %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Information Section -->
      <% if @property.contact_person.present? || @property.contact_phone.present? || @property.contact_email.present? || @property.website.present? || @property.additional_contact.present? %>
        <div class="bg-white rounded-lg shadow-md p-6 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
            <svg class="w-6 h-6 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Contact Information
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if @property.contact_person.present? %>
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 mt-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-500">Contact Person</p>
                  <p class="text-gray-900 font-semibold"><%= @property.contact_person %></p>
                </div>
              </div>
            <% end %>

            <% if @property.contact_phone.present? %>
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 mt-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-500">Phone</p>
                  <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" class="text-blue-600 hover:text-blue-700 font-semibold"><%= @property.contact_phone %></a>
                </div>
              </div>
            <% end %>

            <% if @property.contact_email.present? %>
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 mt-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-500">Email</p>
                  <a href="mailto:<%= @property.contact_email %>" class="text-blue-600 hover:text-blue-700 font-semibold"><%= @property.contact_email %></a>
                </div>
              </div>
            <% end %>

            <% if @property.website.present? %>
              <div class="flex items-start space-x-3">
                <svg class="w-5 h-5 mt-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9-9v18"></path>
                </svg>
                <div>
                  <p class="text-sm font-medium text-gray-500">Website</p>
                  <a href="<%= @property.website %>" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-700 font-semibold"><%= @property.website %></a>
                </div>
              </div>
            <% end %>
          </div>

          <% if @property.additional_contact.present? %>
            <div class="mt-6 pt-6 border-t border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-3">Additional Information</h3>
              <p class="text-gray-700 whitespace-pre-line"><%= @property.additional_contact %></p>
            </div>
          <% end %>

          <!-- Quick Contact Actions -->
          <div class="mt-6 pt-6 border-t border-gray-200">
            <div class="flex flex-wrap gap-3">
              <% if @property.contact_phone.present? %>
                <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  Call Now
                </a>
              <% end %>
              <% if @property.contact_email.present? %>
                <a href="mailto:<%= @property.contact_email %>?subject=Inquiry about <%= @property.title %>" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  Send Email
                </a>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Property Media Section -->
  <% if @property.images.attached? || @property.videos.attached? %>
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Property Media</h2>

      <!-- Images -->
      <% if @property.images.attached? %>
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Images</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <% @property.images.each do |image| %>
              <%= image_tag image, class: "w-full h-48 object-cover rounded-lg border hover:shadow-lg transition-shadow" %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Videos -->
      <% if @property.videos.attached? %>
        <div>
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Videos</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% @property.videos.each do |video| %>
              <div class="relative">
                <video class="w-full h-64 object-cover rounded-lg border" controls>
                  <source src="<%= url_for(video) %>" type="<%= video.content_type %>">
                  Your browser does not support the video tag.
                </video>
                <div class="mt-2 flex justify-between items-center">
                  <p class="text-sm text-gray-600"><%= video.filename %></p>
                  <a href="<%= url_for(video) %>" target="_blank" class="text-amber-700 hover:text-amber-600 text-sm font-medium transition duration-200">
                    Download
                  </a>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Leads Section -->
  <% if @property.leads.any? %>
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Interested Leads (<%= @property.leads.count %>)</h2>
      <div class="space-y-4">
        <% @property.leads.each do |lead| %>
          <div class="border border-gray-200 rounded-lg p-4">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-semibold text-gray-900"><%= lead.name %></h3>
                <p class="text-gray-600"><%= lead.email %> | <%= lead.phone %></p>
                <p class="text-sm text-gray-500 mt-1"><%= lead.message %></p>
              </div>
              <span class="px-2 py-1 text-xs rounded-full
                <%= lead.stage == 'new' ? 'bg-blue-100 text-blue-800' :
                   lead.stage == 'contacted' ? 'bg-yellow-100 text-yellow-800' :
                   lead.stage == 'qualified' ? 'bg-green-100 text-green-800' :
                   'bg-gray-100 text-gray-800' %>">
                <%= lead.stage.humanize %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const carousel = document.getElementById('imageCarousel');
  if (!carousel) return; // Exit if no carousel exists
  
  const images = carousel.querySelectorAll('.carousel-image');
  const dots = carousel.querySelectorAll('.carousel-dot');
  const currentImageSpan = document.getElementById('currentImage');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  
  let currentIndex = 0;
  
  function showImage(index) {
    // Hide all images
    images.forEach(img => img.classList.remove('opacity-100'));
    images.forEach(img => img.classList.add('opacity-0'));
    
    // Show selected image
    images[index].classList.remove('opacity-0');
    images[index].classList.add('opacity-100');
    
    // Update dots
    dots.forEach(dot => dot.classList.remove('bg-white'));
    dots.forEach(dot => dot.classList.add('bg-white/50'));
    dots[index].classList.remove('bg-white/50');
    dots[index].classList.add('bg-white');
    
    // Update counter
    currentImageSpan.textContent = index + 1;
    currentIndex = index;
  }
  
  // Next button
  nextBtn?.addEventListener('click', function() {
    const nextIndex = (currentIndex + 1) % images.length;
    showImage(nextIndex);
  });
  
  // Previous button
  prevBtn?.addEventListener('click', function() {
    const prevIndex = (currentIndex - 1 + images.length) % images.length;
    showImage(prevIndex);
  });
  
  // Dot navigation
  dots.forEach((dot, index) => {
    dot.addEventListener('click', function() {
      showImage(index);
    });
  });
  
  // Auto-slide every 5 seconds (optional)
  setInterval(() => {
    if (images.length > 1) {
      const nextIndex = (currentIndex + 1) % images.length;
      showImage(nextIndex);
    }
  }, 5000);
});
</script>