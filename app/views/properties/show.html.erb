<div class="min-h-screen bg-gradient-to-br from-gray-50 to-blue-50">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Back Navigation -->
    <div class="mb-8 animate-fade-in">
      <%= link_to (@project ? project_path(@project) : properties_path), 
          class: "inline-flex items-center px-6 py-3 bg-white border-2 border-gray-200 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 hover:border-gray-400 transition-all duration-200 shadow-sm hover:shadow-md group" do %>
        <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Properties
      <% end %>
    </div>

  <!-- Property Header with Enhanced Image Gallery -->
  <div class="bg-white rounded-2xl shadow-xl overflow-hidden mb-8 animate-slide-up">
    <!-- Property Images - Enhanced Gallery -->
    <div class="relative h-[400px] md:h-[600px] bg-gradient-to-br from-gray-100 to-gray-200 group">
      <% if @property.images.attached? %>
        <% if @property.images.count > 1 %>
          <!-- Enhanced Image Carousel -->
          <div id="imageCarousel" class="relative w-full h-full">
            <% @property.images.each_with_index do |image, index| %>
              <%= image_tag image, 
                  class: "carousel-image w-full h-full object-cover absolute inset-0 cursor-pointer transition-all duration-500 #{index == 0 ? 'block' : 'hidden'} group-hover:scale-105", 
                  data: { index: index },
                  onclick: "openImageModal(this.src)" %>
            <% end %>
            
            <!-- Enhanced Navigation -->
            <button id="prevBtn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-white/90 backdrop-blur-sm shadow-xl p-3 rounded-full hover:bg-white transition-all duration-200 hover:scale-110 opacity-0 group-hover:opacity-100">
              <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7 7"></path>
              </svg>
            </button>
            <button id="nextBtn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-white/90 backdrop-blur-sm shadow-xl p-3 rounded-full hover:bg-white transition-all duration-200 hover:scale-110 opacity-0 group-hover:opacity-100">
              <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
            
            <!-- Enhanced Image Counter and Controls -->
            <div class="absolute bottom-4 left-4 bg-black/70 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium">
              <span id="currentImage">1</span> / <%= @property.images.count %>
            </div>
            
            <!-- Enhanced Auto-play Control -->
            <div class="absolute bottom-4 right-4 bg-black/70 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium">
              <button id="pausePlayBtn" class="flex items-center gap-2 hover:bg-white/20 transition-colors rounded-full px-2 py-1">
                <span id="pausePlayIcon">⏸️</span>
                <span id="pausePlayText">Pause</span>
              </button>
            </div>
            
            <!-- Image Thumbnails -->
            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <% @property.images.each_with_index do |image, index| %>
                <button onclick="showImage(<%= index %>)" class="w-12 h-12 rounded-lg border-2 border-white/50 overflow-hidden hover:border-white transition-all duration-200 hover:scale-110 <%= index == 0 ? 'ring-2 ring-white' : '' %>">
                  <%= image_tag image, class: "w-full h-full object-cover", size: "48x48" %>
                </button>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="relative w-full h-full group">
            <%= image_tag @property.images.first, class: "w-full h-full object-cover cursor-pointer transition-all duration-500 group-hover:scale-105", onclick: "openImageModal(this.src)" %>
            <div class="absolute inset-0 bg-black/0 opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center justify-center h-full">
          <div class="text-center">
            <div class="w-24 h-24 bg-gray-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <p class="text-gray-500 font-medium">No images available</p>
          </div>
        </div>
      <% end %>
      
      <!-- Enhanced Status Badge -->
      <div class="absolute top-4 right-4">
        <span class="px-4 py-2 rounded-full text-sm font-bold backdrop-blur-sm
          <%= case @property.status
              when 'available' then 'bg-green-500/90 text-white shadow-lg'
              when 'sold' then 'bg-red-500/90 text-white shadow-lg'
              when 'booked' then 'bg-blue-500/90 text-white shadow-lg'
              when 'blocked' then 'bg-yellow-500/90 text-white shadow-lg'
              when 'registered' then 'bg-purple-500/90 text-white shadow-lg'
              else 'bg-gray-500/90 text-white shadow-lg'
              end %>">
          <%= @property.status&.humanize || 'Unknown' %>
        </span>
      </div>
    </div>
    
    <!-- Enhanced Property Details -->
    <div class="p-8 bg-gradient-to-b from-white to-gray-50">
      <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-6 gap-6">
        <div class="flex-1">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight"><%= @property.title %></h1>
          <div class="flex flex-wrap items-center gap-3 text-gray-600">
            <span class="inline-flex items-center px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium">
              <%= @property.project.name %>
            </span>
            <span class="inline-flex items-center px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm font-medium">
              Unit <%= @property.unit_number %>
            </span>
            <% if @property.floor.present? %>
              <span class="inline-flex items-center px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm font-medium">
                Floor <%= @property.floor %>
              </span>
            <% end %>
          </div>
        </div>
        <div class="text-center md:text-right">
          <% if @property.price.present? && @property.price > 0 %>
            <div class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 mb-2"><%= format_price(@property.price) %></div>
            <% if @property.area.to_f > 0 %>
              <div class="text-sm text-gray-500 font-medium">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %> per sq ft</div>
            <% end %>
          <% else %>
            <div class="text-xl text-gray-500 font-medium">Price not set</div>
          <% end %>
        </div>
      </div>
      
      <% if @property.description.present? %>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center">
            <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Description
          </h3>
          <div class="text-gray-700 leading-relaxed">
            <%= simple_format(@property.description) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Property Information Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <!-- Property Overview -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-200 overflow-hidden">

      <!-- Card Header -->
      <div class="bg-gradient-to-r from-blue-700 to-blue-500 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <svg class="w-5 h-5 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
          <h2 class="text-base font-bold text-white tracking-wide">Property Overview</h2>
        </div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold
          <%= case @property.status
              when 'available' then 'bg-green-400 text-white'
              when 'sold'      then 'bg-red-400 text-white'
              when 'booked'    then 'bg-yellow-400 text-gray-900'
              when 'blocked'   then 'bg-orange-400 text-white'
              when 'registered' then 'bg-purple-400 text-white'
              else 'bg-gray-300 text-gray-800'
              end %>">
          <%= @property.status&.upcase || 'UNKNOWN' %>
        </span>
      </div>

      <!-- Key stats tiles -->
      <div class="grid grid-cols-4 border-b border-gray-100">
        <div class="flex flex-col items-center gap-1 py-3.5 px-2 border-r border-gray-100 bg-blue-50/40">
          <div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center">
            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
            </svg>
          </div>
          <span class="text-xl font-extrabold text-gray-900 leading-none"><%= @property.area.presence || '—' %></span>
          <span class="text-[11px] font-medium text-gray-500 uppercase tracking-wide">sq.ft Area</span>
        </div>
        <div class="flex flex-col items-center gap-1 py-3.5 px-2 border-r border-gray-100 bg-green-50/40">
          <div class="w-9 h-9 rounded-full bg-green-100 flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <span class="text-xl font-extrabold text-gray-900 leading-none"><%= @property.bedrooms || '—' %></span>
          <span class="text-[11px] font-medium text-gray-500 uppercase tracking-wide">Bedrooms</span>
        </div>
        <div class="flex flex-col items-center gap-1 py-3.5 px-2 border-r border-gray-100 bg-purple-50/40">
          <div class="w-9 h-9 rounded-full bg-purple-100 flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
            </svg>
          </div>
          <span class="text-xl font-extrabold text-gray-900 leading-none"><%= @property.bathrooms || '—' %></span>
          <span class="text-[11px] font-medium text-gray-500 uppercase tracking-wide">Bathrooms</span>
        </div>
        <div class="flex flex-col items-center gap-1 py-3.5 px-2 bg-orange-50/40">
          <div class="w-9 h-9 rounded-full bg-orange-100 flex items-center justify-center">
            <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <span class="text-xl font-extrabold text-gray-900 leading-none"><%= @property.floor.presence || 'G' %></span>
          <span class="text-[11px] font-medium text-gray-500 uppercase tracking-wide">Floor</span>
        </div>
      </div>

      <!-- Specs: 2-column grid — icon + label left, value right -->
      <div class="grid grid-cols-2 divide-x divide-gray-100">

        <!-- Property Type -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-md bg-blue-50 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16"></path>
              </svg>
            </div>
            <span class="text-xs text-gray-400 truncate">Type</span>
          </div>
          <span class="text-xs font-semibold text-gray-800 ml-2 text-right"><%= @property.property_type.present? ? format_property_type(@property.property_type) : '—' %></span>
        </div>

        <!-- Facing -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-md bg-yellow-50 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07l-.71.71M5.64 18.36l-.71.71m12.02 0l-.71-.71M6.34 5.64l-.71-.71"></path>
              </svg>
            </div>
            <span class="text-xs text-gray-400 truncate">Facing</span>
          </div>
          <span class="text-xs font-semibold text-gray-800 ml-2 text-right"><%= @property.facing&.titleize.presence || '—' %></span>
        </div>

        <!-- Furnishing -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-md bg-green-50 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
              </svg>
            </div>
            <span class="text-xs text-gray-400 truncate">Furnishing</span>
          </div>
          <span class="text-xs font-semibold text-gray-800 ml-2 text-right"><%= @property.furnishing_status&.humanize.presence || '—' %></span>
        </div>

        <!-- Parking -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-md bg-indigo-50 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 17H3a2 2 0 01-2-2V7a2 2 0 012-2h14a2 2 0 012 2v2m-4 8h-4m4 0a4 4 0 004-4V9m0 8a4 4 0 01-4 4m0 0H7"></path>
              </svg>
            </div>
            <span class="text-xs text-gray-400 truncate">Parking</span>
          </div>
          <span class="text-xs font-semibold text-gray-800 ml-2 text-right"><%= @property.parking&.humanize.presence || '—' %></span>
        </div>

        <!-- Possession -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-md bg-teal-50 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <span class="text-xs text-gray-400 truncate">Possession</span>
          </div>
          <span class="text-xs font-semibold text-gray-800 ml-2 text-right"><%= @property.possession_status&.humanize.presence || '—' %></span>
        </div>

        <!-- Unit Number -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <div class="flex items-center gap-2 min-w-0">
            <div class="w-7 h-7 rounded-md bg-pink-50 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
              </svg>
            </div>
            <span class="text-xs text-gray-400 truncate">Unit No.</span>
          </div>
          <span class="text-xs font-semibold text-gray-800 ml-2 text-right"><%= @property.unit_number.presence || '—' %></span>
        </div>

      </div>

      <!-- Listed date footer -->
      <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs text-gray-400">Listed on <%= @property.created_at.strftime('%d %b %Y') %></span>
        <% if @property.age_of_property.present? %>
          <span class="text-xs text-gray-600 font-medium"><%= @property.age_of_property %> yr old property</span>
        <% end %>
      </div>

    </div>

    <!-- Location & Additional Details -->
    <div class="bg-white rounded-2xl shadow-md border border-gray-200 overflow-hidden">

      <!-- Card Header -->
      <div class="bg-gradient-to-r from-orange-600 to-orange-400 px-6 py-4 flex items-center gap-2.5">
        <svg class="w-5 h-5 text-orange-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <h2 class="text-base font-bold text-white tracking-wide">Location & Additional Details</h2>
      </div>

      <!-- Location rows -->
      <div class="divide-y divide-gray-100">
        <div class="flex items-center justify-between px-5 py-3">
          <span class="text-xs text-gray-400 uppercase tracking-wide">City</span>
          <span class="text-sm font-semibold text-gray-800"><%= @property.city.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-5 py-3">
          <span class="text-xs text-gray-400 uppercase tracking-wide">State</span>
          <span class="text-sm font-semibold text-gray-800"><%= @property.state.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-5 py-3">
          <span class="text-xs text-gray-400 uppercase tracking-wide">Pincode</span>
          <span class="text-sm font-semibold text-gray-800"><%= @property.pincode.presence || '—' %></span>
        </div>
        <% if @property.address.present? %>
          <div class="flex items-start justify-between px-5 py-3 gap-4">
            <span class="text-xs text-gray-400 uppercase tracking-wide shrink-0 pt-0.5">Address</span>
            <span class="text-sm font-semibold text-gray-800 text-right"><%= @property.address %></span>
          </div>
        <% end %>
      </div>

      <!-- Section divider -->
      <div class="px-5 py-2 bg-gray-50 border-y border-gray-100">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Additional Specifications</span>
      </div>

      <!-- Specs 2-col grid -->
      <div class="grid grid-cols-2 divide-x divide-gray-100">
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Age</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.age_of_property.present? ? "#{@property.age_of_property} yrs" : '—' %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Water Supply</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.water_supply&.humanize.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Power Backup</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.power_backup&.humanize.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Transaction</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.transaction_type&.humanize.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Ownership</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.ownership_type&.humanize.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Boundary Wall</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.boundary_wall&.humanize.presence || '—' %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
          <span class="text-xs text-gray-400">Flooring</span>
          <span class="text-xs font-semibold text-gray-800"><%= @property.flooring_type&.humanize.presence || '—' %></span>
        </div>
        <% if @property.road_width.present? %>
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
