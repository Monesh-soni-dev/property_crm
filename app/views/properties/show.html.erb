<div class="min-h-screen bg-gradient-to-br from-gray-50 to-blue-50">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Back Navigation -->
    <div class="mb-8 animate-fade-in">
      <%= link_to (@project ? project_properties_path(@project) : properties_path), 
          class: "inline-flex items-center px-6 py-3 bg-white border-2 border-gray-200 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 hover:border-gray-400 transition-all duration-200 shadow-sm hover:shadow-md group" do %>
        <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Properties
      <% end %>
    </div>

  <!-- Property Header with Enhanced Image Gallery -->
  <div class="bg-white rounded-2xl shadow-xl overflow-hidden mb-8 animate-slide-up">
    <!-- Property Images - Enhanced Gallery -->
    <div class="relative h-[400px] md:h-[600px] bg-gradient-to-br from-gray-100 to-gray-200 group">
      <% if @property.images.attached? %>
        <% if @property.images.count > 1 %>
          <!-- Enhanced Image Carousel -->
          <div id="imageCarousel" class="relative w-full h-full">
            <% @property.images.each_with_index do |image, index| %>
              <%= image_tag image, 
                  class: "carousel-image w-full h-full object-cover absolute inset-0 cursor-pointer transition-all duration-500 #{index == 0 ? 'block' : 'hidden'} group-hover:scale-105", 
                  data: { index: index },
                  onclick: "openImageModal(this.src)" %>
            <% end %>
            
            <!-- Enhanced Navigation -->
            <button id="prevBtn" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-white/90 backdrop-blur-sm shadow-xl p-3 rounded-full hover:bg-white transition-all duration-200 hover:scale-110 opacity-0 group-hover:opacity-100">
              <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7 7"></path>
              </svg>
            </button>
            <button id="nextBtn" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-white/90 backdrop-blur-sm shadow-xl p-3 rounded-full hover:bg-white transition-all duration-200 hover:scale-110 opacity-0 group-hover:opacity-100">
              <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
            
            <!-- Enhanced Image Counter and Controls -->
            <div class="absolute bottom-4 left-4 bg-black/70 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium">
              <span id="currentImage">1</span> / <%= @property.images.count %>
            </div>
            
            <!-- Enhanced Auto-play Control -->
            <div class="absolute bottom-4 right-4 bg-black/70 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium">
              <button id="pausePlayBtn" class="flex items-center gap-2 hover:bg-white/20 transition-colors rounded-full px-2 py-1">
                <span id="pausePlayIcon">⏸️</span>
                <span id="pausePlayText">Pause</span>
              </button>
            </div>
            
            <!-- Image Thumbnails -->
            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <% @property.images.each_with_index do |image, index| %>
                <button onclick="showImage(<%= index %>)" class="w-12 h-12 rounded-lg border-2 border-white/50 overflow-hidden hover:border-white transition-all duration-200 hover:scale-110 <%= index == 0 ? 'ring-2 ring-white' : '' %>">
                  <%= image_tag image, class: "w-full h-full object-cover", size: "48x48" %>
                </button>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="relative w-full h-full group">
            <%= image_tag @property.images.first, class: "w-full h-full object-cover cursor-pointer transition-all duration-500 group-hover:scale-105", onclick: "openImageModal(this.src)" %>
            <div class="absolute inset-0 bg-black/0 opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center justify-center h-full">
          <div class="text-center">
            <div class="w-24 h-24 bg-gray-200 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <p class="text-gray-500 font-medium">No images available</p>
          </div>
        </div>
      <% end %>
      
      <!-- Enhanced Status Badge -->
      <div class="absolute top-4 right-4">
        <span class="px-4 py-2 rounded-full text-sm font-bold backdrop-blur-sm
          <%= case @property.status
              when 'available' then 'bg-green-500/90 text-white shadow-lg'
              when 'sold' then 'bg-red-500/90 text-white shadow-lg'
              when 'booked' then 'bg-blue-500/90 text-white shadow-lg'
              when 'blocked' then 'bg-yellow-500/90 text-white shadow-lg'
              when 'registered' then 'bg-purple-500/90 text-white shadow-lg'
              else 'bg-gray-500/90 text-white shadow-lg'
              end %>">
          <%= @property.status&.humanize || 'Unknown' %>
        </span>
      </div>
    </div>
    
    <!-- Enhanced Property Details -->
    <div class="p-8 bg-gradient-to-b from-white to-gray-50">
      <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-6 gap-6">
        <div class="flex-1">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight"><%= @property.title %></h1>
          <div class="flex flex-wrap items-center gap-3 text-gray-600">
            <span class="inline-flex items-center px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium">
              <%= @property.project.name %>
            </span>
            <span class="inline-flex items-center px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm font-medium">
              Unit <%= @property.unit_number %>
            </span>
            <% if @property.floor.present? %>
              <span class="inline-flex items-center px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm font-medium">
                Floor <%= @property.floor %>
              </span>
            <% end %>
          </div>
        </div>
        <div class="text-center md:text-right">
          <% if @property.price.present? && @property.price > 0 %>
            <div class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 mb-2">₹<%= number_with_delimiter(@property.price) %></div>
            <div class="text-sm text-gray-500 font-medium">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %> per sq ft</div>
          <% else %>
            <div class="text-xl text-gray-500 font-medium">Price not set</div>
          <% end %>
        </div>
      </div>
      
      <% if @property.description.present? %>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <h3 class="text-lg font-semibold text-gray-900 mb-3 flex items-center">
            <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Description
          </h3>
          <div class="text-gray-700 leading-relaxed">
            <%= simple_format(@property.description) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Property Information Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    
    <!-- Property Overview -->
    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl shadow-lg border border-blue-100 p-8 animate-slide-up">
      <div class="flex items-center mb-6">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center mr-3">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m1 4v-4m1 4h-1m-1 4h-1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-800">Property Overview</h2>
          <p class="text-sm text-gray-600">Key specifications and features</p>
        </div>
      </div>
      
      <div class="space-y-6">
        <!-- Key Metrics -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="group text-center p-6 bg-gradient-to-br from-blue-100 to-blue-50 rounded-2xl border border-blue-200 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="text-3xl font-bold text-blue-700 group-hover:text-blue-800 transition-colors"><%= @property.area %></div>
            <div class="text-sm font-medium text-blue-600 mt-1">Total Area</div>
            <div class="text-xs text-gray-500">square feet</div>
          </div>
          <div class="group text-center p-6 bg-gradient-to-br from-green-100 to-green-50 rounded-2xl border border-green-200 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="text-3xl font-bold text-green-700 group-hover:text-green-800 transition-colors"><%= @property.bedrooms || 0 %></div>
            <div class="text-sm font-medium text-green-600 mt-1">Bedrooms</div>
            <div class="text-xs text-gray-500">rooms</div>
          </div>
          <div class="group text-center p-6 bg-gradient-to-br from-purple-100 to-purple-50 rounded-2xl border border-purple-200 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="text-3xl font-bold text-purple-700 group-hover:text-purple-800 transition-colors"><%= @property.bathrooms || 0 %></div>
            <div class="text-sm font-medium text-purple-600 mt-1">Bathrooms</div>
            <div class="text-xs text-gray-500">rooms</div>
          </div>
          <div class="group text-center p-6 bg-gradient-to-br from-orange-100 to-orange-50 rounded-2xl border border-orange-200 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="text-3xl font-bold text-orange-700 group-hover:text-orange-800 transition-colors"><%= @property.floor || 'G' %></div>
            <div class="text-sm font-medium text-orange-600 mt-1">Floor</div>
            <div class="text-xs text-gray-500">level</div>
          </div>
        </div>
        
        <!-- Project Information -->
        <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl p-6 border border-purple-100">
          <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m1 4v-4m1 4h-1m-1 4h-1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            Project Information
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex justify-between items-center p-3 bg-purple-50 rounded-xl hover:bg-purple-100 transition-colors">
              <span class="text-gray-600 font-medium">Project Name</span>
              <span class="font-bold text-purple-900"><%= @property.project.name %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-purple-50 rounded-xl hover:bg-purple-100 transition-colors">
              <span class="text-gray-600 font-medium">Location</span>
              <span class="font-bold text-purple-900"><%= @property.project.location || 'Not specified' %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-purple-50 rounded-xl hover:bg-purple-100 transition-colors">
              <span class="text-gray-600 font-medium">Project Status</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-purple-500 text-white shadow-lg">
                <%= @property.project.status&.humanize || 'Unknown' %>
              </span>
            </div>
            <div class="flex justify-between items-center p-3 bg-purple-50 rounded-xl hover:bg-purple-100 transition-colors">
              <span class="text-gray-600 font-medium">Listed Date</span>
              <span class="font-bold text-purple-900"><%= @property.created_at.strftime('%B %d, %Y') %></span>
            </div>
          </div>
        </div>
        
        <!-- Additional Details -->
        <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-6 border border-gray-100 mt-6">
          <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Additional Information
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
              <span class="text-gray-600 font-medium">Property Type</span>
              <span class="font-bold text-gray-900"><%= @property.property_type&.titleize || 'Not specified' %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
              <span class="text-gray-600 font-medium">Facing</span>
              <span class="font-bold text-gray-900"><%= @property.facing&.titleize || 'Not specified' %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
              <span class="text-gray-600 font-medium">Unit Number</span>
              <span class="font-bold text-gray-900"><%= @property.unit_number %></span>
            </div>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
              <span class="text-gray-600 font-medium">Status</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold
                <%= case @property.status
                    when 'available' then 'bg-green-100 text-green-800'
                    when 'sold' then 'bg-red-100 text-red-800'
                    when 'booked' then 'bg-blue-100 text-blue-800'
                    when 'blocked' then 'bg-yellow-100 text-yellow-800'
                    when 'registered' then 'bg-purple-100 text-purple-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= @property.status&.humanize || 'Unknown' %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Location & Additional Details -->
    <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-2xl shadow-lg border border-orange-100 p-8 mb-6 animate-slide-up">
      <div class="flex items-center mb-6">
        <div class="w-8 h-8 bg-orange-600 rounded-lg flex items-center justify-center mr-3">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-800">Location & Additional Details</h2>
          <p class="text-sm text-gray-600">Complete property information and amenities</p>
        </div>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Location Information -->
        <div class="space-y-6">
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-orange-100">
            <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              </svg>
              Location
            </h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">City</span>
                <span class="font-bold text-gray-900"><%= @property.city || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">State</span>
                <span class="font-bold text-gray-900"><%= @property.state || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Pincode</span>
                <span class="font-bold text-gray-900"><%= @property.pincode || 'Not specified' %></span>
              </div>
              <% if @property.address.present? %>
                <div class="p-3 bg-orange-50 rounded-xl">
                  <div class="text-gray-600 font-medium mb-2">Address</div>
                  <div class="text-gray-900 font-medium"><%= @property.address %></div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- Property Features -->
        <div class="space-y-6">
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-orange-100">
            <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 14h7v7m7-7h4m-4 0v4m0 4v-4m0-4h4m-4 0H3"></path>
              </svg>
              Features & Amenities
            </h3>
            <% if @property.features.present? %>
              <div class="text-gray-800 leading-relaxed bg-orange-50 rounded-xl p-4">
                <%= simple_format(@property.features) %>
              </div>
            <% else %>
              <div class="text-gray-500 italic bg-orange-50 rounded-xl p-4">
                No features specified
              </div>
            <% end %>
          </div>
          
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-orange-100">
            <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3l3 3m-9 3h6m-6 0h6m-6 0h.01M9 16h.01"></path>
              </svg>
              Property Specifications
            </h3>
            <div class="grid grid-cols-1 gap-3">
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Age</span>
                <span class="font-bold text-gray-900"><%= @property.age_of_property ? "#{@property.age_of_property} years" : 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Possession</span>
                <span class="font-bold text-gray-900"><%= @property.possession_status&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Parking</span>
                <span class="font-bold text-gray-900"><%= @property.parking&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Furnishing</span>
                <span class="font-bold text-gray-900"><%= @property.furnishing_status&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Water Supply</span>
                <span class="font-bold text-gray-900"><%= @property.water_supply&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Power Backup</span>
                <span class="font-bold text-gray-900"><%= @property.power_backup&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Transaction</span>
                <span class="font-bold text-gray-900"><%= @property.transaction_type&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Ownership</span>
                <span class="font-bold text-gray-900"><%= @property.ownership_type&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Boundary Wall</span>
                <span class="font-bold text-gray-900"><%= @property.boundary_wall&.humanize || 'Not specified' %></span>
              </div>
              <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                <span class="text-gray-600 font-medium">Flooring</span>
                <span class="font-bold text-gray-900"><%= @property.flooring_type&.humanize || 'Not specified' %></span>
              </div>
              <% if @property.road_width.present? %>
                <div class="flex justify-between items-center p-3 bg-orange-50 rounded-xl hover:bg-orange-100 transition-colors">
                  <span class="text-gray-600 font-medium">Road Width</span>
                  <span class="font-bold text-gray-900"><%= @property.road_width %></span>
                </div>
              <% end %>
            </div>
          </div>
          
          <% if @property.location_advantage.present? %>
            <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-orange-100">
              <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
                <svg class="w-5 h-5 mr-2 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Location Advantages
              </h3>
              <div class="text-gray-800 leading-relaxed bg-orange-50 rounded-xl p-4">
                <%= simple_format(@property.location_advantage) %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Project & Contact Information -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <!-- Project Information -->
      <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl shadow-lg border border-purple-100 p-8 animate-slide-up">
        <div class="flex items-center mb-6">
          <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center mr-3">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m1 4v-4m1 4h-1m-1 4h-1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Project Information</h2>
            <p class="text-sm text-gray-600">Details about the project</p>
          </div>
        </div>
        <div class="space-y-4">
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-purple-100 hover:bg-white transition-colors">
            <div class="flex justify-between items-center mb-2">
              <span class="text-gray-600 font-medium">Project Name</span>
              <%= link_to project_path(@property.project), 
                  class: "text-purple-700 hover:text-purple-900 font-bold text-lg hover:underline transition-colors" do %>
                <%= @property.project.name %>
                <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              <% end %>
            </div>
          </div>
          
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-purple-100">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 font-medium">Location</span>
              <span class="font-bold text-gray-900"><%= @property.project.location || 'Not specified' %></span>
            </div>
          </div>
          
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-purple-100">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 font-medium">Status</span>
              <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold
                <%= case @property.status
                    when 'available' then 'bg-green-500 text-white shadow-lg'
                    when 'sold' then 'bg-red-500 text-white shadow-lg'
                    when 'booked' then 'bg-blue-500 text-white shadow-lg'
                    when 'blocked' then 'bg-yellow-500 text-white shadow-lg'
                    when 'registered' then 'bg-purple-500 text-white shadow-lg'
                    else 'bg-gray-500 text-white shadow-lg'
                    end %>">
                <%= @property.status&.humanize || 'Unknown' %>
              </span>
            </div>
          </div>
          
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-purple-100">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 font-medium">Listed Date</span>
              <span class="font-bold text-gray-900"><%= @property.created_at.strftime('%B %d, %Y') %></span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Contact Information -->
      <div class="bg-gradient-to-br from-teal-50 to-cyan-50 rounded-2xl shadow-lg border border-teal-100 p-8 animate-slide-up">
        <div class="flex items-center mb-6">
          <div class="w-8 h-8 bg-teal-600 rounded-lg flex items-center justify-center mr-3">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Contact Information</h2>
            <p class="text-sm text-gray-600">Get in touch for inquiries</p>
          </div>
        </div>
        <% if @property.contact_person.present? || @property.contact_phone.present? || @property.contact_email.present? || @property.website.present? %>
          <div class="space-y-4">
            <% if @property.contact_person.present? %>
              <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-teal-100 hover:bg-white transition-colors">
                <div class="flex items-center mb-2">
                  <svg class="w-5 h-5 mr-2 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 007-7 7 0 00-7 7z"></path>
                  </svg>
                  <span class="text-gray-600 font-medium">Contact Person</span>
                </div>
                <div class="font-bold text-gray-900 text-lg"><%= @property.contact_person %></div>
              </div>
            <% end %>

            <% if @property.contact_phone.present? %>
              <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-teal-100 hover:bg-white transition-colors">
                <div class="flex items-center mb-2">
                  <svg class="w-5 h-5 mr-2 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3a2 2 0 012 2v3a2 2 0 01-2 2h.5a.5.5 0 000 1H8v6a2 2 0 002 2h9.5a.5.5 0 000-1H18a2 2 0 002-2V7z"></path>
                  </svg>
                  <span class="text-gray-600 font-medium">Phone</span>
                </div>
                <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" 
                   class="text-teal-700 hover:text-teal-900 font-bold text-lg hover:underline transition-colors">
                  <%= @property.contact_phone %>
                </a>
              </div>
            <% end %>

            <% if @property.contact_email.present? %>
              <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-teal-100 hover:bg-white transition-colors">
                <div class="flex items-center mb-2">
                  <svg class="w-5 h-5 mr-2 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <span class="text-gray-600 font-medium">Email</span>
                </div>
                <a href="mailto:<%= @property.contact_email %>" 
                   class="text-teal-700 hover:text-teal-900 font-bold text-lg hover:underline transition-colors">
                  <%= @property.contact_email %>
                </a>
              </div>
            <% end %>

            <% if @property.website.present? %>
              <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-teal-100 hover:bg-white transition-colors">
                <div class="flex items-center mb-2">
                  <svg class="w-5 h-5 mr-2 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9 0 019 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-600 font-medium">Website</span>
                </div>
                <a href="<%= @property.website %>" target="_blank" 
                   class="text-teal-700 hover:text-teal-900 font-bold text-lg hover:underline transition-colors inline-flex items-center">
                  <%= @property.website %>
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </a>
              </div>
            <% end %>

            <% if @property.additional_contact.present? %>
              <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-teal-100">
                <div class="flex items-center mb-3">
                  <svg class="w-5 h-5 mr-2 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-gray-600 font-medium">Additional Information</span>
                </div>
                <div class="text-gray-800 leading-relaxed"><%= simple_format(@property.additional_contact) %></div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-8 border border-teal-100 text-center">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <p class="text-gray-500 font-medium">No contact information available.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Interested in Our Properties Section -->
  <% if @property.status == 'available' && (!user_signed_in? || @property.project.user_id != current_user&.id) %>
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-8 mb-6">
      <div class="text-center mb-6">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">💡 Interested in Our Properties?</h2>
        <p class="text-gray-700">Connect with our property experts to schedule a visit or get more information about this amazing property!</p>
      </div>

      <% if user_signed_in? %>
        <!-- Authenticated User - Show Interest Form -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Interest Form -->
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">📋 Express Your Interest</h3>
            
            <%= form_with model: [@property.project, Lead.new], local: true, class: "space-y-4" do |form| %>
              <%= form.hidden_field :property_id, value: @property.id %>
              
              <div>
                <%= form.text_field :customer_name, placeholder: "Your Full Name", value: current_user.first_name&.to_s + " " + current_user.last_name&.to_s, required: true,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.email_field :customer_email, placeholder: "Your Email Address", value: current_user.email, required: true,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.telephone_field :customer_phone, placeholder: "Your Phone Number", required: true,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.text_area :notes, placeholder: "Any specific questions or requirements?", rows: 3,
                    class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
              </div>
              
              <div>
                <%= form.submit "🚀 I'm Interested - Contact Me!", 
                    class: "w-full bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-all transform hover:scale-105 shadow-lg" %>
              </div>
            <% end %>
          </div>

          <!-- Direct Contact Options -->
          <div class="space-y-6">
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">📞 Direct Contact</h3>
              <div class="space-y-4">
                <% if @property.contact_phone.present? %>
                  <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" 
                     class="flex items-center gap-3 p-3 bg-green-50 rounded-lg hover:bg-green-100 transition-colors group">
                    <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white">
                      📱
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-green-700">Call Now</div>
                      <div class="text-gray-600"><%= @property.contact_phone %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.contact_email.present? %>
                  <a href="mailto:<%= @property.contact_email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>" 
                     class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors group">
                    <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center text-white">
                      ✉️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-blue-700">Send Email</div>
                      <div class="text-gray-600"><%= @property.contact_email %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.project.user&.email.present? %>
                  <a href="mailto:<%= @property.project.user.email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>" 
                     class="flex items-center gap-3 p-3 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors group">
                    <div class="w-10 h-10 bg-purple-500 rounded-full flex items-center justify-center text-white">
                      🏗️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-purple-700">Contact Builder</div>
                      <div class="text-gray-600"><%= @property.project.user&.first_name&.to_s + " " + @property.project.user&.last_name&.to_s || @property.project.user&.email %></div>
                    </div>
                  </a>
                <% end %>
              </div>
            </div>

            <!-- Quick Actions -->
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">🎯 Quick Actions</h3>
              <div class="space-y-3">
                <% if @property.website.present? %>
                  <a href="<%= @property.website %>" target="_blank" 
                     class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                    <span class="font-medium text-gray-900">🌐 Visit Project Website</span>
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                <% end %>
                
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <span class="font-medium text-gray-900">💰 Price: ₹<%= number_with_delimiter(@property.price) %></span>
                  <span class="text-sm text-gray-500">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %>/sq ft</span>
                </div>
                
                <div class="p-3 bg-yellow-50 rounded-lg border border-yellow-200">
                  <p class="text-sm text-yellow-800 font-medium">
                    ⚡ This property is available now! Contact us quickly to schedule a visit.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Guest User - Interest Form -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <!-- Interest Form -->
          <div class="bg-white rounded-lg p-6 border border-gray-200">
            <%= render 'interests/form' %>
          </div>

          <!-- Guest Contact Options -->
          <div class="space-y-6">
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">📞 Contact Options</h3>
              <p class="text-sm text-gray-600 mb-4">You can also contact us directly without creating an account:</p>
              
              <div class="space-y-4">
                <% if @property.contact_phone.present? %>
                  <a href="tel:<%= @property.contact_phone.gsub(/[^+0-9]/, '') %>" 
                     class="flex items-center gap-3 p-3 bg-green-50 rounded-lg hover:bg-green-100 transition-colors group">
                    <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white">
                      📱
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-green-700">Call Now</div>
                      <div class="text-gray-600"><%= @property.contact_phone %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.contact_email.present? %>
                  <a href="mailto:<%= @property.contact_email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>&body=Hi,%0D%0A%0D%0AI am interested in the property:<%= @property.title %> in <%= @property.project.name %>.%0D%0A%0D%0ACould you please provide more details?%0D%0A%0D%0AThank you!" 
                     class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors group">
                    <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center text-white">
                      ✉️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-blue-700">Send Email</div>
                      <div class="text-gray-600"><%= @property.contact_email %></div>
                    </div>
                  </a>
                <% end %>

                <% if @property.project.user&.email.present? %>
                  <a href="mailto:<%= @property.project.user.email %>?subject=Interest in <%= @property.title %>%20-%20<%= @property.project.name %>&body=Hi,%0D%0A%0D%0AI am interested in your property:<%= @property.title %> in <%= @property.project.name %>.%0D%0A%0D%0ACould you please provide more details?%0D%0A%0D%0AThank you!" 
                     class="flex items-center gap-3 p-3 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors group">
                    <div class="w-10 h-10 bg-purple-500 rounded-full flex items-center justify-center text-white">
                      🏗️
                    </div>
                    <div>
                      <div class="font-semibold text-gray-900 group-hover:text-purple-700">Contact Builder</div>
                      <div class="text-gray-600"><%= @property.project.user&.first_name&.to_s + " " + @property.project.user&.last_name&.to_s || @property.project.user&.email %></div>
                    </div>
                  </a>
                <% end %>
              </div>
            </div>

            <!-- Property Info -->
            <div class="bg-white rounded-lg p-6 border border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">🏠 Property Details</h3>
              
              <div class="space-y-3">
                <% if @property.website.present? %>
                  <a href="<%= @property.website %>" target="_blank" 
                     class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                    <span class="font-medium text-gray-900">🌐 Visit Project Website</span>
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </a>
                <% end %>
                
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <span class="font-medium text-gray-900">💰 Price: ₹<%= number_with_delimiter(@property.price) %></span>
                  <span class="text-sm text-gray-500">₹<%= number_with_delimiter((@property.price.to_f / @property.area.to_f).round) %>/sq ft</span>
                </div>
                
                <div class="p-3 bg-yellow-50 rounded-lg border border-yellow-200">
                  <p class="text-sm text-yellow-800 font-medium">
                    ⚡ This property is available now! Sign up to get priority access.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Action Buttons -->
  <% if user_signed_in? && (@property.project.user == current_user || current_user.admin?) %>
    <div class="bg-gradient-to-r from-gray-50 to-slate-50 rounded-2xl shadow-lg border border-gray-200 p-8 animate-slide-up">
      <div class="flex flex-col sm:flex-row gap-4">
        <%= link_to edit_property_path(@property), 
            class: "group inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" do %>
          <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-4h-4m-4 0v6m0 4h4"></path>
          </svg>
          Edit Property
        <% end %>
        <%= link_to @property, method: :delete, 
            confirm: 'Are you sure you want to delete this property? This action cannot be undone.', 
            class: "group inline-flex items-center px-6 py-3 bg-gradient-to-r from-red-600 to-pink-600 hover:from-red-700 hover:to-pink-700 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105" do %>
          <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m0 4h4"></path>
          </svg>
          Delete Property
        <% end %>
      </div>
    </div>
  <% end %>
  
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const carousel = document.getElementById('imageCarousel');
  if (!carousel) return;

  const images = carousel.querySelectorAll('.carousel-image');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const currentImageSpan = document.getElementById('currentImage');
  const pausePlayBtn = document.getElementById('pausePlayBtn');
  const pausePlayIcon = document.getElementById('pausePlayIcon');
  const pausePlayText = document.getElementById('pausePlayText');
  
  let currentIndex = 0;
  let autoPlayInterval;
  let isPlaying = true;

  function showImage(index) {
    images.forEach((img, i) => {
      img.style.display = i === index ? 'block' : 'none';
    });
    if (currentImageSpan) {
      currentImageSpan.textContent = index + 1;
    }
  }

  function nextImage() {
    currentIndex = currentIndex < images.length - 1 ? currentIndex + 1 : 0;
    showImage(currentIndex);
  }

  function prevImage() {
    currentIndex = currentIndex > 0 ? currentIndex - 1 : images.length - 1;
    showImage(currentIndex);
  }

  function startAutoPlay() {
    if (images.length > 1) {
      autoPlayInterval = setInterval(nextImage, 4000); // Change every 4 seconds
      isPlaying = true;
      if (pausePlayIcon) pausePlayIcon.textContent = '⏸️';
      if (pausePlayText) pausePlayText.textContent = 'Pause';
    }
  }

  function pauseAutoPlay() {
    clearInterval(autoPlayInterval);
    isPlaying = false;
    if (pausePlayIcon) pausePlayIcon.textContent = '▶️';
    if (pausePlayText) pausePlayText.textContent = 'Play';
  }

  function toggleAutoPlay() {
    if (isPlaying) {
      pauseAutoPlay();
    } else {
      startAutoPlay();
    }
  }

  // Event listeners
  prevBtn?.addEventListener('click', function() {
    pauseAutoPlay();
    prevImage();
  });

  nextBtn?.addEventListener('click', function() {
    pauseAutoPlay();
    nextImage();
  });

  pausePlayBtn?.addEventListener('click', function() {
    toggleAutoPlay();
  });

  // Initialize carousel
  showImage(0);
  startAutoPlay();

  // Pause auto-play when mouse hovers over carousel
  carousel?.addEventListener('mouseenter', function() {
    if (isPlaying) {
      clearInterval(autoPlayInterval);
    }
  });

  carousel?.addEventListener('mouseleave', function() {
    if (isPlaying) {
      startAutoPlay();
    }
  });
});

// Image Modal Functions
function openImageModal(imageSrc) {
  const modal = document.getElementById('imageModal');
  const modalImage = document.getElementById('modalImage');
  
  if (modal && modalImage) {
    modalImage.src = imageSrc;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden'; // Prevent background scroll
  }
}

function closeImageModal() {
  const modal = document.getElementById('imageModal');
  
  if (modal) {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = 'auto'; // Restore scroll
  }
}

// Close modal when clicking outside of image
function modalOverlayClick(event) {
  if (event.target.id === 'imageModal') {
    closeImageModal();
  }
}

// Keyboard navigation for modal
document.addEventListener('keydown', function(event) {
  const modal = document.getElementById('imageModal');
  
  if (modal && !modal.classList.contains('hidden')) {
    if (event.key === 'Escape') {
      closeImageModal();
    }
  }
});
</script>

