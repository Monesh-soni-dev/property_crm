        <div class="w-10 h-10 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold">PP</div>
        <div>
          <h3 class="text-blue-400 font-bold text-lg">PlotPlans</h3>
          <p class="text-blue-300 text-sm">Construction workspace</p>
        </div>
      </div>
