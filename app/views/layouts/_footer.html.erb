<footer class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 border-t border-slate-700 text-slate-300 mt-20">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Brand Section -->
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-600 to-blue-700 flex items-center justify-center text-white shadow-xl">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
        </div>
        <div>
          <h3 class="text-blue-400 font-bold text-2xl font-['Playfair_Display']">PlotPlans</h3>
          <p class="text-blue-300 text-sm font-medium">Property Management Excellence</p>
        </div>
      </div>
      <p class="text-slate-400 text-base max-w-lg mx-auto leading-relaxed">
        Transforming property management with innovative solutions, seamless workflows, and exceptional user experiences.
      </p>
    </div>

    <!-- Navigation Links Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
          </svg>
          Quick Links
        </h4>
        <div class="space-y-3">
          <%= link_to root_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Dashboard
          <% end %>
          <%= link_to properties_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Properties
          <% end %>
          <%= link_to projects_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Projects
          <% end %>
        </div>
      </div>
      
      <!-- Features -->
      <div>
        <h4 class="text-white font-semibold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          Features
        </h4>
        <div class="space-y-3">
          <span class="block text-slate-400">Property Listing</span>
          <span class="block text-slate-400">Lead Management</span>
          <span class="block text-slate-400">Project Tracking</span>
        </div>
      </div>
      
      <!-- Support -->
      <div>
        <h4 class="text-white font-semibold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          Support
        </h4>
        <div class="space-y-3">
          <%= link_to help_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Help Center
          <% end %>
          <%= link_to contact_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Contact Us
          <% end %>
          <%= link_to documentation_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Documentation
          <% end %>
        </div>
      </div>
      
      <!-- Company -->
      <div>
        <h4 class="text-white font-semibold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
          Company
        </h4>
        <div class="space-y-3">
          <%= link_to about_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            About Us
          <% end %>
          <%= link_to privacy_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Privacy Policy
          <% end %>
          <%= link_to terms_path, class: "block text-slate-400 hover:text-blue-400 transition-colors duration-200 hover:translate-x-1 transform" do %>
            Terms of Service
          <% end %>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-slate-700 pt-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-6 text-sm text-slate-400">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
            </svg>
            Built with Rails & Tailwind CSS
          </span>
          <span class="hidden md:inline text-slate-600">•</span>
          <span>Version 2.1.0</span>
        </div>
        
        <div class="flex items-center gap-6">
          <div class="text-sm text-slate-500">
            © <%= Date.today.year %> PlotPlans. All rights reserved.
          </div>
          
          <!-- Social Links -->
          <div class="flex items-center gap-3">
            <a href="#" class="w-8 h-8 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-all duration-200 hover:scale-110">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
              </svg>
            </a>
            <a href="#" class="w-8 h-8 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-all duration-200 hover:scale-110">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/>
              </svg>
            </a>
            <a href="#" class="w-8 h-8 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-all duration-200 hover:scale-110">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
