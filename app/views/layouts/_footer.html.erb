          <%= link_to "Home", root_path, class: "text-gray-400 hover:text-blue-400 transition duration-200 text-sm" %>
          <%= link_to "Projects", projects_path, class: "text-gray-400 hover:text-blue-400 transition duration-200 text-sm" %>
          <%= link_to "Properties", properties_path, class: "text-gray-400 hover:text-blue-400 transition duration-200 text-sm" %>
          <%= link_to "Contact", "#", class: "text-gray-400 hover:text-blue-400 transition duration-200 text-sm" %>
        </div>

        <!-- Company Links -->
        <div class="flex items-center gap-6">
          <span class="text-white font-semibold text-sm">Company:</span>
          <a href="#" class="text-gray-400 hover:text-blue-400 transition duration-200 text-sm">About Us</a>
          <a href="#" class="text-gray-400 hover:text-blue-400 transition duration-200 text-sm">Privacy</a>
          <a href="#" class="text-gray-400 hover:text-blue-400 transition duration-200 text-sm">Terms</a>
          <a href="#" class="text-gray-400 hover:text-blue-400 transition duration-200 text-sm">Support</a>
        </div>
