<footer class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 border-t border-gray-700 text-gray-300 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <!-- Brand Section -->
    <div class="text-center mb-6">
