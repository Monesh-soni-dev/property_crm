<header class="bg-gradient-to-r from-[#1a2e4a] via-[#2a4a72] to-[#1a2e4a] text-white flex items-center justify-between px-4 md:px-8 h-16 flex-shrink-0 shadow-lg border-b-4 border-[#e8834a] relative">
  
  <!-- Background decorative elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-[#e8834a]/5 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-[#f5a870]/5 rounded-full blur-3xl -z-10"></div>

  <%# Brand with animation -->
  <%= link_to root_path, class: "flex items-center gap-3 flex-shrink-0 group" do %>
    <div class="w-10 h-10 bg-gradient-to-br from-[#e8834a] to-[#f5a870] rounded-xl flex items-center justify-center flex-shrink-0 shadow-xl group-hover:shadow-2xl group-hover:scale-110 transition-all duration-300">
      <svg class="w-5 h-5 fill-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"></path>
      </svg>
    </div>
    <span class="font-['Playfair_Display'] text-2xl tracking-wider hidden sm:inline font-bold bg-gradient-to-r from-white to-[#f5a870] bg-clip-text text-transparent group-hover:from-[#f5a870] group-hover:to-white transition-all duration-300">
      Build<span class="text-[#f5a870]">Track</span>
    </span>
  <% end %>

  <%# Main nav with enhanced styling -->
  <nav class="flex gap-1 md:gap-3 flex-1 justify-center mx-4">
    <%= nav_link "Dashboard",    root_path %>
    <span class="hidden lg:inline"><%= nav_link "Properties",   properties_path %></span>
  </nav>

  <%# Right side actions -->
  <div class="flex items-center gap-2 md:gap-4">
    <!-- Notifications button with pulse animation -->
    <button class="relative w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-all duration-300 group" title="Notifications">
      <svg class="w-5 h-5 fill-white/80 group-hover:fill-white transition" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.93 6 11v5l-2 2v1h16v-1l-2-2z"></path>
      </svg>
      <span class="absolute top-2 right-2 w-2.5 h-2.5 bg-[#e8834a] rounded-full border-2 border-[#1a2e4a] animate-pulse"></span>
    </button>

    <% if user_signed_in? %>
      <!-- User profile dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-2.5 bg-white/10 hover:bg-white/15 rounded-full px-3 py-2 transition-all duration-300 group">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#e8834a] to-[#f5a870] flex items-center justify-center text-xs font-bold text-white shadow-lg">
            <%= current_user&.initials %>
          </div>
          <span class="text-sm text-white/90 hidden xs:inline font-medium"><%= current_user&.full_name %></span>
          <svg class="w-4 h-4 fill-white/70 group-hover:fill-white transition transform group-hover:-rotate-180 duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M7 10l5 5 5-5z"></path>
          </svg>
        </button>

        <%# Animated dropdown menu -->
        <div class="absolute right-0 mt-3 w-56 bg-white/95 backdrop-blur-md text-gray-900 rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-50 border border-white/20">
          <!-- Header section -->
          <div class="px-4 py-4 border-b border-gray-200">
            <p class="font-bold text-gray-900"><%= current_user&.full_name %></p>
            <p class="text-xs text-gray-500 mt-1"><%= current_user&.email %></p>
            <div class="mt-2 px-2 py-1 bg-blue-50 rounded-md">
              <p class="text-xs font-semibold text-blue-700 capitalize"><%= current_user&.role %></p>
            </div>
          </div>

          <!-- Menu items -->
          <div class="py-3">
            <%= link_to "👤 Profile", edit_user_registration_path, class: "block px-4 py-2.5 text-sm hover:bg-blue-50 text-gray-700 hover:text-blue-700 transition font-medium" %>
            <%= link_to "⚙️ Settings", "#", class: "block px-4 py-2.5 text-sm hover:bg-blue-50 text-gray-700 hover:text-blue-700 transition font-medium" %>
            <hr class="my-2 border-gray-200">
            <%= link_to "🚪 Sign Out", destroy_user_session_path, method: :delete, class: "block px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 hover:text-red-700 transition font-medium" %>
          </div>
        </div>
      </div>
    <% else %>
      <!-- Auth buttons for guests -->
      <div class="flex items-center gap-2 md:gap-3">
        <%= link_to "Sign In", new_user_session_path, class: "px-4 py-2 text-sm font-medium text-white hover:text-[#f5a870] transition duration-300" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "px-4 py-2 text-sm font-bold bg-gradient-to-r from-[#e8834a] to-[#f5a870] text-white rounded-lg hover:shadow-lg hover:shadow-[#e8834a]/50 transition-all duration-300 transform hover:scale-105" %>
      </div>
    <% end %>
  </div>
</header>