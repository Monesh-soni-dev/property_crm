<header class="bg-brand text-white shadow-[0_20px_50px_-24px_rgba(15,23,42,0.8)]">
  <div class="max-w-6xl mx-auto flex flex-col gap-4 px-4 py-4 sm:px-6 lg:px-8 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">
      <%= link_to root_path, class: "inline-flex items-center gap-3" do %>
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-accent text-sm font-semibold text-white shadow-lg">PP</span>
        <div>
          <p class="text-lg font-semibold tracking-tight text-white">PlotPlans</p>
          <p class="text-sm text-slate-200">Modern construction workspace</p>
        </div>
      <% end %>
    </div>

    <nav class="flex flex-wrap items-center justify-center gap-3 text-sm text-white">
      <%= link_to "Dashboard", root_path, class: "rounded-full bg-white/10 px-4 py-2 text-white transition hover:bg-white/20 hover:text-white" %>
      <%= link_to "Properties", properties_path, class: "rounded-full bg-white/10 px-4 py-2 text-white transition hover:bg-white/20 hover:text-white" %>
    </nav>

    <div class="flex flex-wrap items-center justify-end gap-3">
      <% if user_signed_in? %>
        <span class="rounded-full bg-white/15 px-3 py-2 text-sm text-white"><%= current_user&.initials %></span>
        <span class="hidden text-sm text-slate-200 sm:inline"><%= current_user&.full_name %></span>
        <%= link_to "Sign Out", destroy_user_session_path, method: :delete, class: "inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand transition hover:bg-slate-100 hover:text-brand" %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path, class: "text-sm text-white/90 hover:text-white" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "inline-flex items-center rounded-full bg-accent px-4 py-2 text-sm font-semibold text-white shadow-lg transition hover:bg-[#f5b972]" %>
      <% end %>
    </div>
  </div>
</header>
