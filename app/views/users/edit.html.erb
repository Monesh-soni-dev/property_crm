<div class="container mx-auto px-4 py-8 max-w-4xl">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Profile</h1>
    <p class="text-gray-600">Update your profile information and preferences</p>
  </div>

  <!-- Flash Messages -->
  <% if flash[:notice] %>
    <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <!-- Edit Form -->
  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <%= form_with(model: @user, url: dashboard_profile_path, method: :patch, 
        class: "space-y-8 p-8", 
        local: true,
        html: { multipart: true }) do |f| %>
      
      <!-- Profile Photo Section -->
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Profile Photo</h3>
        <div class="flex items-center space-x-6">
          <div class="shrink-0">
            <% if @user.photo.attached? %>
              <div class="w-24 h-24 rounded-full overflow-hidden">
                <%= image_tag @user.photo, class: "w-full h-full object-cover" %>
              </div>
            <% else %>
              <div class="w-24 h-24 rounded-full bg-gray-200 flex items-center justify-center">
                <span class="text-2xl font-bold text-gray-500"><%= @user.initials %></span>
              </div>
            <% end %>
          </div>
          <div class="flex-1">
            <%= f.label :photo, "Change profile photo", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.file_field :photo, 
                class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer",
                accept: "image/png, image/jpg, image/jpeg",
                onchange: "previewEditPhoto(event)" %>
            <p class="text-xs text-gray-500 mt-1">PNG, JPG, or JPEG (max 5MB)</p>
            <% if @user.photo.attached? %>
              <div class="mt-3">
                <label class="flex items-center">
                  <%= f.check_box :remove_photo, class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
                  <span class="ml-2 text-sm text-gray-600">Remove current photo</span>
                </label>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Basic Information -->
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Basic Information</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :first_name, 
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                placeholder: "Enter your first name" %>
            <% if @user.errors[:first_name].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @user.errors[:first_name].first %></p>
            <% end %>
          </div>
          
          <div>
            <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :last_name, 
                class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                placeholder: "Enter your last name" %>
            <% if @user.errors[:last_name].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @user.errors[:last_name].first %></p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Contact Information</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, 
                class: "w-full px-4 py-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                placeholder: "Enter your email address" %>
            <% if @user.errors[:email].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @user.errors[:email].first %></p>
            <% end %>
          </div>
          
          <div>
            <%= f.label :mobile_number, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :mobile_number, 
                class: "w-full px-4 py-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                placeholder: "Enter your 10-digit mobile number",
                maxlength: 10 %>
            <% if @user.errors[:mobile_number].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @user.errors[:mobile_number].first %></p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Location Information -->
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Location Information</h3>
        <div class="space-y-6">
          <div>
            <%= f.label :address, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :address, rows: 3,
                class: "w-full px-4 py-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition resize-none",
                placeholder: "Enter your complete address" %>
            <% if @user.errors[:address].any? %>
              <p class="mt-1 text-sm text-red-600"><%= @user.errors[:address].first %></p>
            <% end %>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= f.label :city, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :city, 
                  class: "w-full px-4 py-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                  placeholder: "Enter your city" %>
              <% if @user.errors[:city].any? %>
                <p class="mt-1 text-sm text-red-600"><%= @user.errors[:city].first %></p>
              <% end %>
            </div>
            
            <div>
              <%= f.label :state, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :state, 
                  class: "w-full px-4 py-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                  placeholder: "Enter your state" %>
              <% if @user.errors[:state].any? %>
                <p class="mt-1 text-sm text-red-600"><%= @user.errors[:state].first %></p>
              <% end %>
            </div>
            
            <div>
              <%= f.label :pincode, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :pincode, 
                  class: "w-full px-4 py-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition",
                  placeholder: "Enter 6-digit pincode",
                  maxlength: 6 %>
              <% if @user.errors[:pincode].any? %>
                <p class="mt-1 text-sm text-red-600"><%= @user.errors[:pincode].first %></p>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Submit Buttons -->
      <div class="flex justify-between items-center pt-6 border-t border-gray-200">
        <%= link_to dashboard_profile_path, class: "text-gray-600 hover:text-gray-500 font-medium" do %>
          <svg class="w-5 h-5 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7l7-7m-7 7h18"></path>
          </svg>
          Cancel
        <% end %>
        
        <div class="space-x-4">
          <%= link_to dashboard_profile_path, class: "px-6 py-3 bg-gray-600 text-white font-medium rounded-lg hover:bg-gray-700 transition-colors" do %>
            View Profile
          <% end %>
          
          <%= f.submit "Update Profile", class: "px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
function previewEditPhoto(event) {
  const file = event.target.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = function(e) {
      console.log('New photo selected for preview');
    };
    reader.readAsDataURL(file);
  }
}
</script>
