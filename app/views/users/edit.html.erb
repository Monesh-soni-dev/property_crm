<div class="container mx-auto px-4 py-8 max-w-4xl">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Profile</h1>
    <p class="text-gray-600">Update your profile information and preferences</p>
  </div>

  <!-- Flash Messages -->
  <% if flash[:notice] %>
    <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <!-- Edit Form -->
  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <%= form_with(model: @user, url: profile_path, method: :patch, 
        class: "space-y-8 p-8", 
        local: true,
        html: { multipart: true }) do |f| %>
      
      <!-- Profile Photo Section -->
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-8 border border-blue-100">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-xl font-semibold text-gray-900 flex items-center">
            <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Profile Photo
          </h3>
          <div class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium">
            Optional
          </div>
        </div>
        
        <div class="flex items-center space-x-8">
          <div class="relative group">
            <div class="w-32 h-32 rounded-full overflow-hidden ring-4 ring-white shadow-xl transform transition-transform duration-200 group-hover:scale-105">
              <% if @user.photo.attached? %>
                <%= image_tag @user.photo, class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                  <span class="text-3xl font-bold text-white"><%= @user.initials %></span>
                </div>
              <% end %>
            </div>
            <div class="absolute bottom-0 right-0 w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center shadow-lg">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
          </div>
          
          <div class="flex-1 space-y-4">
            <div>
              <%= f.label :photo, "Upload new photo", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <div class="relative">
                <%= f.file_field :photo, 
                    class: "w-full text-sm text-gray-500 file:mr-4 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-blue-700 cursor-pointer transition-all duration-200",
                    accept: "image/png, image/jpg, image/jpeg",
                    onchange: "previewEditPhoto(event)" %>
              </div>
              <p class="text-xs text-gray-500 mt-2 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                PNG, JPG, or JPEG (max 5MB)
              </p>
            </div>
            
            <% if @user.photo.attached? %>
              <div class="flex items-center p-3 bg-yellow-50 border border-yellow-200 rounded-lg">
                <%= f.check_box :remove_photo, class: "rounded border-yellow-300 text-blue-600 focus:ring-blue-500" %>
                <span class="ml-2 text-sm text-yellow-800">Remove current photo</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Basic Information -->
      <div class="bg-gradient-to-r from-purple-50 to-pink-50 rounded-2xl p-6 border border-purple-100">
        <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          Basic Information
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :first_name, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= f.text_field :first_name, 
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all duration-200 bg-white shadow-sm",
                placeholder: "Enter your first name" %>
            <% if @user.errors[:first_name].any? %>
              <p class="mt-2 text-sm text-red-600 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <%= @user.errors[:first_name].first %>
              </p>
            <% end %>
          </div>
          
          <div>
            <%= f.label :last_name, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= f.text_field :last_name, 
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition-all duration-200 bg-white shadow-sm",
                placeholder: "Enter your last name" %>
            <% if @user.errors[:last_name].any? %>
              <p class="mt-2 text-sm text-red-600 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <%= @user.errors[:last_name].first %>
              </p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-6 border border-green-100">
        <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Contact Information
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :email, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= f.email_field :email, 
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-all duration-200 bg-white shadow-sm",
                placeholder: "Enter your email address" %>
            <% if @user.errors[:email].any? %>
              <p class="mt-2 text-sm text-red-600 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <%= @user.errors[:email].first %>
              </p>
            <% end %>
          </div>
          
          <div>
            <%= f.label :mobile_number, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= f.text_field :mobile_number, 
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-all duration-200 bg-white shadow-sm",
                placeholder: "Enter your 10-digit mobile number",
                maxlength: 10 %>
            <% if @user.errors[:mobile_number].any? %>
              <p class="mt-2 text-sm text-red-600 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <%= @user.errors[:mobile_number].first %>
              </p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Location Information -->
      <div class="bg-gradient-to-r from-orange-50 to-amber-50 rounded-2xl p-6 border border-orange-100">
        <h3 class="text-xl font-semibold text-gray-900 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Location Information
        </h3>
        <div class="space-y-6">
          <div>
            <%= f.label :address, class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <%= f.text_area :address, rows: 3,
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all duration-200 bg-white shadow-sm resize-none",
                placeholder: "Enter your complete address" %>
            <% if @user.errors[:address].any? %>
              <p class="mt-2 text-sm text-red-600 flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <%= @user.errors[:address].first %>
              </p>
            <% end %>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <%= f.label :city, class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= f.text_field :city, 
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all duration-200 bg-white shadow-sm",
                  placeholder: "Enter your city" %>
              <% if @user.errors[:city].any? %>
                <p class="mt-2 text-sm text-red-600 flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <%= @user.errors[:city].first %>
                </p>
              <% end %>
            </div>
            
            <div>
              <%= f.label :state, class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= f.text_field :state, 
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all duration-200 bg-white shadow-sm",
                  placeholder: "Enter your state" %>
              <% if @user.errors[:state].any? %>
                <p class="mt-2 text-sm text-red-600 flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <%= @user.errors[:state].first %>
                </p>
              <% end %>
            </div>
            
            <div>
              <%= f.label :pincode, class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= f.text_field :pincode, 
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all duration-200 bg-white shadow-sm",
                  placeholder: "Enter 6-digit pincode",
                  maxlength: 6 %>
              <% if @user.errors[:pincode].any? %>
                <p class="mt-2 text-sm text-red-600 flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <%= @user.errors[:pincode].first %>
                </p>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Submit Buttons -->
      <div class="flex justify-between items-center pt-6 border-t border-gray-200">
        <%= link_to profile_path, class: "inline-flex items-center px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-xl transition-all duration-200 transform hover:scale-105" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7l7-7m-7 7h18"></path>
          </svg>
          Cancel
        <% end %>
        
        <div class="flex items-center gap-3">
          <%= link_to profile_path, class: "inline-flex items-center px-6 py-3 bg-gradient-to-r from-gray-600 to-gray-700 hover:from-gray-700 hover:to-gray-800 text-white font-medium rounded-xl transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
            View Profile
          <% end %>
          
          <%= f.submit "Update Profile", class: "inline-flex items-center px-8 py-3 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold rounded-xl transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
function previewEditPhoto(event) {
  const file = event.target.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = function(e) {
      console.log('New photo selected for preview');
    };
    reader.readAsDataURL(file);
  }
}
</script>
