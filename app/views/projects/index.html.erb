<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">All Projects</h1>
      <p class="text-sm text-gray-600 mt-1"><%= @total_projects %> total projects · <%= @active_projects %> active</p>
    </div>
    <% if user_signed_in? %>
      <%= link_to "New Project", new_project_path, class: "bg-amber-700 text-white px-4 py-2 rounded-lg hover:bg-amber-600 shadow-md transition duration-200" %>
    <% end %>
  </div>

  <% if @projects.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @projects.each do |project| %>
        <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition">
          <div class="flex justify-between items-start mb-4">
            <h2 class="text-xl font-semibold text-gray-900"><%= project.name %></h2>
            <span class="px-2 py-1 text-xs rounded-full
              <%= project.status == 'active' ? 'bg-green-100 text-green-800' :
                 project.status == 'completed' ? 'bg-blue-100 text-blue-800' :
                 'bg-gray-100 text-gray-800' %>">
              <%= project.status&.humanize || 'Unknown' %>
            </span>
          </div>

          <!-- Project Image Preview -->
          <% if project.images.attached? %>
            <div class="mb-4">
              <%= image_tag project.images.first, class: "w-full h-32 object-cover rounded-lg border" %>
            </div>
          <% end %>

          <% if project.description.present? %>
            <p class="text-gray-600 mb-4 line-clamp-3"><%= project.description %></p>
          <% end %>

          <div class="space-y-2 mb-4">
            <% if project.properties.any? %>
              <div class="flex items-center text-sm text-gray-500">
                <span class="mr-2">🏠</span>
                <span><%= project.properties.count %> properties</span>
              </div>
            <% end %>

            <% if project.start_date %>
              <div class="flex items-center text-sm text-gray-500">
                <span class="mr-2">📅</span>
                <span>Started: <%= project.start_date.strftime('%b %d, %Y') %></span>
              </div>
            <% end %>

            <% if project.user %>
              <div class="flex items-center text-sm text-gray-500">
                <span class="mr-2">👤</span>
                <span>By: <%= project.user.first_name %> <%= project.user.last_name %></span>
              </div>
            <% end %>
          </div>

          <div class="flex justify-between items-center pt-4 border-t border-gray-100">
            <%= link_to "View Details", project_path(project), class: "bg-amber-700 text-white px-3 py-2 rounded-lg hover:bg-amber-600 font-medium transition duration-200 shadow-sm" %>
            <% if user_signed_in? && project.user == current_user %>
              <div class="flex gap-2">
                <%= link_to "Edit", edit_project_path(project), class: "bg-amber-100 text-amber-900 px-3 py-2 rounded-lg hover:bg-amber-200 text-sm font-medium transition duration-200" %>
                <%= link_to "Delete", project_path(project), method: :delete,
                    data: { confirm: "Are you sure you want to delete this project?" },
                    class: "text-red-600 hover:text-red-800 text-sm font-medium transition duration-200" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="text-6xl mb-4">🏗️</div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">No Projects Found</h3>
      <p class="text-gray-500 mb-6">There are no projects available at the moment.</p>
      <% if user_signed_in? %>
        <%= link_to "Create Your First Project", new_project_path, class: "bg-amber-700 text-white px-6 py-3 rounded-lg hover:bg-amber-600 font-medium shadow-md transition duration-200" %>
      <% else %>
        <%= link_to "Sign In to Create Projects", new_user_session_path, class: "bg-amber-700 text-white px-6 py-3 rounded-lg hover:bg-amber-600 font-medium shadow-md transition duration-200" %>
      <% end %>
    </div>
  <% end %>
</div>