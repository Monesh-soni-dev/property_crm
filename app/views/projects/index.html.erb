<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">All Projects</h1>
      <p class="text-sm text-gray-600 mt-1"><%= @total_projects %> total projects · <%= @active_projects %> active</p>
    </div>
    <% if user_signed_in? && !current_user.customer? %>
      <%= link_to "New Project", new_project_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition-all transform hover:scale-105 shadow-lg" %>
    <% end %>
  </div>

  <% if @projects.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @projects.each do |project| %>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden flex flex-col h-full hover:shadow-md transition-shadow duration-200">

          <!-- Image (fixed height, always same) -->
          <div class="h-44 bg-gray-100 shrink-0 overflow-hidden">
            <% if project.images.attached? %>
              <%= image_tag project.images.first, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100">
                <svg class="w-12 h-12 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
              </div>
            <% end %>
          </div>

          <!-- Card body — grows to fill height -->
          <div class="flex flex-col flex-1 p-5">

            <!-- Title + status badge -->
            <div class="flex items-start justify-between gap-2 mb-2">
              <h2 class="text-base font-bold text-gray-900 leading-snug line-clamp-2"><%= project.name %></h2>
              <span class="shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                <%= case project.status
                    when 'active'     then 'bg-green-100 text-green-700'
                    when 'completed'  then 'bg-blue-100 text-blue-700'
                    when 'on_hold'    then 'bg-yellow-100 text-yellow-700'
                    else 'bg-gray-100 text-gray-600'
                    end %>">
                <%= project.status&.humanize || 'Unknown' %>
              </span>
            </div>

            <!-- Description — fixed 2-line clamp -->
            <p class="text-sm text-gray-500 line-clamp-2 mb-4">
              <%= project.description.presence || 'No description provided.' %>
            </p>

            <!-- Meta row -->
            <div class="grid grid-cols-2 gap-2 mb-4">
              <div class="flex items-center gap-1.5 text-xs text-gray-500">
                <svg class="w-3.5 h-3.5 text-blue-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                <span><%= project.properties.count %> properties</span>
              </div>
              <% if project.location.present? %>
                <div class="flex items-center gap-1.5 text-xs text-gray-500">
                  <svg class="w-3.5 h-3.5 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  <span class="truncate"><%= project.location %></span>
                </div>
              <% end %>
              <% if project.start_date %>
                <div class="flex items-center gap-1.5 text-xs text-gray-500">
                  <svg class="w-3.5 h-3.5 text-teal-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <span><%= project.start_date.strftime('%b %Y') %></span>
                </div>
              <% end %>
              <% if project.user %>
                <div class="flex items-center gap-1.5 text-xs text-gray-500">
                  <svg class="w-3.5 h-3.5 text-purple-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <span class="truncate"><%= project.user.first_name %></span>
                </div>
              <% end %>
            </div>

            <!-- Footer actions — always pinned to bottom -->
            <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
              <%= link_to "View Details", project_path(project), class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors" %>
              <% if user_signed_in? && project.user == current_user %>
                <div class="flex gap-1.5">
                  <%= link_to "Edit", edit_project_path(project), class: "px-3 py-2 rounded-lg bg-orange-50 text-orange-700 hover:bg-orange-100 text-xs font-semibold transition-colors" %>
                  <%= link_to "Delete", project_path(project), method: :delete,
                      data: { confirm: "Are you sure you want to delete this project?" },
                      class: "px-3 py-2 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 text-xs font-semibold transition-colors" %>
                </div>
              <% end %>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <div class="text-6xl mb-4">🏗️</div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">No Projects Found</h3>
      <p class="text-gray-500 mb-6">There are no projects available at the moment.</p>
      <% if user_signed_in? && !current_user.customer? %>
        <%= link_to "Create Your First Project", new_project_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-2xl font-semibold shadow-lg transition-all transform hover:scale-105" %>
      <% else %>
        <%= link_to "Sign In to Create Projects", new_user_session_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-2xl font-semibold shadow-lg transition-all transform hover:scale-105" %>
      <% end %>
    </div>
  <% end %>
</div>