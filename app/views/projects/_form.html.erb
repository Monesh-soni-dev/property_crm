<%= form_with(model: project, class: "space-y-6", data: { controller: "project-properties" }) do |form| %>
  <% if project.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            There were <%= pluralize(project.errors.count, "error") %> with your submission:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc pl-5 space-y-1">
              <% project.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Project Name -->
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Enter project name" %>
    </div>

    <!-- Project Status -->
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status, [['Active', 'active'], ['Completed', 'completed'], ['On Hold', 'on_hold']], { include_blank: 'Select status' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <!-- Project Description -->
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Describe your project..." %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Start Date -->
    <div>
      <%= form.label :start_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.date_field :start_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- End Date -->
    <div>
      <%= form.label :end_date, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.date_field :end_date, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <!-- Project Images -->
  <div>
    <%= form.label :images, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :images, multiple: true, accept: "image/*", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-500 mt-1">Select multiple images (JPG, PNG, GIF, etc.)</p>
    <% if project.persisted? && project.images.attached? %>
      <div class="mt-3">
        <p class="text-sm font-medium text-gray-700 mb-2">Current Images:</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          <% project.images.each do |image| %>
            <div class="relative">
              <%= image_tag image, class: "w-full h-24 object-cover rounded-lg border" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Project Videos -->
  <div>
    <%= form.label :videos, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.file_field :videos, multiple: true, accept: "video/*", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    <p class="text-sm text-gray-500 mt-1">Select multiple videos (MP4, AVI, MOV, etc.)</p>
    <% if project.persisted? && project.videos.attached? %>
      <div class="mt-3">
        <p class="text-sm font-medium text-gray-700 mb-2">Current Videos:</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
          <% project.videos.each do |video| %>
            <div class="relative">
              <video class="w-full h-32 object-cover rounded-lg border" controls>
                <%= video_tag video, class: "w-full h-32 object-cover rounded-lg border" %>
              </video>
              <p class="text-xs text-gray-500 mt-1"><%= video.filename %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Project Properties</h2>
        <p class="text-sm text-gray-500">Add one or more properties while creating the project.</p>
      </div>
      <button
        type="button"
        class="px-4 py-2 border border-amber-700 text-amber-700 rounded-lg hover:bg-amber-50 font-medium transition duration-200"
        data-action="project-properties#add"
      >
        Add Another Property
      </button>
    </div>

    <template data-project-properties-target="template">
      <%= form.fields_for :properties, Property.new(status: "available"), child_index: "NEW_RECORD" do |property_fields| %>
        <%= render "property_fields", form: property_fields %>
      <% end %>
    </template>

    <div class="space-y-4" data-project-properties-target="container">
      <%= form.fields_for :properties do |property_fields| %>
        <%= render "property_fields", form: property_fields %>
      <% end %>
    </div>
  </div>

  <!-- Submit Button -->
  <div class="flex justify-end space-x-4">
    <%= link_to "Cancel", projects_path, class: "px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition duration-200" %>
    <%= form.submit class: "px-6 py-2 bg-amber-700 text-white rounded-lg hover:bg-amber-600 font-medium transition duration-200 shadow-md focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" %>
  </div>
<% end %>
