<div class="container mx-auto px-4 py-8">
  <div class="mb-8">
    <%= link_to "← Back to Projects", projects_path, class: "text-amber-700 hover:text-amber-600 mb-4 inline-block font-medium transition duration-200" %>

    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-start mb-6">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @project.name %></h1>
          <% if @project.description.present? %>
            <p class="text-gray-600 text-lg"><%= @project.description %></p>
          <% end %>
        </div>

        <div class="flex items-center gap-4">
          <span class="px-3 py-1 rounded-full text-sm font-medium
            <%= @project.status == 'active' ? 'bg-green-100 text-green-800' :
               @project.status == 'completed' ? 'bg-blue-100 text-blue-800' :
               @project.status == 'on_hold' ? 'bg-yellow-100 text-yellow-800' :
               'bg-gray-100 text-gray-800' %>">
            <%= @project.status&.humanize || 'Unknown' %>
          </span>

          <% if user_signed_in? && @project.user == current_user %>
            <div class="flex gap-2">
              <%= link_to "Edit Project", edit_project_path(@project), class: "bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded-lg font-medium transition-all shadow-md" %>
              <%= link_to "Delete", @project, method: :delete,
                  data: { confirm: "Are you sure you want to delete this project and all its properties?" },
                  class: "bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 font-medium transition duration-200 shadow-md" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Project Details -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-gray-50 rounded-lg p-4">
          <div class="text-2xl font-bold text-gray-900"><%= @total_properties %></div>
          <div class="text-sm text-gray-600">Total Properties</div>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <div class="text-2xl font-bold text-green-600"><%= @available_properties %></div>
          <div class="text-sm text-gray-600">Available</div>
        </div>

        <div class="bg-blue-50 rounded-lg p-4">
          <div class="text-2xl font-bold text-blue-600"><%= @project.properties.where(status: :booked).count %></div>
          <div class="text-sm text-gray-600">Booked</div>
        </div>

        <div class="bg-red-50 rounded-lg p-4">
          <div class="text-2xl font-bold text-red-600"><%= @project.properties.where(status: :sold).count %></div>
          <div class="text-sm text-gray-600">Sold</div>
        </div>
      </div>

      <!-- Project Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <% if @project.start_date || @project.end_date %>
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-900 mb-3">Timeline</h3>
            <div class="space-y-2">
              <% if @project.start_date %>
                <div class="flex justify-between">
                  <span class="text-gray-600">Start Date:</span>
                  <span class="font-medium"><%= @project.start_date.strftime('%B %d, %Y') %></span>
                </div>
              <% end %>
              <% if @project.end_date %>
                <div class="flex justify-between">
                  <span class="text-gray-600">End Date:</span>
                  <span class="font-medium"><%= @project.end_date.strftime('%B %d, %Y') %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-3">Project Owner</h3>
          <div class="flex items-center">
            <div class="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center text-white font-semibold mr-3">
              <%= @project.user&.first_name&.first || '?' %>
            </div>
            <div>
              <div class="font-medium text-gray-900"><%= @project.user&.first_name&.to_s + " " + @project.user&.last_name&.to_s || 'Unknown' %></div>
              <div class="text-sm text-gray-600"><%= @project.user&.email %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Project Media Section -->
  <% if @project.images.attached? || @project.videos.attached? %>
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Project Media</h2>

      <!-- Images -->
      <% if @project.images.attached? %>
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Images</h3>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <% @project.images.each do |image| %>
              <%= image_tag image, class: "w-full h-48 object-cover rounded-lg border hover:shadow-lg transition-shadow" %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Videos -->
      <% if @project.videos.attached? %>
        <div>
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Videos</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% @project.videos.each do |video| %>
              <div class="relative">
                <video class="w-full h-64 object-cover rounded-lg border" controls>
                  <source src="<%= url_for(video) %>" type="<%= video.content_type %>">
                  Your browser does not support the video tag.
                </video>
                <div class="mt-2 flex justify-between items-center">
                  <p class="text-sm text-gray-600"><%= video.filename %></p>
                  <a href="<%= url_for(video) %>" target="_blank" class="text-blue-600 hover:text-blue-700 text-sm font-medium">
                    Download
                  </a>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Properties Section -->
  <div class="bg-white rounded-lg shadow-md p-6">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold text-gray-900">Properties in this Project</h2>
    </div>

    <% if @properties.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @properties.each do |property| %>
          <div class="border border-gray-200 rounded-lg p-4 hover:border-blue-300 transition">
            <div class="flex justify-between items-start mb-3">
              <h3 class="font-semibold text-gray-900"><%= property.title %></h3>
              <span class="px-2 py-1 text-xs rounded-full
                <%= property.available? ? 'bg-green-100 text-green-800' :
                   property.sold? ? 'bg-red-100 text-red-800' :
                   'bg-gray-100 text-gray-800' %>">
                <%= property.status&.humanize || 'Unknown' %>
              </span>
            </div>

            <div class="space-y-1 text-sm text-gray-600 mb-3">
              <div>Unit: <%= property.unit_number %></div>
              <div>Floor: <%= property.floor %></div>
              <div><%= format_property_type(property.property_type) %></div>
            </div>
            <% if property.description.present? %>
              <p class="text-sm text-gray-500 mb-3 line-clamp-2"><%= property.description %></p>
            <% end %>

            <div class="flex justify-between items-center">
              <span class="font-semibold text-gray-900"><%= number_to_currency(property.price, unit: '₹', format: '%u%n') %></span>
              <%= link_to "View Details", project_property_path(@project, property), class: "text-amber-700 hover:text-amber-600 text-sm font-medium" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <div class="text-4xl mb-4">🏠</div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No Properties Yet</h3>
        <p class="text-gray-600 mb-4">This project doesn't have any properties added yet.</p>
        <% if user_signed_in? && @project.user == current_user %>
          <%= link_to "Add First Property", new_project_property_path(@project), class: "bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>