<div class="rounded-xl border border-gray-200 bg-gray-50 p-4 space-y-4" data-project-properties-target="propertyRow">
  <div class="flex items-center justify-between gap-4">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-700">Property Details</h3>
    <button
      type="button"
      class="text-sm font-medium text-red-600 hover:text-red-700"
      data-action="project-properties#remove"
    >
      Remove
    </button>
  </div>

  <%= form.hidden_field :_destroy, value: "0", data: { project_properties_target: "destroyField" } %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., 2 BHK Garden View" %>
    </div>

    <div>
      <%= form.label :unit_number, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :unit_number, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "e.g., A-101" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div>
      <%= form.label :floor, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :floor, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Floor" %>
    </div>

    <div>
      <%= form.label :property_type, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :property_type, [['Apartment', 'apartment'], ['Villa', 'villa'], ['Plot', 'plot'], ['Commercial', 'commercial']], { include_blank: 'Select type' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :price, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :price, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Price" %>
    </div>

    <div>
      <%= form.label :area, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :area, step: :any, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Area sq ft" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div>
      <%= form.label :bedrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bedrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Bedrooms" %>
    </div>

    <div>
      <%= form.label :bathrooms, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.number_field :bathrooms, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Bathrooms" %>
    </div>

    <div>
      <%= form.label :facing, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :facing, [['North', 'north'], ['South', 'south'], ['East', 'east'], ['West', 'west'], ['North-East', 'north_east'], ['North-West', 'north_west'], ['South-East', 'south_east'], ['South-West', 'south_west']], { include_blank: 'Select facing' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :status, [['Available', 'available'], ['Blocked', 'blocked'], ['Booked', 'booked'], ['Registered', 'registered'], ['Sold', 'sold']], { selected: form.object.status.presence || 'available' }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Describe this property..." %>
  </div>
</div>
