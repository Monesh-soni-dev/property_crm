<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-2xl font-['Playfair_Display'] font-semibold">
      All Properties
    </h1>
    <p class="text-sm text-gray-400 mt-1">
      <%= @total_properties %> total properties · <%= @available_properties %> available · <%= @sold_properties %> sold
    </p>
  </div>
  <% if user_signed_in? %>
    <div class="flex gap-2">
      <%= link_to properties_path, class: "flex items-center gap-1.5 bg-[#1a2e4a] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[#2a4a72] transition" do %>
        View All Properties
      <% end %>
    </div>
  <% end %>
</div>

<!-- Property Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-white border border-gray-200 rounded-xl p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
        🏠
      </div>
      <div>
        <p class="text-sm font-medium text-gray-600">Total Properties</p>
        <p class="text-2xl font-bold text-gray-900"><%= @total_properties %></p>
      </div>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
        ✅
      </div>
      <div>
        <p class="text-sm font-medium text-gray-600">Available</p>
        <p class="text-2xl font-bold text-gray-900"><%= @available_properties %></p>
      </div>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center">
        ❌
      </div>
      <div>
        <p class="text-sm font-medium text-gray-600">Sold</p>
        <p class="text-2xl font-bold text-gray-900"><%= @sold_properties %></p>
      </div>
    </div>
  </div>
</div>

<!-- Properties Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
  <% @properties.each do |property| %>
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-blue-400 transition group">
      <div class="h-48 bg-stone-100 relative flex items-center justify-center">
        <% if property.images.attached? %>
          <%= image_tag property.images.first, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="text-6xl text-gray-300">🏠</div>
        <% end %>
        <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-xs font-semibold
          <%= property.available? ? 'bg-green-50 text-green-800 border border-green-200' :
             property.sold? ? 'bg-red-50 text-red-800 border border-red-200' :
             property.blocked? ? 'bg-yellow-50 text-yellow-800 border border-yellow-200' :
             'bg-gray-50 text-gray-800 border border-gray-200' %>">
          <%= property.status&.humanize || 'Unknown' %>
        </span>
      </div>
      <div class="p-4">
        <h3 class="font-semibold text-gray-900 mb-1"><%= property.title %></h3>
        <p class="text-sm text-gray-500 mb-2"><%= property.project.name %> · Floor <%= property.floor %></p>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-600"><%= property.property_type %></span>
          <span class="font-semibold text-gray-900"><%= number_to_currency(property.price, unit: '₹', format: '%u%n') %></span>
        </div>
        <div class="flex items-center justify-between text-xs text-gray-500 mt-2">
          <span><%= property.area %> sq ft</span>
          <span><%= property.bedrooms %> BHK</span>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @properties.empty? %>
  <div class="text-center py-12">
    <div class="text-6xl mb-4">🏠</div>
    <h3 class="text-xl font-semibold text-gray-900 mb-2">No Properties Found</h3>
    <p class="text-gray-500">There are no properties available at the moment.</p>
    <% if user_signed_in? %>
      <div class="mt-4">
        <%= link_to "Add Your First Property", projects_path, class: "bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700 transition" %>
      </div>
    <% end %>
  </div>
<% end %>